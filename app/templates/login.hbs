{{page-title "Login — Career Caddy"}}
<RouteLayout
  @flashMessages={{this.flashMessages}}
  @noSubnav={{true}}
  @mainClass="login-main"
>
  <:subnav></:subnav>
  <:main>
    <div class="landing-hero landing-hero--centered">
      <div class="landing-hero-overlay"></div>
      <div class="login-card">
        <div class="login-card-brand">
          <span class="brand-title">Career<span>Caddy</span></span>
        </div>

        <h1 class="login-card-title">Welcome back.</h1>
        <p class="login-card-sub">Sign in to your account to continue.</p>

        <form {{on "submit" this.authenticate}} class="login-form">
          <div class="login-field">
            <label for="username">Username</label>
            <input
              id="username"
              type="text"
              placeholder="Enter username"
              value={{this.username}}
              {{on "change" this.updateUsername}}
              autocomplete="username"
            />
          </div>
          <div class="login-field">
            <label for="password">Password</label>
            <input
              id="password"
              type="password"
              placeholder="Enter password"
              value={{this.password}}
              {{on "change" this.updatePassword}}
              autocomplete="current-password"
            />
          </div>
          <button type="submit" class="login-submit">Sign in</button>
          <button
            type="button"
            class="login-demo"
            {{on "click" this.tryDemo}}
          >Try Demo</button>
        </form>

        <p class="login-card-setup">
          <LinkTo @route="forgot-password">Forgot your password?</LinkTo>
        </p>

        {{#if this.bootstrapOpen}}
          <p class="login-card-setup">
            First time here?
            <LinkTo @route="setup">Set up Career Caddy</LinkTo>
          </p>
        {{/if}}

        <p class="login-card-setup">
          Don't have an account?
          <LinkTo @route="signup">Sign up</LinkTo>
        </p>
      </div>
    </div>
  </:main>
</RouteLayout>