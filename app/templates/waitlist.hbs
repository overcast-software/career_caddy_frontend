{{page-title "Join the Waiting List — Career Caddy"}}
<RouteLayout @noSubnav={{true}} @mainClass="login-main">
  <:subnav></:subnav>
  <:main>
    <div class="landing-hero landing-hero--centered">
      <div class="landing-hero-overlay"></div>
      <div class="login-card">
        <div class="login-card-brand">
          <span class="brand-title">Career<span>Caddy</span></span>
        </div>

        {{#if this.submitted}}
          <h1 class="login-card-title">You're on the list.</h1>
          <p class="login-card-sub">
            We'll let you know when Career Caddy is ready for you.
          </p>
          <div class="mt-6">
            <LinkTo @route="login" class="login-submit">Back to Login</LinkTo>
          </div>
        {{else}}
          <h1 class="login-card-title">Join the waiting list.</h1>
          <p class="login-card-sub">
            Career Caddy is currently in early access. Enter your email and
            we'll notify you when a spot opens up.
          </p>

          {{#if this.errorMessage}}
            <div class="error">{{this.errorMessage}}</div>
          {{/if}}

          <form {{on "submit" this.submit}} class="login-form">
            <div class="login-field">
              <label for="waitlist-email">Email address</label>
              <input
                id="waitlist-email"
                type="email"
                placeholder="you@example.com"
                value={{this.email}}
                {{on "input" this.updateEmail}}
                autocomplete="email"
                required
              />
            </div>
            <button type="submit" class="login-submit" disabled={{this.saving}}>
              {{if this.saving "Joining..." "Join Waiting List"}}
            </button>
          </form>

          <p class="login-card-setup">
            Already have an account?
            <LinkTo @route="login">Sign in</LinkTo>
          </p>
        {{/if}}
      </div>
    </div>
  </:main>
</RouteLayout>