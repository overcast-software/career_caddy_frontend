{{page-title "Edit Profile — Settings"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="settings.profile" class="nav-link">Profile</LinkTo>
    <LinkTo @route="settings.data" class="nav-link">Data</LinkTo>
    <LinkTo @route="settings.appearance" class="nav-link">Appearance</LinkTo>
    <LinkTo @route="settings.ai-spend" class="nav-link">AI Spend</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-semibold">Edit Profile</h1>
      </div>

      <fieldset disabled={{this.isSubmitting}}>
        <form class="builder-form two-col" {{on "submit" this.save}}>
          <div class="field">
            <label class="field-label" for="settings-first-name">First name</label>
            <input
              id="settings-first-name"
              type="text"
              value={{this.firstName}}
              {{on "input" (fn this.updateField "firstName")}}
            />
          </div>

          <div class="field">
            <label class="field-label" for="settings-last-name">Last name</label>
            <input
              id="settings-last-name"
              type="text"
              value={{this.lastName}}
              {{on "input" (fn this.updateField "lastName")}}
            />
          </div>

          <div class="field">
            <label class="field-label" for="settings-email">Email</label>
            <input
              id="settings-email"
              type="email"
              value={{this.email}}
              {{on "input" (fn this.updateField "email")}}
            />
          </div>

          <div class="field">
            <label class="field-label" for="settings-phone">Phone</label>
            <input
              id="settings-phone"
              type="tel"
              value={{this.phone}}
              {{on "input" (fn this.updateField "phone")}}
            />
          </div>

          <div class="field">
            <label class="field-label" for="settings-linkedin">LinkedIn</label>
            <input
              id="settings-linkedin"
              type="url"
              value={{this.linkedin}}
              placeholder="https://linkedin.com/in/..."
              {{on "input" (fn this.updateField "linkedin")}}
            />
          </div>

          <div class="field">
            <label class="field-label" for="settings-github">GitHub</label>
            <input
              id="settings-github"
              type="url"
              value={{this.github}}
              placeholder="https://github.com/..."
              {{on "input" (fn this.updateField "github")}}
            />
          </div>

          <div class="field-full">
            <label class="field-label" for="settings-address">Address</label>
            <textarea
              id="settings-address"
              rows="2"
              value={{this.address}}
              {{on "input" (fn this.updateField "address")}}
            ></textarea>
          </div>

          <div class="col-span-full">
            <label class="field-label">Snippets</label>
            <p class="text-xs text-gray-400 mt-1 mb-1">Reusable text you can
              copy with one click — prompts, URLs, taglines, etc.</p>
          </div>
          {{#each this.links as |link index|}}
            <div
              class="col-span-full min-w-0 flex gap-3 pb-3
                {{unless
                  (eq index 0)
                  'border-t border-gray-200 dark:border-gray-600 pt-4'
                }}"
            >
              <div class="w-1/4 min-w-0 flex flex-col gap-2">
                <input
                  type="text"
                  value={{link.name}}
                  placeholder="Label"
                  aria-label="Snippet label"
                  class="w-full min-w-0 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm"
                  {{on "change" (fn this.updateLinkField index "name")}}
                />
                <div class="flex gap-2">
                  <button
                    type="button"
                    class="px-2 py-1 text-xs rounded border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30"
                    {{on "click" (fn this.removeLink index)}}
                  >Remove</button>
                  {{#if (eq index this.lastLinkIndex)}}
                    <button
                      type="button"
                      class="px-2 py-1 text-xs rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"
                      {{on "click" this.addLink}}
                    >+ Add</button>
                  {{/if}}
                </div>
              </div>
              <textarea
                placeholder="Content to copy"
                aria-label="Snippet content"
                rows="3"
                class="flex-1 min-w-0 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 px-3 py-2 text-sm resize-y"
                {{on "change" (fn this.updateLinkField index "url")}}
              >{{link.url}}</textarea>
            </div>
          {{/each}}
          {{#unless this.links.length}}
            <div class="field-row col-span-full">
              <button
                type="button"
                class="btn small"
                {{on "click" this.addLink}}
              >+ Add Snippet</button>
            </div>
          {{/unless}}

          <div class="form-actions justify-end">
            <button type="submit" class="btn primary">
              {{if this.isSubmitting "Saving\u2026" "Save"}}
            </button>
            <button
              type="button"
              class="btn"
              {{on "click" this.cancel}}
            >Cancel</button>
          </div>
        </form>
      </fieldset>
    </div>
  </:main>
</RouteLayout>