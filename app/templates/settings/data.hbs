{{page-title "Data — Settings"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="settings.index" class="nav-link">Profile</LinkTo>
    <LinkTo @route="settings.data" class="nav-link">Data</LinkTo>
    <LinkTo @route="settings.appearance" class="nav-link">Appearance</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card max-w-lg">
      <h1 class="text-xl font-semibold mb-2">Data</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        Export your career data as an Excel spreadsheet, or import from a
        previously exported file.
      </p>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
        <button
          type="button"
          class="btn primary inline-flex items-center gap-2"
          disabled={{this.isExporting}}
          {{on "click" this.exportData}}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"
            />
          </svg>
          {{if this.isExporting "Exporting\u2026" "Export (.xlsx)"}}
        </button>

        <label
          class="btn inline-flex items-center gap-2 cursor-pointer
            {{if this.isImporting 'opacity-50 pointer-events-none'}}"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-5 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"
            />
          </svg>
          {{if this.isImporting "Importing\u2026" "Import (.xlsx)"}}
          <input
            type="file"
            accept=".xlsx"
            class="sr-only"
            disabled={{this.isImporting}}
            {{on "change" this.importData}}
          />
        </label>
      </div>
    </div>
  </:main>
</RouteLayout>