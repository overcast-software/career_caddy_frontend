{{page-title "Profile — Settings"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="settings.index" class="nav-link">Profile</LinkTo>
    <LinkTo @route="settings.data" class="nav-link">Data</LinkTo>
    <LinkTo @route="settings.appearance" class="nav-link">Appearance</LinkTo>
    <LinkTo @route="settings.ai-spend" class="nav-link">AI Spend</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-semibold">Profile</h1>
        {{#unless this.isEditing}}
          <button
            type="button"
            class="btn primary"
            {{on "click" this.edit}}
          >Edit</button>
        {{/unless}}
      </div>

      {{#if this.isEditing}}
        <fieldset disabled={{this.isSubmitting}}>
          <form class="builder-form two-col" {{on "submit" this.save}}>
            <div class="field">
              <label class="field-label" for="settings-first-name">First name</label>
              <input
                id="settings-first-name"
                type="text"
                value={{this.firstName}}
                {{on "input" (fn this.updateField "firstName")}}
              />
            </div>

            <div class="field">
              <label class="field-label" for="settings-last-name">Last name</label>
              <input
                id="settings-last-name"
                type="text"
                value={{this.lastName}}
                {{on "input" (fn this.updateField "lastName")}}
              />
            </div>

            <div class="field">
              <label class="field-label" for="settings-email">Email</label>
              <input
                id="settings-email"
                type="email"
                value={{this.email}}
                {{on "input" (fn this.updateField "email")}}
              />
            </div>

            <div class="field">
              <label class="field-label" for="settings-phone">Phone</label>
              <input
                id="settings-phone"
                type="tel"
                value={{this.phone}}
                {{on "input" (fn this.updateField "phone")}}
              />
            </div>

            <div class="field">
              <label
                class="field-label"
                for="settings-linkedin"
              >LinkedIn</label>
              <input
                id="settings-linkedin"
                type="url"
                value={{this.linkedin}}
                placeholder="https://linkedin.com/in/..."
                {{on "input" (fn this.updateField "linkedin")}}
              />
            </div>

            <div class="field">
              <label class="field-label" for="settings-github">GitHub</label>
              <input
                id="settings-github"
                type="url"
                value={{this.github}}
                placeholder="https://github.com/..."
                {{on "input" (fn this.updateField "github")}}
              />
            </div>

            <div class="field-full">
              <label class="field-label" for="settings-address">Address</label>
              <textarea
                id="settings-address"
                rows="2"
                value={{this.address}}
                {{on "input" (fn this.updateField "address")}}
              ></textarea>
            </div>

            <div class="field-row">
              <label class="field-label w-full">Snippets</label>
              <p class="text-xs text-gray-400 -mt-1 mb-1">Reusable text you can
                copy with one click — prompts, URLs, taglines, etc.</p>
            </div>
            {{#each this.links as |link index|}}
              <div class="flex items-center gap-2 col-span-full">
                <input
                  type="text"
                  value={{link.name}}
                  placeholder="Label"
                  aria-label="Snippet label"
                  class="w-1/4 rounded border border-gray-300 px-3 py-2 text-sm"
                  {{on "change" (fn this.updateLinkField index "name")}}
                />
                <input
                  type="text"
                  value={{link.url}}
                  placeholder="Content to copy"
                  aria-label="Snippet content"
                  class="flex-1 rounded border border-gray-300 px-3 py-2 text-sm"
                  {{on "change" (fn this.updateLinkField index "url")}}
                />
                <button
                  type="button"
                  class="px-2 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50 shrink-0"
                  {{on "click" (fn this.removeLink index)}}
                >Remove</button>
              </div>
            {{/each}}
            <div class="field-row">
              <button
                type="button"
                class="btn small"
                {{on "click" this.addLink}}
              >Add Snippet</button>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn primary">
                {{if this.isSubmitting "Saving\u2026" "Save"}}
              </button>
              <button
                type="button"
                class="btn"
                {{on "click" this.cancel}}
              >Cancel</button>
            </div>
          </form>
        </fieldset>
      {{else}}
        <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
          <div>
            <dt class="font-medium text-gray-500 dark:text-gray-400">Name</dt>
            <dd
              class="mt-1 text-gray-900 dark:text-gray-100"
            >{{this.model.name}}</dd>
          </div>
          <div>
            <dt
              class="font-medium text-gray-500 dark:text-gray-400"
            >Username</dt>
            <dd
              class="mt-1 text-gray-900 dark:text-gray-100"
            >{{this.model.username}}</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-500 dark:text-gray-400">Email</dt>
            <dd class="mt-1 text-gray-900 dark:text-gray-100">{{or
                this.model.email
                "—"
              }}</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-500 dark:text-gray-400">Phone</dt>
            <dd class="mt-1 text-gray-900 dark:text-gray-100">{{or
                this.model.phone
                "—"
              }}</dd>
          </div>
          <div>
            <dt
              class="font-medium text-gray-500 dark:text-gray-400"
            >LinkedIn</dt>
            <dd class="mt-1 text-gray-900 dark:text-gray-100 truncate">{{or
                this.model.linkedin
                "—"
              }}</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-500 dark:text-gray-400">GitHub</dt>
            <dd class="mt-1 text-gray-900 dark:text-gray-100 truncate">{{or
                this.model.github
                "—"
              }}</dd>
          </div>
          <div class="col-span-2">
            <dt
              class="font-medium text-gray-500 dark:text-gray-400"
            >Address</dt>
            <dd
              class="mt-1 text-gray-900 dark:text-gray-100 whitespace-pre-line"
            >{{or this.model.address "—"}}</dd>
          </div>
          {{#if this.links.length}}
            <div class="col-span-2">
              <dt
                class="font-medium text-gray-500 dark:text-gray-400"
              >Snippets</dt>
              <dd class="mt-1">
                <ul class="space-y-1">
                  {{#each this.links as |link index|}}
                    <li class="text-sm">
                      <span
                        class="font-medium text-gray-700 dark:text-gray-300"
                      >{{link.name}}</span>
                      {{#if link.url}}
                        —
                        <span
                          class="text-gray-500 dark:text-gray-400"
                        >{{link.url}}</span>
                        <button
                          type="button"
                          class="ml-1 px-2 py-0.5 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
                          {{on "click" (fn this.copySnippet index)}}
                        >{{if
                            (eq this.copiedSnippetIndex index)
                            "Copied!"
                            "Copy"
                          }}</button>
                      {{/if}}
                    </li>
                  {{/each}}
                </ul>
              </dd>
            </div>
          {{/if}}
        </dl>
      {{/if}}
    </div>
  </:main>
</RouteLayout>