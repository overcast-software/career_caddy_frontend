{{page-title (concat "@" this.username " — Career Caddy")}}

{{! Public profile page (CC #51) — the human-readable twin of a user's
    ActivityPub outbox. Renders chromeless (app/controllers/application.js's
    `chromeless` getter skips <MainApplication> for this route) so a logged-out
    visitor sees a clean, shareable page with no auth-gated app navigation. All
    data comes from two AllowAny endpoints (the user resource + their federated
    job-posts feed); no private library data is read here. }}
<div class="mx-auto max-w-2xl px-4 py-10">
  {{#if this.user}}
    <header class="mb-8 flex items-center gap-4">
      {{! Avatar placeholder (initial letter). Room here for a real avatar + bio
          block once the api surfaces those on the public user resource. }}
      <div
        class="flex size-16 shrink-0 items-center justify-center rounded-full bg-blue-100 text-2xl font-semibold uppercase text-blue-700 dark:bg-blue-900/40 dark:text-blue-300"
        aria-hidden="true"
      >
        {{this.initial}}
      </div>
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
          {{this.displayName}}
        </h1>
        <p
          class="text-sm text-gray-500 dark:text-gray-400"
        >@{{this.username}}</p>
      </div>
    </header>

    {{#if this.posts.length}}
      <ul class="space-y-4">
        {{#each this.posts as |post|}}
          <li
            class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <a
              href={{post.link}}
              target="_blank"
              rel="noopener noreferrer"
              class="text-lg font-medium text-gray-900 hover:text-blue-600 dark:text-gray-100 dark:hover:text-blue-400"
            >
              {{post.title}}
            </a>
            <div
              class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-gray-500 dark:text-gray-400"
            >
              {{#if post.companyName}}
                <span>{{post.companyName}}</span>
              {{/if}}
              {{#if post.location}}
                {{#if post.companyName}}
                  <span aria-hidden="true">&middot;</span>
                {{/if}}
                <span>{{post.location}}</span>
              {{/if}}
              {{#let (or post.postedDate post.createdAt) as |postedAt|}}
                {{#if postedAt}}
                  {{#if (or post.companyName post.location)}}
                    <span aria-hidden="true">&middot;</span>
                  {{/if}}
                  <time datetime={{postedAt}}>
                    {{format-date postedAt "MMM D, YYYY"}}
                  </time>
                {{/if}}
              {{/let}}
            </div>
          </li>
        {{/each}}
      </ul>

      {{! Infinite-scroll sentinel — when it enters the viewport, load the next
          keyset page. Rendered only while a cursor remains (this.hasMore), so
          the IntersectionObserver detaches once the feed is exhausted. The
          "Loading more…" line shows only mid-fetch. No load-more button. }}
      {{#if this.hasMore}}
        <div
          {{in-viewport this.loadMore}}
          class="py-6 text-center text-sm text-gray-400 dark:text-gray-500"
        >
          {{#if this.loadingMore}}Loading more…{{/if}}
        </div>
      {{/if}}
    {{else}}
      {{! Empty state — known user, no audience-public posts yet. The empty →
          populated transition (once they publish one) is the end-to-end
          publish test signal. }}
      <div
        class="rounded-lg border border-dashed border-gray-300 px-6 py-16 text-center dark:border-gray-700"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="mx-auto size-12 text-gray-400 dark:text-gray-500"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 6.006a2.18 2.18 0 01-.75.388m-16.5-.388a2.18 2.18 0 01-.75-1.661V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m4.5 6.006a48.667 48.667 0 01-7.5 0M12 9v-.75m0 0V6.75m0 .75A2.25 2.25 0 1014.25 9.75 2.25 2.25 0 0012 7.5z"
          />
        </svg>
        <h2 class="mt-4 text-base font-medium text-gray-700 dark:text-gray-300">
          No published posts yet
        </h2>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
          When
          {{this.displayName}}
          publishes a job post, it'll show up here.
        </p>
      </div>
    {{/if}}
  {{else}}
    {{! Not-found state — unknown username (or the api slice isn't deployed
        yet). No console error, no login bounce; just a clean message. }}
    <div
      class="rounded-lg border border-dashed border-gray-300 px-6 py-16 text-center dark:border-gray-700"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="mx-auto size-12 text-gray-400 dark:text-gray-500"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"
        />
      </svg>
      <h1 class="mt-4 text-base font-medium text-gray-700 dark:text-gray-300">
        Profile not found
      </h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        We couldn't find a profile for @{{this.username}}.
      </p>
    </div>
  {{/if}}
</div>