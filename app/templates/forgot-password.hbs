{{page-title "Reset Password — Career Caddy"}}
<RouteLayout @noSubnav={{true}} @mainClass="login-main">
  <:subnav></:subnav>
  <:main>
    <div class="landing-hero landing-hero--centered">
      <div class="landing-hero-overlay"></div>
      <div class="login-card">
        <div class="login-card-brand">
          <span class="brand-title">Career<span>Caddy</span></span>
        </div>

        {{#if this.submitted}}
          <h1 class="login-card-title">Check your email.</h1>
          <p class="login-card-sub">
            If an account with that email exists, we've sent a password reset link.
          </p>
          <div class="mt-6">
            <LinkTo @route="login" class="login-submit">Back to Login</LinkTo>
          </div>
        {{else}}
          <h1 class="login-card-title">Reset your password.</h1>
          <p class="login-card-sub">
            Enter your email address and we'll send you a reset link.
          </p>

          {{#if this.errorMessage}}
            <div class="error">{{this.errorMessage}}</div>
          {{/if}}

          <form {{on "submit" this.submit}} class="login-form">
            <div class="login-field">
              <label for="reset-email">Email address</label>
              <input
                id="reset-email"
                type="email"
                placeholder="you@example.com"
                value={{this.email}}
                {{on "input" this.updateEmail}}
                autocomplete="email"
                required
              />
            </div>
            <button type="submit" class="login-submit" disabled={{this.saving}}>
              {{if this.saving "Sending..." "Send Reset Link"}}
            </button>
          </form>

          <p class="login-card-setup">
            Remember your password?
            <LinkTo @route="login">Sign in</LinkTo>
          </p>
        {{/if}}
      </div>
    </div>
  </:main>
</RouteLayout>
