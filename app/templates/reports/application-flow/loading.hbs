{{! Rendered by Ember while reports.application-flow's model hook is
    pending. Keeps the page skeleton visible (subnav + heading) so the
    user lands on the right page immediately instead of the previous
    page hanging until the fetch resolves. }}
<RouteLayout>
  <:subnav>
    <LinkTo
      @route="reports.application-flow"
      class="nav-link nav-link-active"
    >Application Flow</LinkTo>
    <LinkTo @route="reports.sources" class="nav-link">Sources</LinkTo>
  </:subnav>
  <:main>
    <div class="space-y-4">
      <header class="flex flex-wrap items-baseline justify-between gap-2">
        <h1 class="text-xl font-semibold">Application Flow</h1>
      </header>
      <div
        class="animate-pulse rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700"
      >
        <div class="h-4 w-1/3 rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="mt-4 h-[360px] rounded bg-gray-100 dark:bg-gray-800"></div>
      </div>
    </div>
  </:main>
</RouteLayout>