{{! Rendered by Ember while reports.application-flow's model hook is
    pending. The skeleton mirrors the real layout — subnav tabs, header
    with counts, filter bar, and a sankey-shaped column placeholder —
    so the page feels populated instantly even before the report
    payload arrives. No JS; all shimmer via animate-pulse + nth-child
    column widths. }}
<RouteLayout>
  <:subnav>
    <LinkTo
      @route="reports.application-flow"
      class="nav-link nav-link-active"
    >Application Flow</LinkTo>
    <LinkTo @route="reports.sources" class="nav-link">Sources</LinkTo>
  </:subnav>
  <:main>
    <div class="space-y-4">
      <header class="flex flex-wrap items-baseline justify-between gap-2">
        <h1 class="text-xl font-semibold">Application Flow</h1>
        <div
          class="animate-pulse h-4 w-48 rounded bg-gray-200 dark:bg-gray-700"
        ></div>
      </header>

      <div
        class="animate-pulse mb-4 flex flex-wrap items-center gap-3 rounded-lg border border-gray-200 bg-white p-3 dark:border-gray-700 dark:bg-gray-900"
      >
        <div class="h-6 w-24 rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-6 w-40 rounded bg-gray-200 dark:bg-gray-700"></div>
        <div class="h-6 w-28 rounded bg-gray-200 dark:bg-gray-700"></div>
        <div
          class="ml-auto h-6 w-32 rounded bg-gray-200 dark:bg-gray-700"
        ></div>
      </div>

      <div
        class="animate-pulse rounded-lg border border-gray-200 bg-white p-6 dark:border-gray-700 dark:bg-gray-900"
      >
        {{! Sankey-shaped placeholder: five column groups of stacked
            rectangles separated by thin connector strips. Heights step
            down per column to suggest the funnel narrowing. }}
        <div class="flex h-[360px] items-stretch gap-3">
          <div class="flex flex-1 flex-col justify-center gap-2">
            <div
              class="h-[280px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
          </div>
          <div class="flex flex-1 flex-col justify-center gap-1">
            <div class="h-1 w-full rounded bg-gray-100 dark:bg-gray-800"></div>
          </div>
          <div class="flex flex-1 flex-col justify-center gap-2">
            <div
              class="h-[140px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
            <div
              class="h-[80px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
          </div>
          <div class="flex flex-1 flex-col justify-center gap-1">
            <div class="h-1 w-full rounded bg-gray-100 dark:bg-gray-800"></div>
          </div>
          <div class="flex flex-1 flex-col justify-center gap-2">
            <div
              class="h-[80px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
            <div
              class="h-[60px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
            <div
              class="h-[40px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
          </div>
          <div class="flex flex-1 flex-col justify-center gap-1">
            <div class="h-1 w-full rounded bg-gray-100 dark:bg-gray-800"></div>
          </div>
          <div class="flex flex-1 flex-col justify-center gap-2">
            <div
              class="h-[50px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
            <div
              class="h-[40px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
            <div
              class="h-[30px] w-full rounded bg-gray-200 dark:bg-gray-700"
            ></div>
          </div>
        </div>
      </div>
    </div>
  </:main>
</RouteLayout>