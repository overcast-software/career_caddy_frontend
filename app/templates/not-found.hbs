{{page-title "404 — Out of Bounds"}}
<div
  class="min-h-screen flex flex-col items-center justify-center bg-gray-900 text-gray-100 p-6"
>
  <div class="w-full max-w-2xl text-center space-y-4">
    <p
      class="font-mono text-xs tracking-[0.3em] text-emerald-400 uppercase"
    >Error 404</p>
    <h1 class="font-mono text-5xl md:text-6xl font-bold">Out of Bounds</h1>
    <p class="text-gray-400 text-sm md:text-base">
      Can't find
      <code
        class="font-mono bg-gray-800 px-1.5 py-0.5 rounded"
      >/{{@model.path}}</code>. Take a few swings while we figure out where it
      went.
    </p>

    <Games::MiniGolf />

    <div class="flex items-center justify-center gap-3 pt-2">
      <LinkTo
        @route="index"
        class="inline-flex items-center gap-1.5 rounded bg-emerald-500 hover:bg-emerald-400 text-gray-900 font-medium text-sm px-4 py-2 transition"
      >
        ← Back to the clubhouse
      </LinkTo>
    </div>
  </div>
</div>