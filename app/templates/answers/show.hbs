{{page-title "Answer"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    answer details
    {{#if this.model.favorite}}⭐{{/if}}
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="field">
        <h3>Question:</h3>
        {{this.model.question.content.content}}
      </div>
      <div class="field">
        <label
          class="block text-sm font-medium text-gray-700 mb-1"
        >Answer:</label>
        <div
          class="rounded-lg border border-gray-300 px-4 py-3 text-gray-800 whitespace-pre-wrap"
        >{{this.model.content}}</div>
        {{#if this.model.favorite}}
          <div class="favorite-indicator">⭐ Favorite Answer</div>
        {{/if}}
      </div>
      <div class="actions">
        <button
          type="button"
          class="btn small"
          {{on "click" this.copyToClipboard}}
        >{{this.copyButtonText}}</button>
        <LinkTo
          @route="answers.edit"
          @model={{this.model}}
          class="btn"
        >Edit</LinkTo>
      </div>
    </div>
  </:main>
</RouteLayout>