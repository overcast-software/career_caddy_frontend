<div class="mt-4 border-t border-gray-200 pt-4 space-y-3">
  <div class="flex items-center justify-between">
    <h3 class="text-sm font-semibold text-gray-700">Answers</h3>
    <LinkTo class="btn small" @route="questions.show.answers.new">New Answer</LinkTo>
  </div>
  <Answers::DetailList
    @answers={{this.model}}
    @editRoute="questions.show.answers.edit"
    @showQuestion={{false}}
    @onDelete={{this.removeAnswer}}
  />
</div>