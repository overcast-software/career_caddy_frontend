<div class="mt-4 border-t border-gray-200 pt-4 space-y-3">
  <div class="flex items-center justify-between">
    <h3 class="text-sm font-semibold text-gray-700">Answers</h3>
    <LinkTo
      class="btn small"
      @route="questions.show.answers.new"
      @model={{this.model.question}}
    >New Answer</LinkTo>
  </div>
  {{#each this.model.answers as |answer|}}
    <div class="panel-card">
      <MarkdownToHtml @markdown={{answer.content}} />
      <div class="flex gap-2 mt-2">
        <LinkTo
          @route="questions.show.answers.show"
          @model={{answer}}
          class="btn small"
        >View</LinkTo>
        <LinkTo
          @route="questions.show.answers.edit"
          @model={{answer}}
          class="btn small"
        >Edit</LinkTo>
      </div>
    </div>
  {{else}}
    <p class="text-sm text-gray-400">No answers yet.</p>
  {{/each}}
</div>