<Answers::Show @answer={{this.model}} @editRoute="questions.show.answers.edit">
  <:actions>
    <button
      type="button"
      class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
      {{on "click" this.copyToClipboard}}
    >{{this.copyButtonText}}</button>
    <LinkTo
      @route="questions.show.answers"
      class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
    >All Answers</LinkTo>
  </:actions>
</Answers::Show>