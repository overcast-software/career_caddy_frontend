{{page-title "Questions"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <div class="controls">
      <input
        type="search"
        aria-label="search"
        placeholder="Search questions..."
        value={{this.search}}
        {{on "input" this.onSearchInput}}
      />
      <LinkTo @route="questions.new" class="btn">+ New Question</LinkTo>
    </div>
  </:subnav>
  <:main>
    {{#if this.isSearching}}
      <div class="py-8 text-center text-sm text-gray-400">Searching…</div>
    {{else}}
      {{#each this.model as |question|}}
        <Panel::Card>
          <div class="question-header">
            <p>{{question.company.name}}: {{question.content}}</p>
          </div>
          <p class="text-sm text-gray-500">answers:
            {{question.answers.length}}</p>
          <div class="flex gap-2 mt-2">
            <LinkTo
              @route="questions.show.answers"
              @model={{question}}
              class="btn small"
            >show</LinkTo>
            <LinkTo
              @route="questions.show.answers.new"
              @model={{question}}
              class="btn small"
            >answer</LinkTo>
          </div>
        </Panel::Card>
      {{else}}
        <p class="text-gray-500 text-sm py-6 text-center">No questions found.</p>
      {{/each}}
      <InfinityLoader @infinityModel={{this.model}} @hideOnInfinity={{true}}>
        <div class="py-4 text-center text-sm text-gray-400">Loading more…</div>
      </InfinityLoader>
    {{/if}}
  </:main>
</RouteLayout>