{{page-title "Scrape Profiles — Admin"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
    <LinkTo @route="admin.scrape-profiles" class="nav-link">Scrape Profiles</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <h1 class="text-xl font-semibold mb-4">Scrape Profiles</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        Domain-level profiles that capture page structure and extraction
        patterns from past scrapes.
      </p>

      {{#if this.model.length}}
        <div
          class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800"
        >
          <table class="min-w-full text-sm">
            <thead
              class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600"
            >
              <tr>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Hostname</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Auth</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Success Rate</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Scrape Count</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Last Success</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Tier</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Enabled</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
              {{#each this.model as |profile|}}
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                  <td
                    class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100"
                  >
                    <LinkTo
                      @route="admin.scrape-profiles.show"
                      @model={{profile.id}}
                      class="text-accent-600 dark:text-accent-400 hover:underline"
                    >
                      {{profile.hostname}}
                    </LinkTo>
                  </td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                    {{#if profile.requiresAuth}}
                      <span
                        class="inline-block px-2 py-0.5 text-xs rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300"
                      >Auth</span>
                    {{else}}
                      <span class="text-gray-400">No</span>
                    {{/if}}
                  </td>
                  <td class="px-4 py-3">
                    <span class={{profile.successRateClass}}>
                      {{profile.successRatePercent}}%
                    </span>
                  </td>
                  <td
                    class="px-4 py-3 text-gray-600 dark:text-gray-300"
                  >{{profile.scrapeCount}}</td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                    {{#if profile.lastSuccessAt}}
                      {{moment-format profile.lastSuccessAt "MMM D, YYYY"}}
                    {{else}}
                      —
                    {{/if}}
                  </td>
                  <td class="px-4 py-3">
                    <span
                      class="inline-block px-2 py-0.5 text-xs rounded-full bg-accent-100 text-accent-800 dark:bg-accent-900/30 dark:text-accent-300"
                    >{{profile.tierLabel}}</span>
                  </td>
                  <td class="px-4 py-3">
                    {{#if profile.enabled}}
                      <span
                        class="text-green-600 dark:text-green-400"
                      >Yes</span>
                    {{else}}
                      <span class="text-red-600 dark:text-red-400">No</span>
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <EmptyState
          @message="No scrape profiles yet. Profiles are created automatically after successful scrapes."
        />
      {{/if}}
    </div>
  </:main>
</RouteLayout>