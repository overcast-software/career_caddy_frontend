{{page-title (concat this.model.hostname " — Scrape Profile")}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
    <LinkTo @route="admin.scrape-profiles" class="nav-link">Scrape Profiles</LinkTo>
    <LinkTo @route="admin.companies.index" class="nav-link">Companies</LinkTo>
    <LinkTo @route="admin.dedupe" class="nav-link">Dedupe</LinkTo>
    <LinkTo @route="admin.ai-models" class="nav-link">AI Models</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="flex items-center justify-between mb-6 gap-3 flex-wrap">
        <h1 class="text-xl font-semibold">{{this.model.hostname}}</h1>
        <div class="flex items-center gap-3 flex-wrap">
          <button
            type="button"
            class="inline-flex items-center gap-1.5 rounded-md bg-accent-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-accent-500 disabled:opacity-60 disabled:cursor-not-allowed dark:bg-accent-500 dark:hover:bg-accent-400"
            disabled={{or this.sharpening (not this.canSharpen)}}
            title={{this.sharpenDisabledHint}}
            data-test-sharpen-profile
            {{on "click" this.sharpenProfile}}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-4"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
              />
            </svg>
            {{if this.sharpening "Queuing…" "Sharpen with browser"}}
          </button>
          <LinkTo
            @route="admin.scrape-profiles.index"
            class="text-sm text-accent-600 dark:text-accent-400 hover:underline"
          >Back to profiles</LinkTo>
        </div>
      </div>

      <div
        class="mb-6 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 p-4"
      >
        <h2
          class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3"
        >Stats</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
          <div>
            <span class="text-gray-500 dark:text-gray-400">Auth Required</span>
            <div class="font-medium text-gray-900 dark:text-gray-100">
              {{if this.model.requiresAuth "Yes" "No"}}
            </div>
          </div>
          <div>
            <span class="text-gray-500 dark:text-gray-400">Success Rate</span>
            <div class="font-medium {{this.model.successRateClass}}">
              {{this.model.successRatePercent}}%
            </div>
          </div>
          <div>
            <span class="text-gray-500 dark:text-gray-400">Scrape Count</span>
            <div class="font-medium text-gray-900 dark:text-gray-100">
              {{this.model.scrapeCount}}
            </div>
          </div>
          <div>
            <span class="text-gray-500 dark:text-gray-400">Avg Content Length</span>
            <div class="font-medium text-gray-900 dark:text-gray-100">
              {{if this.model.avgContentLength this.model.avgContentLength "—"}}
            </div>
          </div>
          <div>
            <span class="text-gray-500 dark:text-gray-400">Last Success</span>
            <div class="font-medium text-gray-900 dark:text-gray-100">
              {{#if this.model.lastSuccessAt}}
                {{moment-format this.model.lastSuccessAt "MMM D, YYYY h:mm a"}}
              {{else}}
                —
              {{/if}}
            </div>
          </div>
          <div>
            <span class="text-gray-500 dark:text-gray-400">Last Updated</span>
            <div class="font-medium text-gray-900 dark:text-gray-100">
              {{#if this.model.updatedAt}}
                {{format-date this.model.updatedAt "MMM D, YYYY h:mm a"}}
              {{else}}
                —
              {{/if}}
            </div>
          </div>
        </div>
      </div>

      <form class="builder-form" {{on "submit" this.save}}>
        <h2
          class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3"
        >Configuration</h2>

        <div class="field">
          <label class="field-label" for="preferredTier">Preferred Tier</label>
          <select
            id="preferredTier"
            class="field-input"
            {{on "change" (fn this.updateField "preferredTier")}}
          >
            <option
              value="auto"
              selected={{eq this.preferredTier "auto"}}
            >Auto</option>
            <option value="0" selected={{eq this.preferredTier "0"}}>Tier 0 —
              Deterministic</option>
            <option value="1" selected={{eq this.preferredTier "1"}}>Tier 1 —
              Mini + Hints</option>
            <option value="2" selected={{eq this.preferredTier "2"}}>Tier 2 —
              Haiku</option>
            <option value="3" selected={{eq this.preferredTier "3"}}>Tier 3 —
              Sonnet</option>
          </select>
        </div>

        <div class="field">
          <label class="field-label" for="extractionHints">Extraction Hints</label>
          <textarea
            id="extractionHints"
            class="field-input h-24"
            value={{this.extractionHints}}
            placeholder="LLM-generated hints about this domain's job posting format..."
            {{on "input" (fn this.updateField "extractionHints")}}
          ></textarea>
        </div>

        <div class="field">
          <label class="field-label" for="pageStructure">Page Structure</label>
          <textarea
            id="pageStructure"
            class="field-input h-24"
            value={{this.pageStructure}}
            placeholder="LLM-generated description of the page layout..."
            {{on "input" (fn this.updateField "pageStructure")}}
          ></textarea>
        </div>

        <div class="field">
          <label class="field-label" for="cssSelectors">CSS Selectors (JSON)</label>
          <textarea
            id="cssSelectors"
            class="field-input h-24 font-mono text-xs"
            value={{this.cssSelectors}}
            placeholder='{"title": "h1.job-title", "company": ".company-name"}'
            {{on "input" (fn this.updateField "cssSelectors")}}
          ></textarea>
        </div>

        <div class="field">
          <label class="flex items-center gap-2 cursor-pointer">
            <input
              type="checkbox"
              checked={{this.enabled}}
              {{on "change" this.toggleEnabled}}
            />
            <span class="field-label mb-0">Enabled</span>
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn primary">Save</button>
          <button
            type="button"
            class="btn"
            {{on "click" this.cancel}}
          >Cancel</button>
        </div>
      </form>
    </div>
  </:main>
</RouteLayout>