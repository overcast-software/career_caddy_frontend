{{page-title "AI Models — Admin"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
    <LinkTo @route="admin.scrape-profiles" class="nav-link">Scrape Profiles</LinkTo>
    <LinkTo @route="admin.ai-models" class="nav-link">AI Models</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="mb-4">
        <h1 class="text-xl font-semibold">AI Models</h1>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
          Live view of the model each agent role resolves to, as seen by the API
          container. Every row's env var is overridable — a
          <span
            class="rounded bg-gray-200 px-1.5 py-0.5 font-mono text-[0.7rem] text-gray-700 dark:bg-gray-700 dark:text-gray-300"
          >default</span>
          source just means no env value is currently set, so the built-in
          fallback applies. Host-run agents (poller, pipeline) read their own
          env and may differ. Changes require a restart of the relevant service.
        </p>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr
              class="border-b border-gray-200 dark:border-gray-700 text-left text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400"
            >
              <th class="pb-2 pr-4 font-medium">Role</th>
              <th class="pb-2 pr-4 font-medium">Purpose</th>
              <th class="pb-2 pr-4 font-medium">Env Var</th>
              <th class="pb-2 pr-4 font-medium">Current Model</th>
              <th class="pb-2 font-medium">Source</th>
            </tr>
          </thead>
          <tbody>
            {{#each this.rows as |row|}}
              <tr
                class="border-b border-gray-100 dark:border-gray-700 last:border-0"
              >
                <td
                  class="py-3 pr-4 font-mono text-xs text-gray-900 dark:text-gray-100"
                >{{row.role}}</td>
                <td
                  class="py-3 pr-4 text-gray-700 dark:text-gray-300"
                >{{row.purpose}}</td>
                <td
                  class="py-3 pr-4 font-mono text-xs text-accent-700 dark:text-accent-400"
                >{{row.env_var}}</td>
                <td
                  class="py-3 pr-4 font-mono text-xs text-gray-900 dark:text-gray-100"
                >{{row.resolved}}</td>
                <td class="py-3 text-xs">
                  {{#if (eq row.source "env")}}
                    <span
                      class="rounded bg-emerald-100 px-2 py-0.5 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300"
                    >env</span>
                  {{else}}
                    <span
                      class="rounded bg-gray-200 px-2 py-0.5 text-gray-700 dark:bg-gray-700 dark:text-gray-300"
                    >default</span>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
            <tr class="border-t-2 border-gray-200 dark:border-gray-700">
              <td
                class="py-3 pr-4 text-xs italic text-gray-500 dark:text-gray-400"
                colspan="2"
              >
                Global fallback when no role-specific override is set
              </td>
              <td
                class="py-3 pr-4 font-mono text-xs text-accent-700 dark:text-accent-400"
              >CADDY_DEFAULT_MODEL</td>
              <td
                class="py-3 pr-4 font-mono text-xs text-gray-900 dark:text-gray-100"
              >{{this.globalDefault}}</td>
              <td class="py-3 text-xs">
                {{#if (eq this.globalDefaultSource "env")}}
                  <span
                    class="rounded bg-emerald-100 px-2 py-0.5 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300"
                  >env</span>
                {{else}}
                  <span
                    class="rounded bg-gray-200 px-2 py-0.5 text-gray-700 dark:bg-gray-700 dark:text-gray-300"
                  >default</span>
                {{/if}}
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div
        class="mt-6 rounded-md border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900 dark:border-amber-900/40 dark:bg-amber-950/30 dark:text-amber-200"
      >
        <p class="font-medium">How to change</p>
        <p class="mt-1">
          Edit
          <code
            class="rounded bg-amber-100 px-1 py-0.5 font-mono text-xs dark:bg-amber-900/40"
          >.env</code>
          (or
          <code
            class="rounded bg-amber-100 px-1 py-0.5 font-mono text-xs dark:bg-amber-900/40"
          >ai/.envrc</code>
          for host-run agents), then restart the relevant service:
        </p>
        <ul class="mt-2 list-disc space-y-1 pl-5">
          <li>
            <code
              class="rounded bg-amber-100 px-1 py-0.5 font-mono text-xs dark:bg-amber-900/40"
            >docker compose restart chat</code>
            for
            <code class="font-mono text-xs">CHAT_MODEL</code>
          </li>
          <li>Restart host-run agents (pipeline, poller) for the others</li>
        </ul>
      </div>

      <div class="mt-6">
        <h2
          class="mb-2 text-sm font-semibold text-gray-700 dark:text-gray-300"
        >Curated suggestions</h2>
        <div class="flex flex-wrap gap-2">
          {{#each this.suggestions as |model|}}
            <code
              class="rounded bg-gray-100 px-2 py-1 font-mono text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-300"
            >{{model}}</code>
          {{/each}}
        </div>
        <p class="mt-3 text-xs text-gray-500 dark:text-gray-400">
          pydantic-ai accepts arbitrary strings of the form
          <code class="font-mono">provider:model-name</code>; the list above is
          just what we've used.
        </p>
      </div>
    </div>
  </:main>
</RouteLayout>