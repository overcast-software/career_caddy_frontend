{{page-title "Invitations — Admin"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
    <LinkTo @route="admin.scrape-profiles" class="nav-link">Scrape Profiles</LinkTo>
    <LinkTo @route="admin.ai-models" class="nav-link">AI Models</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <h1 class="text-xl font-semibold mb-4">Invitations</h1>

      {{#if this.model.length}}
        <div
          class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800"
        >
          <table class="min-w-full text-sm">
            <thead
              class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600"
            >
              <tr>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Email</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Status</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Sent</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Expires</th>
                <th
                  class="px-4 py-3 text-right font-semibold text-gray-600 dark:text-gray-300"
                >Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
              {{#each this.model as |invitation|}}
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                  <td
                    class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100"
                  >{{invitation.email}}</td>
                  <td class="px-4 py-3">
                    {{#if (eq invitation.status "accepted")}}
                      <span
                        class="inline-block whitespace-nowrap px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400"
                      >Accepted</span>
                    {{else if (eq invitation.status "expired")}}
                      <span
                        class="inline-block whitespace-nowrap px-2 py-0.5 text-xs rounded-full bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400"
                      >Expired</span>
                    {{else}}
                      <span
                        class="inline-block whitespace-nowrap px-2 py-0.5 text-xs rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400"
                      >Pending</span>
                    {{/if}}
                  </td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                    {{#if invitation.createdAt}}
                      {{moment-format
                        invitation.createdAt
                        "MMM D, YYYY h:mm a"
                      }}
                    {{else}}
                      —
                    {{/if}}
                  </td>
                  <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                    {{#if invitation.expiresAt}}
                      {{moment-format
                        invitation.expiresAt
                        "MMM D, YYYY h:mm a"
                      }}
                    {{else}}
                      —
                    {{/if}}
                  </td>
                  <td class="px-4 py-3 text-right space-x-2">
                    {{#if (eq invitation.status "pending")}}
                      <button
                        type="button"
                        class="px-2 py-1 text-xs rounded border border-blue-200 text-blue-600 hover:bg-blue-50 dark:border-blue-800 dark:text-blue-400 dark:hover:bg-blue-900/30"
                        {{on "click" (fn this.resendInvitation invitation)}}
                      >Resend</button>
                      <button
                        type="button"
                        class="px-2 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50 dark:border-red-800 dark:text-red-400 dark:hover:bg-red-900/30"
                        {{on "click" (fn this.revokeInvitation invitation)}}
                      >Revoke</button>
                    {{else if (eq invitation.status "expired")}}
                      <button
                        type="button"
                        class="px-2 py-1 text-xs rounded border border-blue-200 text-blue-600 hover:bg-blue-50 dark:border-blue-800 dark:text-blue-400 dark:hover:bg-blue-900/30"
                        {{on "click" (fn this.resendInvitation invitation)}}
                      >Resend</button>
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <EmptyState @message="No invitations sent yet." />
      {{/if}}
    </div>
  </:main>
</RouteLayout>