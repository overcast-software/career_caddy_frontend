{{page-title "Users — Admin"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-xl font-semibold">Users</h1>
        <LinkTo @route="admin.users.new" class="btn primary">
          New User
        </LinkTo>
      </div>

      {{#if this.model.length}}
        <div class="overflow-x-auto">
          <table class="w-full text-sm table-fixed min-w-[600px]">
            <thead>
              <tr
                class="border-b border-gray-200 dark:border-gray-700 text-left text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400"
              >
                <th class="pb-2 pr-4 font-medium w-[18%]">Name</th>
                <th class="pb-2 pr-4 font-medium w-[28%]">Email</th>
                <th class="pb-2 pr-4 font-medium w-[14%]">Username</th>
                <th class="pb-2 pr-4 font-medium w-[10%]">Role</th>
                <th class="pb-2 pr-4 font-medium w-[10%]">Status</th>
                <th class="pb-2 font-medium w-[20%]">Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each this.model as |user|}}
                <tr
                  class="border-b border-gray-100 dark:border-gray-700 last:border-0"
                >
                  <td
                    class="py-3 pr-4 font-medium text-gray-900 dark:text-gray-100 truncate"
                  >{{user.name}}</td>
                  <td
                    class="py-3 pr-4 text-gray-600 dark:text-gray-300 truncate"
                  >{{user.email}}</td>
                  <td
                    class="py-3 pr-4 text-gray-500 dark:text-gray-400 truncate"
                  >{{user.username}}</td>
                  <td class="py-3 pr-4">
                    {{#if user.isStaff}}
                      <span
                        class="inline-flex items-center rounded-full bg-accent-100 px-2 py-0.5 text-xs font-medium text-accent-700 dark:bg-accent-900/40 dark:text-accent-300"
                      >Staff</span>
                    {{else if user.isGuest}}
                      <span
                        class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400"
                      >Guest</span>
                    {{else}}
                      <span
                        class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-300"
                      >User</span>
                    {{/if}}
                  </td>
                  <td class="py-3 pr-4">
                    {{#if user.isActive}}
                      <span
                        class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700 dark:bg-green-900/30 dark:text-green-400"
                      >Active</span>
                    {{else}}
                      <span
                        class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-700 dark:bg-red-900/30 dark:text-red-400"
                      >Inactive</span>
                    {{/if}}
                  </td>
                  <td class="py-3">
                    <div class="flex items-center gap-3">
                      <LinkTo
                        @route="admin.users.show"
                        @model={{user.id}}
                        class="text-sm text-accent-600 hover:underline dark:text-accent-400"
                      >Edit</LinkTo>
                      <button
                        type="button"
                        class="text-sm
                          {{if
                            user.isActive
                            'text-yellow-600 hover:text-yellow-800 dark:text-yellow-500'
                            'text-green-600 hover:text-green-800 dark:text-green-500'
                          }}"
                        {{on "click" (fn this.toggleActive user)}}
                      >
                        {{if user.isActive "Deactivate" "Activate"}}
                      </button>
                      <button
                        type="button"
                        class="text-sm text-red-600 hover:text-red-800 dark:text-red-400"
                        {{on "click" (fn this.deleteUser user)}}
                      >Delete</button>
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <EmptyState @message="No users found." />
      {{/if}}
    </div>
  </:main>
</RouteLayout>