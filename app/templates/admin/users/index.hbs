{{page-title "Users — Admin"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-xl font-semibold">Users</h1>
        <LinkTo
          @route="admin.users.new"
          class="btn primary"
        >
          New User
        </LinkTo>
      </div>

      {{#if this.model.length}}
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 text-left text-xs uppercase tracking-wide text-gray-500">
              <th class="pb-2 pr-4 font-medium">Name</th>
              <th class="pb-2 pr-4 font-medium">Email</th>
              <th class="pb-2 pr-4 font-medium">Username</th>
              <th class="pb-2 pr-4 font-medium">Role</th>
              <th class="pb-2 pr-4 font-medium">Status</th>
              <th class="pb-2 font-medium">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each this.model as |user|}}
              <tr class="border-b border-gray-100 last:border-0">
                <td class="py-3 pr-4 font-medium text-gray-900">{{user.name}}</td>
                <td class="py-3 pr-4 text-gray-600">{{user.email}}</td>
                <td class="py-3 pr-4 text-gray-500">{{user.username}}</td>
                <td class="py-3 pr-4">
                  {{#if user.isStaff}}
                    <span class="inline-flex items-center rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700">Staff</span>
                  {{else if user.isGuest}}
                    <span class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-700">Guest</span>
                  {{else}}
                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">User</span>
                  {{/if}}
                </td>
                <td class="py-3 pr-4">
                  {{#if user.isActive}}
                    <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700">Active</span>
                  {{else}}
                    <span class="inline-flex items-center rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-700">Inactive</span>
                  {{/if}}
                </td>
                <td class="py-3">
                  <div class="flex items-center gap-3">
                    <LinkTo
                      @route="admin.users.show"
                      @model={{user.id}}
                      class="text-sm text-blue-600 hover:underline"
                    >Edit</LinkTo>
                    <button
                      type="button"
                      class="text-sm {{if user.isActive 'text-yellow-600 hover:text-yellow-800' 'text-green-600 hover:text-green-800'}}"
                      {{on "click" (fn this.toggleActive user)}}
                    >
                      {{if user.isActive "Deactivate" "Activate"}}
                    </button>
                    <button
                      type="button"
                      class="text-sm text-red-600 hover:text-red-800"
                      {{on "click" (fn this.destroy user)}}
                    >Delete</button>
                  </div>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      {{else}}
        <EmptyState @message="No users found." />
      {{/if}}
    </div>
  </:main>
</RouteLayout>
