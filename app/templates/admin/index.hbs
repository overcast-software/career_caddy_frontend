{{page-title "API Keys — Admin"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-xl font-semibold">API Keys</h1>
        <button
          type="button"
          class="btn primary"
          {{on "click" this.createNew}}
        >New API Key</button>
      </div>

      {{#if this.model.length}}
        <div class="overflow-x-auto">
          <table class="w-full text-sm table-fixed min-w-[500px]">
            <colgroup>
              <col class="w-[25%]" />
              <col class="w-[15%]" />
              <col class="w-[15%]" />
              <col class="w-[15%]" />
              <col class="w-[15%]" />
              <col class="w-[15%]" />
            </colgroup>
            <thead>
              <tr
                class="border-b border-gray-200 dark:border-gray-700 text-left text-xs uppercase tracking-wide text-gray-500 dark:text-gray-400"
              >
                <th class="pb-2 pr-4 font-medium">Name</th>
                <th class="pb-2 pr-4 font-medium">Prefix</th>
                <th class="pb-2 pr-4 font-medium">Status</th>
                <th class="pb-2 pr-4 font-medium">Created</th>
                <th class="pb-2 pr-4 font-medium">Scopes</th>
                <th class="pb-2 font-medium">Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each this.model as |apiKey|}}
                <tr
                  class="border-b border-gray-100 dark:border-gray-700 last:border-0"
                >
                  <td
                    class="py-3 pr-4 font-medium text-gray-900 dark:text-gray-100 truncate"
                  >{{apiKey.name}}</td>
                  <td
                    class="py-3 pr-4 text-gray-500 dark:text-gray-400 font-mono text-xs"
                  >{{apiKey.keyPrefix}}…</td>
                  <td class="py-3 pr-4">
                    <span
                      class="{{apiKey.statusClass}}"
                    >{{apiKey.statusText}}</span>
                  </td>
                  <td
                    class="py-3 pr-4 text-gray-600 dark:text-gray-300"
                  >{{moment-format apiKey.createdAt "MMM D, YYYY"}}</td>
                  <td
                    class="py-3 pr-4 text-gray-500 dark:text-gray-400 text-xs"
                  >{{#each apiKey.scopes as |scope|}}{{scope}} {{/each}}</td>
                  <td class="py-3">
                    <div class="flex items-center gap-3">
                      <LinkTo
                        @route="admin.show"
                        @model={{apiKey.id}}
                        class="text-sm text-accent-600 hover:underline dark:text-accent-400"
                      >View</LinkTo>
                      {{#unless apiKey.isRevoked}}
                        <button
                          type="button"
                          class="text-sm text-red-600 hover:text-red-800 dark:text-red-400"
                          {{on "click" (fn this.revokeKey apiKey)}}
                        >Revoke</button>
                      {{/unless}}
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <EmptyState @message="No API keys yet." />
      {{/if}}
    </div>
  </:main>
</RouteLayout>