{{page-title (concat this.model.name " — Company Admin")}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
    <LinkTo @route="admin.scrape-profiles" class="nav-link">Scrape Profiles</LinkTo>
    <LinkTo @route="admin.companies.index" class="nav-link">Companies</LinkTo>
    <LinkTo @route="admin.dedupe" class="nav-link">Dedupe</LinkTo>
    <LinkTo @route="admin.ai-models" class="nav-link">AI Models</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card mb-6">
      <div class="flex items-center justify-between mb-2">
        <h1 class="text-xl font-semibold">{{this.model.name}}</h1>
        <LinkTo
          @route="admin.companies.index"
          class="text-sm text-accent-600 dark:text-accent-400 hover:underline"
        >Back to companies</LinkTo>
      </div>
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
        <div>
          <dt class="text-gray-500 dark:text-gray-400">ID</dt>
          <dd
            class="font-mono text-gray-900 dark:text-gray-100"
          >{{this.model.id}}</dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Job posts</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">{{or
              this.model.jobPostsCount
              0
            }}</dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Applications</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">{{or
              this.model.jobApplicationsCount
              0
            }}</dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Scrapes</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">{{or
              this.model.scrapesCount
              0
            }}</dd>
        </div>
      </dl>
      {{#if this.model.displayName}}
        <p class="mt-4 text-sm text-gray-600 dark:text-gray-400">
          Display name:
          <span class="font-medium">{{this.model.displayName}}</span>
        </p>
      {{/if}}
      <div class="mt-4 flex items-center gap-3">
        <LinkTo
          @route="companies.show"
          @model={{this.model.id}}
          class="text-sm text-accent-600 dark:text-accent-400 hover:underline"
        >View public Company page →</LinkTo>
      </div>
    </div>

    <Companies::AliasesPanel @company={{this.model}} />

    <div class="panel-card mt-6" data-test-merge-panel>
      <h2 class="text-lg font-semibold mb-2">Merge into another company</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        Move every job post, scrape, application, and alias from
        <span class="font-medium">{{this.model.name}}</span>
        into the target company. This action is permanent and removes the
        current Company row.
      </p>

      <div class="max-w-md">
        <PowerSelect
          @options={{this.emptyOptions}}
          @selected={{this.mergeTarget}}
          @search={{this.searchCompanies}}
          @searchEnabled={{true}}
          @placeholder="Search for the target company…"
          @onChange={{this.selectMergeTarget}}
          as |company|
        >
          {{company.name}}
          {{#if company.displayName}}
            <span class="text-xs text-gray-500">({{company.displayName}})</span>
          {{/if}}
        </PowerSelect>
      </div>

      {{#if this.mergeTarget}}
        <div
          class="mt-4 rounded-md bg-amber-50 p-3 ring-1 ring-inset ring-amber-200 dark:bg-amber-500/10 dark:ring-amber-500/30"
          data-test-merge-confirm
        >
          <p class="text-sm text-amber-800 dark:text-amber-200">
            Merge
            <span class="font-medium">{{this.model.name}}</span>
            (#{{this.model.id}}) into
            <span class="font-medium">{{this.mergeTarget.name}}</span>
            (#{{this.mergeTarget.id}})?
          </p>
          <div class="mt-3 flex items-center gap-2">
            <button
              type="button"
              class="btn primary"
              disabled={{this.merging}}
              {{on "click" this.confirmMerge}}
            >
              {{if this.merging "Merging…" "Confirm merge"}}
            </button>
            <button
              type="button"
              class="btn"
              disabled={{this.merging}}
              {{on "click" this.clearMergeTarget}}
            >Cancel</button>
          </div>
        </div>
      {{/if}}
    </div>
  </:main>
</RouteLayout>