{{page-title (concat this.model.sourceCompany.name " — Company Admin")}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
    <LinkTo @route="admin.scrape-profiles" class="nav-link">Scrape Profiles</LinkTo>
    <LinkTo @route="admin.companies.index" class="nav-link">Companies</LinkTo>
    <LinkTo @route="admin.dedupe" class="nav-link">Dedupe</LinkTo>
    <LinkTo @route="admin.ai-models" class="nav-link">AI Models</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card mb-6">
      <div class="flex items-center justify-between mb-2">
        <h1 class="text-xl font-semibold">{{this.model.sourceCompany.name}}</h1>
        <LinkTo
          @route="admin.companies.index"
          class="text-sm text-accent-600 dark:text-accent-400 hover:underline"
        >Back to companies</LinkTo>
      </div>
      <dl class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
        <div>
          <dt class="text-gray-500 dark:text-gray-400">ID</dt>
          <dd
            class="font-mono text-gray-900 dark:text-gray-100"
          >{{this.model.sourceCompany.id}}</dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Job posts</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">{{or
              this.model.sourceCompany.jobPostsCount
              0
            }}</dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Applications</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">{{or
              this.model.sourceCompany.jobApplicationsCount
              0
            }}</dd>
        </div>
        <div>
          <dt class="text-gray-500 dark:text-gray-400">Scrapes</dt>
          <dd class="font-medium text-gray-900 dark:text-gray-100">{{or
              this.model.sourceCompany.scrapesCount
              0
            }}</dd>
        </div>
      </dl>
      {{#if this.model.sourceCompany.displayName}}
        <p class="mt-4 text-sm text-gray-600 dark:text-gray-400">
          Display name:
          <span
            class="font-medium"
          >{{this.model.sourceCompany.displayName}}</span>
        </p>
      {{/if}}
      <div class="mt-4 flex items-center gap-3">
        <LinkTo
          @route="companies.show"
          @model={{this.model.sourceCompany.id}}
          class="text-sm text-accent-600 dark:text-accent-400 hover:underline"
        >View public Company page →</LinkTo>
      </div>
    </div>

    <Companies::AliasesPanel @company={{this.model.sourceCompany}} />

    <div class="panel-card mt-6" data-test-federation-panel>
      <h2 class="text-lg font-semibold mb-2">Federation</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        When enabled, this company exposes an ActivityStreams 2.0 actor at
        <code class="font-mono text-xs">/companies/{{or
            this.model.sourceCompany.slug
            "<slug>"
          }}/</code>
        and the public Subscribe affordance lights up. The slug is the public
        WebFinger handle.
      </p>
      <div class="space-y-3">
        <div>
          <dt class="text-xs text-gray-500 dark:text-gray-400">Slug</dt>
          <dd class="font-mono text-sm text-gray-900 dark:text-gray-100">
            {{#if this.model.sourceCompany.slug}}
              {{this.model.sourceCompany.slug}}
            {{else}}
              <span class="italic text-gray-400 dark:text-gray-500">not set</span>
            {{/if}}
          </dd>
        </div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="checkbox"
            data-test-federation-toggle
            checked={{this.model.sourceCompany.federationEnabled}}
            disabled={{this.savingFederation}}
            {{on "change" this.toggleFederationEnabled}}
          />
          <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
            Federation enabled
          </span>
          {{#if this.savingFederation}}
            <span
              class="text-xs text-gray-500 dark:text-gray-400"
            >Saving…</span>
          {{/if}}
        </label>
      </div>
    </div>

    <Companies::SearchTable
      @sourceCompany={{this.model.sourceCompany}}
      @searchResults={{this.model.searchResults}}
      @searchTerm={{this.search}}
      @isSearching={{this.isSearching}}
      @onSearch={{this.updateSearch}}
      @onSearchStart={{this.startSearching}}
    />
  </:main>
</RouteLayout>