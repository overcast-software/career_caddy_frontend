{{page-title "Companies — Admin"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="admin.index" class="nav-link">API Keys</LinkTo>
    <LinkTo @route="admin.users.index" class="nav-link">Users</LinkTo>
    <LinkTo @route="admin.waitlist" class="nav-link">Waitlist</LinkTo>
    <LinkTo @route="admin.invitations" class="nav-link">Invitations</LinkTo>
    <LinkTo @route="admin.scrape-profiles" class="nav-link">Scrape Profiles</LinkTo>
    <LinkTo @route="admin.companies.index" class="nav-link">Companies</LinkTo>
    <LinkTo @route="admin.dedupe" class="nav-link">Dedupe</LinkTo>
    <LinkTo @route="admin.ai-models" class="nav-link">AI Models</LinkTo>
  </:subnav>
  <:main>
    <div class="panel-card">
      <div
        class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
      >
        <div>
          <h1 class="text-xl font-semibold">Companies</h1>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
            Staff curation hub for the dedupe pipeline. Open a Company to merge
            it into another.
          </p>
        </div>
        <div class="sm:w-80">
          <Menus::SubnavSearch
            @value={{this.search}}
            @onSearch={{this.updateSearch}}
            @onSearchStart={{this.startSearching}}
            @placeholder="Search companies..."
          />
        </div>
      </div>

      {{#if this.relateMode}}
        <div
          class="mb-4 rounded-md bg-accent-50 p-3 ring-1 ring-inset ring-accent-200 dark:bg-accent-500/10 dark:ring-accent-500/30"
          data-test-relate-banner
        >
          <div class="flex flex-wrap items-center justify-between gap-3">
            <p class="text-sm text-accent-800 dark:text-accent-200">
              Relate mode for
              {{#if this.sourceCompany}}
                <span class="font-medium">{{this.sourceCompany.name}}</span>
                (#{{this.source}})
              {{else}}
                Company
                <span class="font-mono">#{{this.source}}</span>
                (not loaded —
                <LinkTo
                  @route="admin.companies.show"
                  @model={{this.source}}
                  class="underline"
                >open it</LinkTo>
                to enable per-row actions)
              {{/if}}
              — pick a row to merge, set as canonical, or adopt as alias.
            </p>
            <button
              type="button"
              class="btn"
              data-test-exit-relate
              {{on "click" this.exitRelateMode}}
            >Exit relate mode</button>
          </div>
        </div>
      {{/if}}

      {{#if this.isSearching}}
        <div class="py-8 text-center text-sm text-gray-400">Searching…</div>
      {{else if this.model.length}}
        <div
          class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800"
        >
          <table class="min-w-full text-sm">
            <thead
              class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600"
            >
              <tr>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >ID</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Name</th>
                <th
                  class="px-4 py-3 text-right font-semibold text-gray-600 dark:text-gray-300"
                >Job Posts</th>
                <th
                  class="px-4 py-3 text-right font-semibold text-gray-600 dark:text-gray-300"
                >Applications</th>
                <th
                  class="px-4 py-3 text-right font-semibold text-gray-600 dark:text-gray-300"
                >Scrapes</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
                >Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
              {{#each this.model as |company|}}
                <tr
                  class="hover:bg-gray-50 dark:hover:bg-gray-700/50
                    {{if (this.isSource company) 'opacity-60'}}"
                  data-test-company-row={{company.id}}
                >
                  <td
                    class="px-4 py-3 font-mono text-xs text-gray-500 dark:text-gray-400"
                  >{{company.id}}</td>
                  <td
                    class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100"
                  >
                    <LinkTo
                      @route="admin.companies.show"
                      @model={{company.id}}
                      class="text-accent-600 dark:text-accent-400 hover:underline"
                    >
                      {{company.name}}
                    </LinkTo>
                    {{#if company.displayName}}
                      <span
                        class="ml-2 text-xs text-gray-500 dark:text-gray-400"
                      >({{company.displayName}})</span>
                    {{/if}}
                    {{#if (this.isSource company)}}
                      <span
                        class="ml-2 rounded bg-accent-50 px-1.5 py-0.5 text-xs font-medium text-accent-700 dark:bg-accent-500/10 dark:text-accent-300"
                      >source</span>
                    {{/if}}
                  </td>
                  <td
                    class="px-4 py-3 text-right text-gray-600 dark:text-gray-300"
                  >{{or company.jobPostsCount 0}}</td>
                  <td
                    class="px-4 py-3 text-right text-gray-600 dark:text-gray-300"
                  >{{or company.jobApplicationsCount 0}}</td>
                  <td
                    class="px-4 py-3 text-right text-gray-600 dark:text-gray-300"
                  >{{or company.scrapesCount 0}}</td>
                  <td class="px-4 py-3 text-sm">
                    <div class="flex flex-wrap items-center gap-2">
                      <LinkTo
                        @route="admin.companies.show"
                        @model={{company.id}}
                        class="text-accent-600 dark:text-accent-400 hover:underline"
                      >
                        Manage
                      </LinkTo>
                      {{#if this.relateMode}}
                        {{#unless (this.isSource company)}}
                          <button
                            type="button"
                            class="btn"
                            disabled={{this.actingId}}
                            data-test-action="merge"
                            {{on "click" (fn this.mergeSourceInto company)}}
                          >
                            {{if
                              (this.isActing "merge" company.id)
                              "Merging…"
                              "Merge source into this"
                            }}
                          </button>
                          <button
                            type="button"
                            class="btn"
                            disabled={{this.actingId}}
                            data-test-action="mark-source"
                            {{on "click" (fn this.markSourceAsAliasOf company)}}
                          >
                            {{if
                              (this.isActing "mark-source" company.id)
                              "Marking…"
                              "Set this as canonical"
                            }}
                          </button>
                          <button
                            type="button"
                            class="btn"
                            disabled={{this.actingId}}
                            data-test-action="adopt"
                            {{on "click" (fn this.adoptRowAsAlias company)}}
                          >
                            {{if
                              (this.isActing "adopt" company.id)
                              "Marking…"
                              "Adopt as alias"
                            }}
                          </button>
                        {{/unless}}
                      {{/if}}
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        <InfinityLoader @infinityModel={{this.model}} @hideOnInfinity={{true}}>
          <div
            class="py-4 text-center text-sm text-gray-400 dark:text-gray-500"
          >
            Loading more…
          </div>
        </InfinityLoader>
      {{else if this.search}}
        <EmptyState @message="No companies match your search." />
      {{else}}
        <EmptyState @message="No companies yet." />
      {{/if}}
    </div>
  </:main>
</RouteLayout>