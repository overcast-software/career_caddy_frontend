{{page-title "Scrape"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:main>
    {{#if this.model.scrape.companySuggestions.length}}
      <div
        class="mb-4 rounded-md bg-blue-50 p-3 ring-1 ring-inset ring-blue-200 dark:bg-blue-500/10 dark:ring-blue-500/30"
        data-test-company-suggestions
      >
        <p class="text-sm font-medium text-blue-800 dark:text-blue-200">
          Suggested companies (trigram match)
        </p>
        <p class="mt-1 text-xs text-blue-700 dark:text-blue-300">
          The extractor minted a new Company for this scrape. These look similar
          — open the curation hub to review and merge if needed.
        </p>
        <ul class="mt-2 space-y-1">
          {{#each this.model.scrape.companySuggestions as |s|}}
            <li class="flex items-baseline gap-x-2 text-sm">
              <LinkTo
                @route="admin.companies.show"
                @model={{s.company_id}}
                class="text-accent-700 dark:text-accent-300 hover:underline"
                data-test-company-suggestion={{s.company_id}}
              >
                {{s.name}}
              </LinkTo>
              <span class="text-xs text-gray-500 dark:text-gray-400">
                similarity
                {{s.similarity}}
              </span>
            </li>
          {{/each}}
        </ul>
      </div>
    {{/if}}

    {{#if
      (and
        this.model.canonicalScrape
        (not-eq this.model.canonicalScrape.id this.model.scrape.id)
      )
    }}
      <div
        class="mb-4 rounded-md bg-amber-50 p-3 ring-1 ring-inset ring-amber-200 dark:bg-amber-500/10 dark:ring-amber-500/30"
        data-test-redirect-banner
      >
        <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
          Redirected to
          <LinkTo
            @route="scrapes.show"
            @model={{this.model.canonicalScrape.id}}
            class="underline"
            data-test-canonical-scrape-link
          >
            scrape #{{this.model.canonicalScrape.id}}
          </LinkTo>
          {{#if this.model.jobPost}}
            ·
            <LinkTo
              @route="job-posts.show"
              @model={{this.model.jobPost.id}}
              class="underline"
              data-test-canonical-job-post-link
            >
              JobPost #{{this.model.jobPost.id}}
            </LinkTo>
          {{/if}}
        </p>
        <p class="mt-1 text-xs text-amber-700 dark:text-amber-300">
          The tracker URL forwarded to a canonical scrape. The JobPost and
          Company below come from the canonical leaf.
        </p>
      </div>
    {{/if}}

    <Scrapes::Item
      @scrape={{this.model.scrape}}
      @canonicalScrape={{this.model.canonicalScrape}}
    />

    <div class="form-actions mt-4">
      <LinkTo
        @route="scrapes.edit"
        @model={{this.model.scrape}}
        class="btn"
      >Edit</LinkTo>
      <button
        type="button"
        class="btn"
        title="Re-fetch the URL and run the full pipeline again"
        {{on "click" (fn this.retryScrape this.model.scrape)}}
      >Retry</button>
      <button
        type="button"
        class="btn"
        title="Re-run extraction on the existing scrape content (no re-fetch)"
        {{on "click" (fn this.parseScrape this.model.scrape)}}
      >Re-parse</button>
      <LinkTo
        @route="scrapes.graph"
        @model={{this.model.scrape.id}}
        class="btn"
      >Graph</LinkTo>
    </div>
  </:main>
</RouteLayout>