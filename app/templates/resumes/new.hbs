{{page-title "New Resume"}}
<RouteLayout @flashMessages={{this.flashMessages}} @mainClass="builder-page">
  <:main>
    <div class="grid min-h-screen builder-grid split">
      <aside class="builder-editor flex flex-col overflow-y-auto pr-2">

        <Builder::Section @title="Job Title" @collapsible={{false}}>
          <Resumes::Title::Form @resume={{this.model}} />
        </Builder::Section>

        <Builder::Section @title="Personal Information">
          <PersonalInformation::Form @user={{this.model.user}} />
        </Builder::Section>

        <Builder::Section @title="Summary" @startCollapsed={{true}}>
          <Summary::Form @summary={{this.model.summary}} />
        </Builder::Section>

        <Builder::Section @title="Skills" @startCollapsed={{true}}>
          <Skills::Form @skills={{this.model.skills}} @resume={{this.model}} />
        </Builder::Section>

        <Builder::Section @title="Experience">
          <:actions>
            <button
              type="button"
              class="rounded bg-accent-100 px-2 py-0.5 text-xs text-accent-800 hover:bg-accent-200"
              {{on "click" this.addExperience}}
            >+ Add</button>
          </:actions>
          <:default>
            <Experiences::List @experiences={{this.model.experiences}} />
          </:default>
        </Builder::Section>

        <Builder::Section @title="Certifications" @startCollapsed={{true}}>
          <:actions>
            <button
              type="button"
              class="rounded bg-accent-100 px-2 py-0.5 text-xs text-accent-800 hover:bg-accent-200"
              {{on "click" this.addCertification}}
            >+ Add</button>
          </:actions>
          <:default>
            {{#each this.model.certifications as |cert|}}
              <Certifications::Form @certification={{cert}} />
            {{/each}}
          </:default>
        </Builder::Section>

        <Builder::Section @title="Education" @startCollapsed={{true}}>
          <Educations::Form @education={{this.model.education}} />
        </Builder::Section>

      </aside>
      <main class="builder-preview bg-gray-100 p-8 overflow-y-auto">
        <div
          class="builder-preview-wrap mx-auto max-w-[8.5in] bg-white shadow-lg rounded-lg min-h-[11in]"
        >
          <Resumes::Item @resume={{this.model}} />
        </div>
      </main>
    </div>
  </:main>
</RouteLayout>