{{page-title "Edit Resume"}}
<RouteLayout @flashMessages={{this.flashMessages}} @mainClass="builder-page">
  <:subnav>
    <div class="builder-controls">
      {{#if this.isDirty}}
        <button
          type="button"
          class="btn"
          {{on "click" this.saveResume}}
        >Save</button>
        <button
          type="button"
          class="btn"
          {{on "click" this.cancel}}
        >Cancel</button>
      {{/if}}
      <LinkTo
        @route="resumes.show"
        @model={{this.model}}
        class="btn"
      >Preview</LinkTo>
      <button
        type="button"
        class="btn"
        {{on "click" this.cloneResume}}
      >Clone</button>
      <button
        type="button"
        class="btn"
        {{on "click" this.exportToWord}}
      >Export</button>
      <button type="button" class="btn" {{on "click" this.toggleLayout}}>
        {{#if this.sideBySide}}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            width="16"
            height="16"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z"
            />
          </svg>
          Stack
        {{else}}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            width="16"
            height="16"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125Z"
            />
          </svg>
          Split
        {{/if}}
      </button>
      <button
        type="button"
        class="btn danger"
        {{on "click" this.deleteResume}}
      >Delete</button>
    </div>
  </:subnav>
  <:main>
    <div
      class="grid min-h-screen transition-[grid-template-columns] duration-300 ease-in-out builder-grid
        {{if this.sideBySide 'split'}}"
    >
      <aside class="builder-editor flex flex-col overflow-y-auto pr-2">

        <Builder::Section @title="Title" @collapsible={{false}}>
          <Resumes::Title::Form @title="Title" @resume={{this.model}} />
        </Builder::Section>

        <Builder::Section @title="Personal Information">
          <PersonalInformation::Form @user={{this.model.user}} />
        </Builder::Section>

        <Builder::Section @title="Summary">
          <Summaries::Carousel
            @summaries={{this.resumeSummaries}}
            @resume={{this.model}}
            @onChange={{this.onSummaryChange}}
          />
        </Builder::Section>

        <Builder::Section @title="Skills">
          <Skills::Form @skills={{this.model.skills}} @resume={{this.model}} />
        </Builder::Section>

        <Builder::Section @title="Experience">
          <:actions>
            <button
              type="button"
              class="rounded bg-accent-100 px-2 py-0.5 text-xs text-accent-800 hover:bg-accent-200"
              {{on "click" this.addExperience}}
            >+ Add</button>
          </:actions>
          <:default>
            <Experiences::List @experiences={{this.model.sortedExperiences}} />
          </:default>
        </Builder::Section>

        <Builder::Section @title="Projects" @startCollapsed={{true}}>
          <:actions>
            <button
              type="button"
              class="rounded bg-accent-100 px-2 py-0.5 text-xs text-accent-800 hover:bg-accent-200"
              {{on "click" this.addProject}}
            >+ Add</button>
          </:actions>
          <:default>
            {{#if this.model.projects.length}}
              <div class="divide-y builder-divider">
                {{#each this.model.projects as |proj|}}
                  <div class="py-3 first:pt-0 last:pb-0">
                    <Projects::Form @project={{proj}} />
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="text-sm builder-label-hint">No projects yet. Use "+ Add"
                to create one.</p>
            {{/if}}
          </:default>
        </Builder::Section>

        <Builder::Section @title="Certifications" @startCollapsed={{true}}>
          <:actions>
            <button
              type="button"
              class="rounded bg-accent-100 px-2 py-0.5 text-xs text-accent-800 hover:bg-accent-200"
              {{on "click" this.addCertification}}
            >+ Add</button>
          </:actions>
          <:default>
            {{#if this.model.certifications.length}}
              <div class="divide-y builder-divider">
                {{#each this.model.certifications as |cert|}}
                  <div class="py-3 first:pt-0 last:pb-0">
                    <Certifications::Form @certification={{cert}} />
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="text-sm builder-label-hint">No certifications yet. Use
                "+ Add" to create one.</p>
            {{/if}}
          </:default>
        </Builder::Section>

        <Builder::Section @title="Education" @startCollapsed={{true}}>
          <:actions>
            <button
              type="button"
              class="rounded bg-accent-100 px-2 py-0.5 text-xs text-accent-800 hover:bg-accent-200"
              {{on "click" this.addEducation}}
            >+ Add</button>
          </:actions>
          <:default>
            {{#if this.model.educations.length}}
              <div class="divide-y builder-divider">
                {{#each this.model.educations as |edu|}}
                  <div class="py-3 first:pt-0 last:pb-0">
                    <Educations::Form @education={{edu}} />
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="text-sm builder-label-hint">No education yet. Use "+
                Add" to create one.</p>
            {{/if}}
          </:default>
        </Builder::Section>

      </aside>
      <main class="builder-preview bg-gray-100 p-8 overflow-y-auto">
        <div
          class="builder-preview-wrap mx-auto max-w-[8.5in] bg-white shadow-lg rounded-lg min-h-[11in]"
        >
          <Resumes::Item
            @resume={{this.model}}
            @activeSummary={{this.activeSummary}}
          />
        </div>
      </main>
    </div>
  </:main>
</RouteLayout>