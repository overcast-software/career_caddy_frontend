{{page-title "Applications"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <div class="controls">
      <Menus::SubnavSearch
        @value={{this.search}}
        @onSearch={{this.updateSearch}}
        @onSearchStart={{this.startSearching}}
        @placeholder="Search applications..."
      />
      <LinkTo @route="job-applications.new" class="btn">+New Application</LinkTo>
    </div>
  </:subnav>
  <:main>
    {{#if this.isSearching}}
      <div class="py-8 text-center text-sm text-gray-400">Searching…</div>
    {{else}}
      {{#if this.model.length}}
        <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
          <table class="min-w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600"
                >Title</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600"
                >Company</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600"
                >Status</th>
                <th
                  class="px-4 py-3 text-left font-semibold text-gray-600"
                >Applied At</th>
                <th
                  class="px-4 py-3 text-right font-semibold text-gray-600"
                >Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {{#each this.model as |application|}}
                <JobApplications::Compact
                  @jobApplication={{application}}
                  @onDelete={{this.removeApplication}}
                />
              {{/each}}
            </tbody>
          </table>
        </div>
        <InfinityLoader @infinityModel={{this.model}} @hideOnInfinity={{true}}>
          <div class="py-4 text-center text-sm text-gray-400">Loading more…</div>
        </InfinityLoader>
      {{else}}
        <p class="text-gray-500 text-sm py-6 text-center">No applications found.</p>
      {{/if}}
    {{/if}}
  </:main>
</RouteLayout>