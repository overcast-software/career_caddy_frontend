<div class="mt-4 border-t border-gray-100 pt-4">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-sm font-semibold text-gray-700">Answer</h3>
    <LinkTo
      @route="job-applications.show.questions.show.answers.edit"
      @model={{this.model}}
      class="btn btn-sm"
    >Edit</LinkTo>
  </div>
  <div class="panel-card">
    <MarkdownToHtml @markdown={{this.model.content}} />
  </div>
</div>
