{{page-title "New Question"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo
      @route="job-applications.show"
      @model={{this.model.jobApplication}}
      class="nav-link"
    >← Back to Application</LinkTo>
  </:subnav>
  <:main>
    <Questions::Form
      @question={{this.model.question}}
      @jobApplication={{this.model.jobApplication}}
    />
  </:main>
</RouteLayout>