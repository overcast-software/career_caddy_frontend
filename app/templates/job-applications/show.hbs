<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo
      @route="job-applications.edit"
      @model={{this.model.id}}
      class="btn"
    >Edit</LinkTo>
    <button
      type="button"
      class="btn"
      {{on "click" this.destroyRecord}}
    >Destroy</button>
    <LinkTo
      @route="job-posts.show.job-applications"
      @model={{this.model.jobPost}}
      class="btn"
    >Job Post</LinkTo>
  </:subnav>
  <:main>
    <div class="space-y-4">
      <div class="panel-card space-y-6">
        <span
          class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700"
        >{{this.model.status}}</span>

        <div class="flow-root">
          <dl class="-my-3 divide-y divide-gray-200 text-sm">
            <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-gray-900">Application for</dt>
              <dd
                class="text-gray-700 sm:col-span-2"
              >{{this.model.jobPost.title}} at {{this.model.company.name}}</dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-gray-900">Resume</dt>
              <dd class="text-gray-700 sm:col-span-2">{{#if
                  this.model.resume
                }}{{this.model.resume.name}}{{else}}N/A{{/if}}</dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-gray-900">Day applied</dt>
              <dd class="text-gray-700 sm:col-span-2">{{format-date
                  this.model.appliedAt
                }}</dd>
            </div>
            <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
              <dt class="font-medium text-gray-900">Status</dt>
              <dd class="text-gray-700 sm:col-span-2">{{this.model.status}}</dd>
            </div>
            {{#if this.model.trackingUrl}}
              <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
                <dt class="font-medium text-gray-900">Link</dt>
                <dd class="text-gray-700 sm:col-span-2">
                  <a
                    href={{this.model.trackingUrl}}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:underline break-all"
                  >
                    {{this.model.trackingUrl}}
                  </a>
                </dd>
              </div>
            {{/if}}
            {{#if this.model.notes}}
              <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
                <dt class="font-medium text-gray-900">Notes</dt>
                <dd
                  class="text-gray-700 sm:col-span-2"
                >{{this.model.notes}}</dd>
              </div>
            {{/if}}
          </dl>
        </div>
      </div>

      <div class="panel-card">
        <JobApplications::StatusLog @jobApplication={{this.model}} />
      </div>

      {{#if this.model.questions.length}}
        <LinkTo
          @route="job-applications.show.questions"
          @model={{this.model}}
          class="btn small"
        >
          Questions ({{this.model.questions.length}})
        </LinkTo>
      {{/if}}
    </div>
  </:main>
  <:outlet>
    {{outlet}}
  </:outlet>
</RouteLayout>