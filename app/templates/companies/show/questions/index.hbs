<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-semibold text-gray-800">Questions</h2>
  <LinkTo @route="companies.show.questions.new" class="btn small">+ New Question</LinkTo>
</div>

<Questions::List
  @questions={{this.model}}
  @answersRoute="companies.show.questions.show"
  @showRoute="companies.show.questions.show"
  @editRoute="companies.show.questions.edit"
  @answerRoute="companies.show.questions.show.answers.new"
  @emptyMessage="No questions for this company."
/>