{{page-title "New Application"}}

<div class="mb-4">
  <LinkTo
    @route="companies.show.job-applications.index"
    @model={{this.company.id}}
    class="text-sm text-gray-500 hover:text-gray-700 inline-flex items-center gap-1"
  >&larr; Back to Applications</LinkTo>
</div>

<JobApplications::Edit
  @jobApplication={{this.model}}
  @jobPostOptions={{this.jobPostOptions}}
  @save={{this.save}}
  @cancel={{this.cancel}}
/>