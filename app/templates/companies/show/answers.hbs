<div class="flex items-center justify-between mb-4">
  <h2
    class="text-lg font-semibold text-gray-800 dark:text-gray-200"
  >Questions</h2>
  <LinkTo @route="companies.show.questions.new" class="btn small">+ New Question</LinkTo>
</div>

{{#if this.model.length}}
  <div
    class="overflow-x-auto rounded-lg border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800"
  >
    <table class="min-w-full text-sm">
      <thead
        class="bg-gray-50 border-b border-gray-200 dark:bg-gray-700 dark:border-gray-600"
      >
        <tr>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
          >Question</th>
          <th
            class="px-4 py-3 text-center font-semibold text-gray-600 dark:text-gray-300 w-24"
          >Answers</th>
          <th
            class="px-4 py-3 text-center font-semibold text-gray-600 dark:text-gray-300 w-16"
          >Fav</th>
          <th
            class="px-4 py-3 text-right font-semibold text-gray-600 dark:text-gray-300 w-40"
          >Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
        {{#each this.model as |question|}}
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
            <td
              class="px-4 py-3 text-gray-900 dark:text-gray-100 whitespace-pre-wrap break-words max-w-lg"
            >
              {{question.content}}
            </td>
            <td class="px-4 py-3 text-center">
              {{#if question.answers.length}}
                <LinkTo
                  @route="questions.show.answers"
                  @model={{question}}
                  class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold hover:bg-indigo-200 dark:bg-indigo-900 dark:text-indigo-300 dark:hover:bg-indigo-800"
                >{{question.answers.length}}</LinkTo>
              {{else}}
                <span class="text-gray-300 dark:text-gray-600 text-xs">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-center text-base">
              {{if question.favorite "★" "☆"}}
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-1.5 flex-wrap">
                <LinkTo
                  @route="questions.show"
                  @model={{question}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
                >Show</LinkTo>
                <LinkTo
                  @route="questions.edit"
                  @model={{question}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
                >Edit</LinkTo>
                <LinkTo
                  @route="questions.show.answers.new"
                  @model={{question}}
                  class="px-2 py-1 text-xs rounded border border-indigo-200 text-indigo-600 hover:bg-indigo-50 dark:border-indigo-600 dark:text-indigo-400 dark:hover:bg-indigo-900"
                >Answer</LinkTo>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <EmptyState @message="No questions for this company." />
{{/if}}