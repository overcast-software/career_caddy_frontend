{{#if this.model.length}}
  <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Job Post</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Score</th>
          <th
            class="px-4 py-3 text-right font-semibold text-gray-600"
          >Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each this.model as |score|}}
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-900">
              <LinkTo @route="job-posts.show.scores" @model={{score.jobPost}}>
                {{score.jobPost.title}}
              </LinkTo>
            </td>
            <td class="px-4 py-3 font-medium text-blue-600">{{score.score}}</td>
            <td class="px-4 py-3 text-right">
              <LinkTo
                @route="scores.show"
                @model={{score}}
                class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
              >View</LinkTo>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <p class="text-gray-500 text-sm py-6 text-center">No scores for this company.</p>
{{/if}}