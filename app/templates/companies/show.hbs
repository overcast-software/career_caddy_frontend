<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    {{this.model.name}}
    <LinkTo
      @route="companies.edit"
      @model={{this.model}}
      class="btn"
    >edit</LinkTo>
  </:subnav>
  <:main>
    <Panel::Card @title={{this.model.name}}>
      <dl class="flex flex-wrap gap-y-2 text-sm">
        <div
          class="flex items-center gap-2 border-r border-gray-300 dark:border-gray-600 pr-4 mr-4 last:border-r-0 last:pr-0 last:mr-0"
        >
          <dt class="text-gray-500 dark:text-gray-400">Job Posts</dt>
          <dd
            class="font-semibold text-gray-900 dark:text-gray-100"
          >{{this.model.jobPosts.length}}</dd>
        </div>
        <div
          class="flex items-center gap-2 border-r border-gray-300 dark:border-gray-600 pr-4 mr-4 last:border-r-0 last:pr-0 last:mr-0"
        >
          <dt class="text-gray-500 dark:text-gray-400">Applications</dt>
          <dd
            class="font-semibold text-gray-900 dark:text-gray-100"
          >{{this.model.jobApplications.length}}</dd>
        </div>
        <div
          class="flex items-center gap-2 border-r border-gray-300 dark:border-gray-600 pr-4 mr-4 last:border-r-0 last:pr-0 last:mr-0"
        >
          <dt class="text-gray-500 dark:text-gray-400">Scrapes</dt>
          <dd
            class="font-semibold text-gray-900 dark:text-gray-100"
          >{{this.model.scrapes.length}}</dd>
        </div>
        <div
          class="flex items-center gap-2 border-r border-gray-300 dark:border-gray-600 pr-4 mr-4 last:border-r-0 last:pr-0 last:mr-0"
        >
          <dt class="text-gray-500 dark:text-gray-400">Questions</dt>
          <dd
            class="font-semibold text-gray-900 dark:text-gray-100"
          >{{this.model.questions.length}}</dd>
        </div>
        <div
          class="flex items-center gap-2 border-r border-gray-300 dark:border-gray-600 pr-4 mr-4 last:border-r-0 last:pr-0 last:mr-0"
        >
          <dt class="text-gray-500 dark:text-gray-400">Scores</dt>
          <dd
            class="font-semibold text-gray-900 dark:text-gray-100"
          >{{this.model.scores.length}}</dd>
        </div>
      </dl>
    </Panel::Card>

    <Panel::Card>
      <Companies::Tabs @company={{this.model}} />
      <div role="tabpanel" class="mt-4">
        {{outlet}}
      </div>
    </Panel::Card>
  </:main>
</RouteLayout>