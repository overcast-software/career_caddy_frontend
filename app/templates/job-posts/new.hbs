{{page-title "Add a job post"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="job-posts" class="nav-link">Back to Job Posts</LinkTo>
  </:subnav>
  <:main>
    <Panel::Card>
      <AnimatedContainer>
        {{#animated-each
          (array this.activeDescriptor)
          key="key"
          use=this.descriptorTransition
          duration=220
          as |desc|
        }}
          <p class="text-sm text-gray-600 dark:text-gray-400">
            {{desc.text}}
          </p>
        {{/animated-each}}
      </AnimatedContainer>
    </Panel::Card>

    <Panel::Card>
      <div class="border-b border-gray-200">
        <div role="tablist" class="-mb-px flex gap-4 overflow-x-auto">
          <LinkTo
            @route="job-posts.new.manual"
            class="flex items-center gap-2 border-b-2 border-transparent px-4 py-2 text-sm font-medium text-gray-600 transition-colors hover:text-gray-700 whitespace-nowrap"
            @activeClass="border-accent-600 !text-accent-600"
          >
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L5.25 18.25l1.051-3.435a4.5 4.5 0 011.13-1.897L16.862 4.487zm0 0L19.5 7.125"
              />
            </svg>
            Manual
          </LinkTo>
          <LinkTo
            @route="job-posts.new.scrape"
            class="flex items-center gap-2 border-b-2 border-transparent px-4 py-2 text-sm font-medium text-gray-600 transition-colors hover:text-gray-700 whitespace-nowrap"
            @activeClass="border-accent-600 !text-accent-600"
          >
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"
              />
            </svg>
            Scrape URL
          </LinkTo>
          <LinkTo
            @route="job-posts.new.paste"
            class="flex items-center gap-2 border-b-2 border-transparent px-4 py-2 text-sm font-medium text-gray-600 transition-colors hover:text-gray-700 whitespace-nowrap"
            @activeClass="border-accent-600 !text-accent-600"
          >
            <svg
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-4"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.25 7.5V6.108c0-1.135.845-2.098 1.976-2.192.373-.03.748-.057 1.123-.08M15.75 18H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08M15.75 18.75v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5A3.375 3.375 0 006.375 7.5H5.25m11.9-3.664A2.251 2.251 0 0015 2.25h-1.5a2.25 2.25 0 00-2.15 1.586m5.8 0c.065.21.1.433.1.664v.75h-6V4.5c0-.231.035-.454.1-.664M6.75 7.5H4.875c-.621 0-1.125.504-1.125 1.125v12c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V16.5a9 9 0 00-9-9z"
              />
            </svg>
            Paste
          </LinkTo>
        </div>
      </div>

      <div class="mt-4 relative overflow-hidden">
        <AnimatedContainer class="w-full">
          {{#animated-each
            (array this.activeTabKey)
            key="@identity"
            use=this.tabTransition
            duration=350
          }}
            <div class="w-full">
              {{outlet}}
            </div>
          {{/animated-each}}
        </AnimatedContainer>
      </div>
    </Panel::Card>
  </:main>
</RouteLayout>