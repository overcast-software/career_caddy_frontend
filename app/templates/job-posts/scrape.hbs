<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo @route="job-posts" class="nav-link">Back to Job Posts</LinkTo>
    <LinkTo @route="job-posts.paste" class="nav-link">Paste job text instead</LinkTo>
  </:subnav>
  <:main>
    <Panel::Card>
      <form class="builder-form" {{on "submit" this.submitScrape}}>
        <div class="field">
          <label class="field-label" for="scrape-url">URL</label>
          <input
            id="scrape-url"
            type="url"
            placeholder="https://..."
            value={{this.url}}
            {{on "input" this.updateUrl}}
          />
        </div>

        <div class="form-actions">
          <button type="submit" class="btn primary">Submit and process</button>
          {{#if this.showHoldOption}}
            <button
              type="button"
              class="btn"
              {{on "click" this.submitHold}}
            >Submit and hold for external service</button>
          {{/if}}
        </div>
      </form>
    </Panel::Card>
  </:main>
</RouteLayout>