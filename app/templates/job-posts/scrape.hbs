<RouteLayout @flashMessages={{this.flashMessages}}>
  <:main>
    <Panel::Card>
      <form class="builder-form" {{on "submit" this.submitScrape}}>
        <div class="field">
          <label class="field-label" for="scrape-url">URL</label>
          <input
            id="scrape-url"
            type="url"
            placeholder="https://..."
            {{on "change" this.updateUrl}}
          />
        </div>

        {{#if this.showHoldOption}}
          <div class="field">
            <span class="field-label">Processing</span>
            <div class="mt-1 flex items-center gap-6">
              <label
                class="inline-flex items-center gap-2 text-sm text-[var(--muted)] cursor-pointer"
              >
                <input
                  type="radio"
                  name="scrape-status"
                  checked={{unless this.isHold true}}
                  {{on "change" (fn this.setStatus null)}}
                  class="border-[var(--border)] text-[var(--accent)]"
                />
                Dispatch
              </label>
              <label
                class="inline-flex items-center gap-2 text-sm text-[var(--muted)] cursor-pointer"
              >
                <input
                  type="radio"
                  name="scrape-status"
                  checked={{this.isHold}}
                  {{on "change" (fn this.setStatus "hold")}}
                  class="border-[var(--border)] text-[var(--accent)]"
                />
                Hold
              </label>
            </div>
          </div>
        {{/if}}

        <div class="form-actions">
          <button type="submit" class="btn primary">Scrape</button>
        </div>
      </form>
    </Panel::Card>
  </:main>
</RouteLayout>