<RouteLayout @flashMessages={{this.flashMessages}}>
  <:main>
    <div class="panel-card space-y-3 pb-4">
      {{! Mobile: stack title/meta on top, actions below. Desktop (sm+):
          side-by-side with actions pinned to the right. Actions
          flex-wrap so a long button row breaks cleanly rather than
          pushing the title column into a narrow vertical ribbon. }}
      <div
        class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between"
      >
        <div class="min-w-0">
          <p class="text-xs text-gray-500">
            {{~#if this.model.company.name~}}
              {{this.model.company.name}}
            {{~else~}}
              <span class="italic text-amber-500">Company missing</span>
            {{~/if~}}
          </p>
          <h1 class="text-lg font-semibold text-gray-900 break-words">
            {{this.model.title}}
            {{#if this.model.link}}
              <a
                href={{this.model.link}}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-500 text-sm ml-1"
              >↗</a>
            {{/if}}
          </h1>
          <div class="flex flex-wrap gap-3 text-xs text-gray-400 mt-0.5">
            {{#if (if this.model.postedDate true this.model.createdAt)}}
              <span>Posted:
                {{moment-format
                  (if
                    this.model.postedDate
                    this.model.postedDate
                    this.model.createdAt
                  )
                  "MMM D, YYYY"
                }}</span>
            {{/if}}
            {{#if this.model.createdAt}}
              <span>Added:
                {{moment-format this.model.createdAt "MMM D, YYYY"}}</span>
            {{/if}}
          </div>
        </div>
        {{! Primary actions row — Run scrape / Copy Description / Edit.
            Triage (Vetted Good / Vetted Bad) drops to its own row
            underneath since it's a judgement call, not a state change. }}
        <div class="flex flex-col items-stretch gap-2 sm:shrink-0 sm:items-end">
          <div class="flex flex-wrap items-center gap-2 sm:justify-end">
            {{#if this.model.link}}
              <button
                type="button"
                class="btn small"
                disabled={{this.scrapeSubmitting}}
                {{on "click" this.runScrape}}
              >
                {{if this.scrapeSubmitting "Queuing…" "Run scrape"}}
              </button>
            {{/if}}
            <button
              type="button"
              class="btn small"
              {{on "click" this.copyDescription}}
            >
              {{this.copyButtonText}}
            </button>
            <LinkTo
              class="btn small"
              @route="job-posts.edit"
              @model={{this.model}}
            >Edit</LinkTo>
          </div>
          <div class="flex flex-wrap items-center gap-2 sm:justify-end">
            <JobPosts::TriageActions @jobPost={{this.model}} />
          </div>
        </div>
      </div>

      <div>
        {{! Animated expand/collapse via max-height transition. Tailwind
            doesn't ship a line-clamp transition (the property isn't
            animatable) — the max-height bounce reads as a smooth
            unfold and settles at the content's natural height once
            the transition finishes. }}
        <p
          class="text-sm text-gray-600 overflow-hidden transition-[max-height] duration-300 ease-out
            {{if this.descriptionExpanded 'max-h-[60rem]' 'max-h-20'}}"
        >{{this.model.description}}</p>
        {{#if this.model.description}}
          <button
            type="button"
            class="mt-1 text-xs font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300"
            {{on "click" this.toggleDescription}}
          >
            {{if this.descriptionExpanded "Collapse" "Expand"}}
          </button>
        {{/if}}
      </div>
    </div>

    <Panel::Card>
      <JobPosts::Tabs @jobPost={{this.model}} />
      {{! Tab pane wrapper. min-h keeps the stage tall even when a tab
          has very little content so the swoosh has somewhere to play
          out; relative+overflow-hidden clips the out-of-bounds half of
          the slide so the old and new panes actually appear to
          translate across each other instead of bleeding into the
          page layout. }}
      <div role="tabpanel" class="mt-4 min-h-[18rem] relative overflow-hidden">
        <LiquidOutlet @class="tab-outlet" />
      </div>
    </Panel::Card>
  </:main>
</RouteLayout>