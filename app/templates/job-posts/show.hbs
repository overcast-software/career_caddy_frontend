<RouteLayout @flashMessages={{this.flashMessages}}>
  <:main>
    <div class="panel-card space-y-1 pb-4">
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="text-xs text-gray-500">
            {{~#if this.model.company.name~}}
              {{this.model.company.name}}
            {{~else~}}
              <span class="italic text-amber-500">Company missing</span>
            {{~/if~}}
          </p>
          <h1 class="text-lg font-semibold text-gray-900">
            {{this.model.title}}
            {{#if this.model.link}}
              <a
                href={{this.model.link}}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-500 text-sm ml-1"
              >↗</a>
            {{/if}}
          </h1>
          <div class="flex gap-3 text-xs text-gray-400 mt-0.5">
            {{#if (if this.model.postedDate true this.model.createdAt)}}
              <span>Posted:
                {{moment-format
                  (if
                    this.model.postedDate
                    this.model.postedDate
                    this.model.createdAt
                  )
                  "MMM D, YYYY"
                }}</span>
            {{/if}}
            {{#if this.model.createdAt}}
              <span>Added:
                {{moment-format this.model.createdAt "MMM D, YYYY"}}</span>
            {{/if}}
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <button
            type="button"
            class="btn small"
            {{on "click" this.copyDescription}}
          >
            {{this.copyButtonText}}
          </button>
          <LinkTo
            class="btn small"
            @route="job-posts.edit"
            @model={{this.model}}
          >Edit</LinkTo>
        </div>
      </div>
      <p
        class="text-sm text-gray-600 line-clamp-4 mt-2"
      >{{this.model.description}}</p>
    </div>

    <Panel::Card>
      <JobPosts::Tabs @jobPost={{this.model}} />
      <div role="tabpanel" class="mt-4">
        {{outlet}}
      </div>
    </Panel::Card>
  </:main>
</RouteLayout>