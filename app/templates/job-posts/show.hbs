<RouteLayout @flashMessages={{this.flashMessages}}>
  <:main>
    <div class="panel-card space-y-3 pb-4">
      {{! Title/meta row, then actions row below — full width on every
          viewport. Earlier we pinned actions to the right of the title
          (sm:justify-between), which with a short title left a big
          empty gap and floated "Run scrape" far from the content. A
          dedicated row keeps the action cluster close to what it acts
          on, and long triage chips can wrap in place without dragging
          the rest to a new line. }}
      <div class="flex flex-col gap-3">
        <div class="min-w-0">
          <p class="text-xs text-gray-500">
            {{~#if this.model.company.name~}}
              {{this.model.company.name}}
            {{~else~}}
              <span class="italic text-amber-500">Company missing</span>
            {{~/if~}}
          </p>
          <h1 class="text-lg font-semibold text-gray-900 break-words">
            {{this.model.title}}
            {{#if this.model.link}}
              <a
                href={{this.model.link}}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-500 text-sm ml-1"
              >↗</a>
            {{/if}}
          </h1>
          <div class="flex flex-wrap gap-3 text-xs text-gray-400 mt-0.5">
            {{#if (if this.model.postedDate true this.model.createdAt)}}
              <span>Posted:
                {{format-date
                  (if
                    this.model.postedDate
                    this.model.postedDate
                    this.model.createdAt
                  )
                  "MMM D, YYYY"
                }}</span>
            {{/if}}
            {{#if this.model.createdAt}}
              <span>Added:
                {{format-date this.model.createdAt "MMM D, YYYY"}}</span>
            {{/if}}
          </div>
          {{#if this.model.duplicateOfId}}
            <LinkTo
              @route="job-posts.show"
              @model={{this.model.duplicateOfId}}
              class="mt-1 inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20 hover:bg-amber-100 dark:bg-amber-500/10 dark:text-amber-300 dark:ring-amber-500/30"
            >
              Duplicate of #{{this.model.duplicateOfId}}
            </LinkTo>
          {{/if}}
          {{#if (eq this.model.applicationStatus "closed")}}
            <span
              class="mt-1 ml-1 inline-flex items-center gap-1 rounded-full bg-red-50 px-2.5 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20 dark:bg-red-500/10 dark:text-red-300 dark:ring-red-500/30"
              title="Extracted text indicates this posting is no longer accepting applications"
            >
              Closed
            </span>
          {{/if}}
          <ApplyDestination @jobPost={{this.model}} />
        </div>
        {{! All header actions — Run scrape / Copy / Edit / Vetted Good /
            Vetted Bad (+ reason picker) — flow in a single wrapping
            row directly under the title, left-aligned. }}
        <div class="flex flex-wrap items-center gap-2">
          {{#if this.model.link}}
            <button
              type="button"
              class="btn small"
              disabled={{this.scrapeSubmitting}}
              {{on "click" this.runScrape}}
            >
              {{if this.scrapeSubmitting "Queuing…" "Run scrape"}}
            </button>
            {{! Only surface Scrape & Score on stubs — a full-description
                post already has enough to score in isolation, and the
                combined action rescrapes the whole page for no gain. }}
            {{#if this.model.isStub}}
              <button
                type="button"
                class="btn small primary"
                disabled={{or this.scrapeSubmitting this.scoreSubmitting}}
                {{on "click" this.scrapeAndScore}}
              >
                {{if
                  this.scoreSubmitting
                  "Scoring…"
                  (if this.scrapeSubmitting "Scraping…" "Scrape & Score")
                }}
              </button>
            {{/if}}
          {{/if}}
          <button
            type="button"
            class="btn small"
            {{on "click" this.copyDescription}}
          >
            {{this.copyButtonText}}
          </button>
          <LinkTo
            class="btn small"
            @route="job-posts.edit"
            @model={{this.model}}
          >Edit</LinkTo>
          <JobPosts::TriageActions @jobPost={{this.model}} />
        </div>
      </div>

      <div>
        {{! Animated expand/collapse. line-clamp-4 gives a clean cut at
            exactly 4 lines when collapsed; max-height on top provides
            the smooth unfold when toggled. Tailwind can't animate
            line-clamp directly (not an animatable property), which is
            why max-height is the transition carrier. Both candidate
            class strings appear literally in the if-helper arguments
            so Tailwind JIT compiles them. }}
        <p
          class="text-sm text-gray-600 overflow-hidden transition-[max-height] duration-300 ease-out
            {{if
              this.descriptionExpanded
              'max-h-screen'
              'max-h-24 line-clamp-4'
            }}"
        >{{this.model.description}}</p>
        {{#if this.model.description}}
          <button
            type="button"
            class="mt-1 text-xs font-medium text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300"
            {{on "click" this.toggleDescription}}
          >
            {{if this.descriptionExpanded "Collapse" "Expand"}}
          </button>
        {{/if}}
      </div>
    </div>

    <Panel::Card>
      <JobPosts::Tabs @jobPost={{this.model}} />
      <div role="tabpanel" class="mt-4 relative overflow-hidden">
        <AnimatedContainer class="w-full">
          {{#animated-each
            (array this.activeTabKey)
            key="@identity"
            use=this.tabTransition
            duration=350
          }}
            <div class="w-full">
              {{outlet}}
            </div>
          {{/animated-each}}
        </AnimatedContainer>
      </div>
    </Panel::Card>
  </:main>
</RouteLayout>