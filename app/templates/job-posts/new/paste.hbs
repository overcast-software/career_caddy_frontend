{{#if this.duplicate}}
  <div
    class="mb-6 rounded-md border border-amber-300 bg-amber-50 p-4 text-sm text-amber-900 dark:border-amber-700 dark:bg-amber-900/30 dark:text-amber-100"
    data-test-paste-duplicate
  >
    <p class="font-semibold">
      A job post for this URL already exists.
    </p>
    {{#if this.duplicate.title}}
      <p class="mt-1">
        <span class="font-medium">{{this.duplicate.title}}</span>
        {{#if this.duplicate.companyName}}
          at
          <span class="font-medium">{{this.duplicate.companyName}}</span>
        {{/if}}
        — re-parsing would overwrite the existing data and burn an LLM call.
        Pick one:
      </p>
    {{else}}
      <p class="mt-1">
        Re-parsing would overwrite the existing data and burn an LLM call. Pick
        one:
      </p>
    {{/if}}
    <div class="mt-3 flex flex-wrap gap-2">
      <button
        type="button"
        class="btn primary"
        data-test-paste-duplicate-open
        {{on "click" this.openExistingDuplicate}}
      >Open job post #{{this.duplicate.id}}</button>
      <button
        type="button"
        class="btn"
        data-test-paste-duplicate-force
        {{on "click" this.forceReparseDuplicate}}
      >Re-parse anyway</button>
    </div>
  </div>
{{/if}}

<form
  class="space-y-6"
  {{on-insert this.installBookmarkletListener}}
  {{on "submit" this.submitPaste}}
>
  <div>
    <label
      for="paste-url"
      class="block text-sm font-semibold text-gray-900 dark:text-gray-100"
    >URL (optional)</label>
    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
      If you have the job posting URL, paste it here — we'll keep it on the Job
      Post for reference. The URL alone won't trigger a scrape; use the Scrape
      URL tab for that.
    </p>
    <input
      id="paste-url"
      type="url"
      class="mt-2 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 disabled:bg-gray-100 dark:border-gray-600 dark:bg-gray-800 dark:disabled:bg-gray-900 dark:text-gray-100"
      placeholder="https://..."
      value={{this.url}}
      disabled={{this.submitting}}
      {{on "input" this.updateUrl}}
    />
  </div>

  <div>
    <label
      for="paste-text"
      class="block text-sm font-semibold text-gray-900 dark:text-gray-100"
    >Job posting content</label>
    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
      Open the job posting in another tab, select all (<kbd
        class="rounded bg-gray-200 px-1 py-0.5 font-mono text-xs dark:bg-gray-700"
      >Ctrl</kbd>+<kbd
        class="rounded bg-gray-200 px-1 py-0.5 font-mono text-xs dark:bg-gray-700"
      >A</kbd>), copy (<kbd
        class="rounded bg-gray-200 px-1 py-0.5 font-mono text-xs dark:bg-gray-700"
      >Ctrl</kbd>+<kbd
        class="rounded bg-gray-200 px-1 py-0.5 font-mono text-xs dark:bg-gray-700"
      >C</kbd>), and paste below. The AI extracts the title, company, salary,
      location, and description.
    </p>
    <textarea
      id="paste-text"
      class="mt-2 block w-full min-h-[20rem] rounded-md border border-gray-300 px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500 disabled:bg-gray-100 dark:border-gray-600 dark:bg-gray-800 dark:disabled:bg-gray-900 dark:text-gray-100"
      placeholder="Paste the full text of a job posting here — I'll pull out the key fields."
      value={{this.text}}
      disabled={{this.submitting}}
      {{on "input" this.updateText}}
    ></textarea>
  </div>

  <div class="flex items-center justify-end gap-3">
    {{#if this.submitting}}
      <span class="text-sm text-gray-500 dark:text-gray-400">Parsing…</span>
    {{/if}}
    <button
      type="submit"
      class="btn primary"
      disabled={{this.submitting}}
    >{{this.submitLabel}}</button>
  </div>
</form>

{{! template-lint-disable no-nested-interactive }}
<details
  class="mt-8 rounded-md border border-gray-200 p-4 dark:border-gray-700"
>
  <summary
    class="cursor-pointer text-sm font-semibold text-gray-900 dark:text-gray-100"
  >Install the bookmarklet</summary>
  <div class="mt-3 space-y-2 text-sm text-gray-600 dark:text-gray-400">
    <p>
      Drag this link to your bookmarks bar. On any job posting page, click it —
      the posting's URL and visible text are shipped to this form in a new tab.
    </p>
    <p>
      <a
        href="#"
        {{on-insert this.setBookmarkletHref}}
        class="inline-flex items-center rounded-md border border-accent-500 bg-accent-50 px-3 py-1.5 font-semibold text-accent-700 hover:bg-accent-100 dark:border-accent-400 dark:bg-accent-900/30 dark:text-accent-200 dark:hover:bg-accent-900/50"
      >📎 Send to Career Caddy</a>
    </p>
    <p class="text-xs text-gray-500 dark:text-gray-500">
      Allow popups for this domain. The bookmarklet opens a new tab and posts
      the page text to it — nothing leaves your browser until you hit submit.
    </p>
  </div>
</details>

<div class="mt-4 rounded-md border border-gray-200 p-4 dark:border-gray-700">
  <p class="text-sm font-semibold text-gray-900 dark:text-gray-100">
    Browser extension
  </p>
  <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
    A signed
    <em>Career Caddy Sender</em>
    extension is on the way to the Chrome Web Store and Firefox Add-ons. Until
    it's listed, the bookmarklet above covers the same workflow on most sites.
  </p>
</div>