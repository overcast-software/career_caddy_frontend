{{#if (in-route-scope "job-posts.show.cover-letters.show")}}
  <LinkTo
    @route="job-posts.show.cover-letters"
    @model={{this.jobPost}}
    class="mb-4 inline-block text-sm text-blue-600 hover:underline"
  >← Cover letters</LinkTo>
{{else}}
  <section class="panel-card mb-6">
    <h2 class="panel-title">New cover letter</h2>
    <div class="panel-body">
      <div class="flex items-center gap-2">
        <div class="flex-1 max-w-xs">
          <PowerSelect
            @options={{this.resumes}}
            @selected={{this.selectedResume}}
            @onChange={{this.selectResume}}
            @placeholder="Select resume…"
            as |resume|
          >{{or resume.name resume.title}}</PowerSelect>
        </div>
        <button
          type="button"
          class="btn shrink-0"
          {{on "click" this.createCoverLetter}}
        >Create</button>
      </div>
      <textarea
        id="cl-instructions"
        class="w-full bg-accent-50 text-gray-900 dark:bg-accent-900/20 dark:text-gray-100"
        rows="3"
        placeholder="Instructions for AI (optional)..."
        {{on "input" this.updateInstructions}}
      >{{this.instructions}}</textarea>
    </div>
  </section>

  <section class="mb-6">
    <h2 class="panel-title">Cover letters</h2>
    <CoverLetters::List
      @coverLetters={{this.model}}
      @isPending={{this.isPending}}
      @showJobPost={{false}}
      @jobPost={{this.jobPost}}
      @emptyMessage="No cover letters yet."
    />
  </section>
{{/if}}

{{outlet}}