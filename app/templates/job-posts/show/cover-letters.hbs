<div class="flex items-center gap-2 mb-4">
  <div class="flex-1 max-w-xs">
    <PowerSelect
      @options={{this.resumes}}
      @selected={{this.selectedResume}}
      @onChange={{this.selectResume}}
      @placeholder="Select resume…"
      as |resume|
    >{{or resume.name resume.title}}</PowerSelect>
  </div>
  <button
    type="button"
    class="btn shrink-0"
    {{on "click" this.createCoverLetter}}
  >New Cover Letter</button>
</div>

<CoverLetters::List
  @coverLetters={{this.model}}
  @isPending={{this.isPending}}
  @showJobPost={{false}}
  @emptyMessage="No cover letters yet."
/>