<div class="flex items-center gap-2 mb-4">
  <div class="flex-1 max-w-xs">
    <PowerSelect
      @options={{this.resumes}}
      @selected={{this.selectedResume}}
      @onChange={{this.selectResume}}
      @placeholder="Select resume…"
      as |resume|
    >{{or resume.name resume.title}}</PowerSelect>
  </div>
  <button type="button" class="btn shrink-0" {{on "click" this.createCoverLetter}}>New Cover Letter</button>
</div>

{{#if this.model.length}}
  <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Status</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Created</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Favorite</th>
          <th class="px-4 py-3 text-right font-semibold text-gray-600">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each this.model as |coverLetter|}}
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3">
              {{#if (this.isPending coverLetter)}}
                <span class="inline-flex items-center gap-1.5 text-gray-400">
                  <svg class="animate-spin size-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                  Generating…
                </span>
              {{else}}
                {{or coverLetter.status "—"}}
              {{/if}}
            </td>
            <td class="px-4 py-3 text-gray-600">{{format-date coverLetter.createdAt "MMM D, YYYY"}}</td>
            <td class="px-4 py-3 text-gray-600">
              {{#if coverLetter.favorite}}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4 text-amber-400">
                  <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
                </svg>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-right">
              {{#unless (this.isPending coverLetter)}}
                <LinkTo
                  @route="cover-letters.show"
                  @model={{coverLetter}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
                >View</LinkTo>
              {{/unless}}
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <p class="text-gray-500 text-sm py-6 text-center">No cover letters yet.</p>
{{/if}}
