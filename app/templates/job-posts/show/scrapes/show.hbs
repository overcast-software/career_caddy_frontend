{{page-title "Scrape"}}
<div class="space-y-4">
  <LinkTo
    @route="job-posts.show.scrapes"
    @model={{this.jobPost}}
    class="mb-4 inline-block text-sm text-blue-600 hover:underline"
  >← Scrapes</LinkTo>

  <Scrapes::Item @scrape={{this.model}} />

  <div class="form-actions mt-4">
    <LinkTo @route="scrapes.edit" @model={{this.model}} class="btn">
      Edit
    </LinkTo>
    <button
      type="button"
      class="btn"
      title="Re-fetch the URL and run the full pipeline again"
      {{on "click" (fn this.retryScrape this.model)}}
    >Retry</button>
    <button
      type="button"
      class="btn"
      title="Re-run extraction on the existing scrape content (no re-fetch)"
      {{on "click" (fn this.parseScrape this.model)}}
    >Re-parse</button>
    <LinkTo
      @route="scrapes.graph"
      @model={{this.model.id}}
      class="btn"
    >Graph</LinkTo>
  </div>
</div>