{{! Generic skeleton for any /job-posts/:id/* child route whose model
    hook is pending. Keeps the tab slide animation feeling "alive"
    while data resolves — the user sees a placeholder pane pass under
    the tab strip rather than an empty void. }}
<div
  class="animate-pulse space-y-3"
  role="status"
  aria-label="Loading tab content"
>
  <div class="h-5 w-1/3 rounded bg-gray-200 dark:bg-gray-700"></div>
  <div class="h-4 w-full rounded bg-gray-200 dark:bg-gray-700"></div>
  <div class="h-4 w-5/6 rounded bg-gray-200 dark:bg-gray-700"></div>
  <div class="h-4 w-2/3 rounded bg-gray-200 dark:bg-gray-700"></div>
</div>