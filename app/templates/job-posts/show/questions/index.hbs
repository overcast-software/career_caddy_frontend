{{outlet}}

<div class="flex items-center justify-between mb-4">
  <h2
    class="text-lg font-semibold text-gray-800 dark:text-gray-200"
  >Questions</h2>
  <LinkTo
    @route="job-posts.show.questions.new"
    @model={{this.model.jobPost}}
    class="btn"
  >New Question</LinkTo>
</div>

{{#if this.model.questions.length}}
  <div
    class="overflow-x-auto rounded-lg border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800"
  >
    <table class="min-w-full text-sm">
      <thead
        class="bg-gray-50 border-b border-gray-200 dark:bg-gray-700 dark:border-gray-600"
      >
        <tr>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
          >Question</th>
          <th
            class="px-4 py-3 text-center font-semibold text-gray-600 dark:text-gray-300 w-24"
          >Answers</th>
          <th
            class="px-4 py-3 text-center font-semibold text-gray-600 dark:text-gray-300 w-16"
          >Fav</th>
          <th
            class="px-4 py-3 text-right font-semibold text-gray-600 dark:text-gray-300 w-48"
          >Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
        {{#each this.model.questions as |question|}}
          <tr
            class="hover:bg-gray-50 dark:hover:bg-gray-700
              {{if
                (eq this.answeringQuestionId question.id)
                'bg-accent-50 dark:bg-accent-900/30'
              }}"
          >
            <td
              class="px-4 py-3 text-gray-900 dark:text-gray-100 whitespace-pre-wrap break-words max-w-lg"
            >
              {{question.content}}
            </td>
            <td class="px-4 py-3 text-center">
              {{#if question.answers.length}}
                <LinkTo
                  @route="job-posts.show.questions.show"
                  @models={{array this.model.jobPost.id question.id}}
                  class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-accent-100 text-accent-700 text-xs font-semibold hover:bg-accent-200 dark:bg-accent-900 dark:text-accent-300 dark:hover:bg-accent-800"
                >{{question.answers.length}}</LinkTo>
              {{else}}
                <span class="text-gray-300 dark:text-gray-600 text-xs">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-center text-base">
              {{if question.favorite "★" "☆"}}
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-1.5 flex-wrap">
                <LinkTo
                  @route="job-posts.show.questions.show"
                  @models={{array this.model.jobPost.id question.id}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
                >Show</LinkTo>
                <button
                  type="button"
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
                  {{on "click" (fn this.editQuestion question)}}
                >Edit</button>
                <button
                  type="button"
                  class="px-2 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50 dark:border-red-800 dark:text-red-400 dark:hover:bg-red-900/30"
                  {{on "click" (fn this.deleteQuestion question)}}
                >Delete</button>
                <button
                  type="button"
                  class="px-2 py-1 text-xs rounded border
                    {{if
                      (eq this.answeringQuestionId question.id)
                      'border-accent-400 bg-accent-50 text-accent-700 dark:border-accent-500 dark:bg-accent-900/50 dark:text-accent-300'
                      'border-accent-200 text-accent-600 hover:bg-accent-50 dark:border-accent-600 dark:text-accent-400 dark:hover:bg-accent-900/30'
                    }}"
                  {{on "click" (fn this.startAnswering question)}}
                >Answer</button>
              </div>
            </td>
          </tr>

          {{#if (eq this.answeringQuestionId question.id)}}
            <tr
              class="bg-accent-50 dark:bg-accent-900/20 border-t border-accent-100 dark:border-accent-800"
            >
              <td colspan="4" class="px-4 pb-4 pt-2">
                <form {{on "submit" this.submitAnswer}}>
                  <div class="flex flex-col gap-3">

                    <div class="flex items-center gap-2">
                      <span
                        class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide"
                      >
                        Answering:
                      </span>
                      <span
                        class="text-sm text-gray-700 dark:text-gray-300 italic"
                      >{{question.content}}</span>
                    </div>

                    <div class="flex items-center gap-2">
                      <button
                        type="button"
                        class="px-3 py-1.5 text-xs rounded border font-medium
                          {{if
                            this.useAI
                            'bg-accent-600 border-accent-600 text-white hover:bg-accent-700'
                            'border-gray-300 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700'
                          }}"
                        disabled={{if this.isPollingAnswerId true false}}
                        {{on "click" this.toggleAI}}
                      >
                        {{if this.useAI "✓ Ask AI" "Ask AI"}}
                      </button>
                      {{#if (eq this.isPollingAnswerId question.id)}}
                        <span
                          class="text-xs text-accent-500 italic flex items-center gap-1"
                        >
                          <svg
                            class="animate-spin size-3"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                          >
                            <circle
                              class="opacity-25"
                              cx="12"
                              cy="12"
                              r="10"
                              stroke="currentColor"
                              stroke-width="4"
                            ></circle>
                            <path
                              class="opacity-75"
                              fill="currentColor"
                              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"
                            ></path>
                          </svg>
                          AI is generating…
                        </span>
                      {{/if}}
                    </div>

                    {{#if this.useAI}}
                      <div class="flex flex-col gap-1">
                        <label
                          for="additional-prompt"
                          class="text-xs font-medium text-gray-500 dark:text-gray-400"
                        >Additional context for AI (optional)</label>
                        <textarea
                          id="additional-prompt"
                          class="w-full rounded border border-gray-300 px-3 py-2 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-accent-300 focus:border-accent-400 resize-y dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:focus:ring-accent-600 dark:focus:border-accent-500"
                          rows="2"
                          placeholder="e.g. Emphasize my background in distributed systems…"
                          {{on "input" this.updateAdditionalPrompt}}
                        >{{this.additionalPrompt}}</textarea>
                      </div>
                    {{else}}
                      <div class="flex flex-col gap-1">
                        <label
                          for="answer-content"
                          class="text-xs font-medium text-gray-500 dark:text-gray-400"
                        >Your answer</label>
                        <textarea
                          id="answer-content"
                          class="w-full rounded border border-gray-300 px-3 py-2 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-accent-300 focus:border-accent-400 resize-y dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:focus:ring-accent-600 dark:focus:border-accent-500"
                          rows="4"
                          placeholder="Write your answer here…"
                          {{on "input" this.updateAnswerContent}}
                        >{{this.answerContent}}</textarea>
                      </div>
                    {{/if}}

                    <div class="flex items-center gap-2">
                      <button
                        type="submit"
                        class="btn primary"
                        disabled={{if this.isPollingAnswerId true false}}
                      >Save</button>
                      <button
                        type="button"
                        class="btn"
                        {{on "click" this.cancelAnswer}}
                      >Cancel</button>
                    </div>

                  </div>
                </form>
              </td>
            </tr>
          {{/if}}

        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <div class="text-center py-12 text-gray-400 dark:text-gray-500">
    <p class="text-sm">No questions yet.</p>
    <LinkTo
      @route="job-posts.show.questions.new"
      @model={{this.model.jobPost}}
      class="mt-2 inline-block text-sm text-accent-500 hover:underline dark:text-accent-400"
    >Add the first one →</LinkTo>
  </div>
{{/if}}