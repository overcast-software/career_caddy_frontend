{{outlet}}

<div class="flex justify-end mb-4">
  <LinkTo
    @route="job-posts.show.questions.new"
    @model={{this.model.jobPost}}
    class="btn"
  >New Question</LinkTo>
</div>

{{#if this.model.questions.length}}
  <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Question</th>
          <th class="px-4 py-3 text-right font-semibold text-gray-600">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each this.model.questions as |question|}}
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-900 max-w-md truncate">{{question.content}}</td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <LinkTo
                  @route="questions.show"
                  @model={{question}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
                >Show</LinkTo>
                <LinkTo
                  @route="questions.show.answers"
                  @model={{question}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
                >Answers</LinkTo>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <p class="text-gray-500 text-sm py-6 text-center">No questions for this job post.</p>
{{/if}}
