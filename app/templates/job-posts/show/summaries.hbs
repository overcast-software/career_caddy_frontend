<div class="flex items-center gap-2 mb-4">
  <div class="flex-1 max-w-xs">
    <PowerSelect
      @options={{this.resumes}}
      @selected={{this.selectedResume}}
      @onChange={{this.selectResume}}
      @placeholder="Select resume…"
      as |resume|
    >{{or resume.name resume.title}}</PowerSelect>
  </div>
  <button
    type="button"
    class="btn shrink-0"
    {{on "click" this.createSummary}}
  >+ New Summary</button>
</div>

{{#if this.model.summaries.length}}
  <div
    class="overflow-x-auto rounded-lg border border-gray-200 bg-white dark:border-gray-700 dark:bg-gray-800"
  >
    <table class="min-w-full text-sm">
      <thead
        class="bg-gray-50 border-b border-gray-200 dark:bg-gray-700 dark:border-gray-600"
      >
        <tr>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
          >Summary</th>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
          >Resume</th>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
          >Active</th>
          <th
            class="px-4 py-3 text-right font-semibold text-gray-600 dark:text-gray-300"
          >Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
        {{#each this.model.summaries as |summary|}}
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
            <td
              class="px-4 py-3 text-gray-900 dark:text-gray-100 max-w-md truncate"
            >
              {{#if (this.isPending summary)}}
                <span class="inline-flex items-center gap-1.5 text-gray-400">
                  <svg
                    class="animate-spin size-3.5"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                  >
                    <circle
                      class="opacity-25"
                      cx="12"
                      cy="12"
                      r="10"
                      stroke="currentColor"
                      stroke-width="4"
                    ></circle>
                    <path
                      class="opacity-75"
                      fill="currentColor"
                      d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"
                    ></path>
                  </svg>
                  Generating…
                </span>
              {{else}}
                {{summary.content}}
              {{/if}}
            </td>
            <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
              {{#if summary.resume.id}}
                {{or summary.resume.name summary.resume.title}}
              {{else}}
                <span class="italic text-gray-500">Career Data</span>
              {{/if}}
            </td>
            <td class="px-4 py-3">
              {{#if summary.active}}
                <span
                  class="inline-flex items-center rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20 dark:bg-green-900/30 dark:text-green-400 dark:ring-green-500/30"
                >Active</span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-right">
              {{#unless (this.isPending summary)}}
                <LinkTo
                  @route="summaries.show"
                  @model={{summary}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
                >View</LinkTo>
              {{/unless}}
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <EmptyState @message="No summaries for this job post." />
{{/if}}