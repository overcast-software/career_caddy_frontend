{{page-title "Applications"}}
{{outlet}}

<div class="fairway">
  {{#if this.model.jobApplications.length}}
    <div class="flex justify-end mb-4">
      <LinkTo
        @route="job-applications.new"
        @query={{hash jobId=this.model.jobPost.id}}
        class="btn"
      >
        New Application
      </LinkTo>
    </div>
    {{#each this.model.jobApplications as |jobApplication|}}
      <Panel::Card>
        <LinkTo @route="job-applications.show" @model={{jobApplication.id}}>
          {{jobApplication.id}}
        </LinkTo>
        -- applied at
        {{format-date jobApplication.createdAt}}
        status:
        {{jobApplication.status}}
      </Panel::Card>
    {{/each}}
  {{else}}
    <Panel::Card @title="No applications yet">
      <:top>
        <LinkTo
          @route="job-applications.new"
          @query={{hash jobId=this.model.jobPost.id}}
          class="btn"
        >
          New Application
        </LinkTo>
      </:top>
      <:default>
        No job applications have been created for this posting.
      </:default>
    </Panel::Card>
  {{/if}}
</div>
