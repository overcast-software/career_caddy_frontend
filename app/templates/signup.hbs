{{page-title "Sign Up — Career Caddy"}}
<RouteLayout @noSubnav={{true}} @mainClass="login-main">
  <:subnav></:subnav>
  <:main>
    <div class="landing-hero landing-hero--centered">
      <div class="landing-hero-overlay"></div>
      <div class="login-card">
        <div class="login-card-brand">
          <span class="brand-title">Career<span>Caddy</span></span>
        </div>

        {{#if this.success}}
          {{#if this.registrationOpen}}
            <h1 class="login-card-title">Account created.</h1>
            <p class="login-card-sub">
              Your account is ready. You can now sign in.
            </p>
            <div class="mt-6">
              <LinkTo @route="login" class="login-submit">Sign in</LinkTo>
            </div>
          {{else}}
            <h1 class="login-card-title">You're on the list.</h1>
            <p class="login-card-sub">
              We'll let you know when Career Caddy is ready for you.
            </p>
            <div class="mt-6">
              <LinkTo @route="login" class="login-submit">Back to Login</LinkTo>
            </div>
          {{/if}}
        {{else if this.registrationOpen}}
          <h1 class="login-card-title">Create an account.</h1>
          <p class="login-card-sub">
            Sign up for Career Caddy to start managing your job search.
          </p>

          {{#if this.errorMessage}}
            <div class="error">{{this.errorMessage}}</div>
          {{/if}}

          <form
            aria-label="Create account"
            {{on "submit" this.submitRegistration}}
            class="login-form"
          >
            <div class="login-field">
              <label for="first-name">First name</label>
              <input
                id="first-name"
                type="text"
                placeholder="First name"
                value={{this.firstName}}
                {{on "input" this.updateFirstName}}
                autocomplete="given-name"
              />
            </div>
            <div class="login-field">
              <label for="last-name">Last name</label>
              <input
                id="last-name"
                type="text"
                placeholder="Last name"
                value={{this.lastName}}
                {{on "input" this.updateLastName}}
                autocomplete="family-name"
              />
            </div>
            <div class="login-field">
              <label for="email">Email</label>
              <input
                id="email"
                type="email"
                placeholder="you@example.com"
                value={{this.email}}
                {{on "input" this.updateEmail}}
                autocomplete="email"
                required
              />
            </div>
            <div class="login-field">
              <label for="username">Username</label>
              <input
                id="username"
                type="text"
                placeholder="Choose a username"
                value={{this.username}}
                {{on "input" this.updateUsername}}
                autocomplete="username"
                required
              />
            </div>
            <div class="login-field">
              <label for="password">Password</label>
              <input
                id="password"
                type="password"
                placeholder="Choose a password"
                value={{this.password}}
                {{on "input" this.updatePassword}}
                autocomplete="new-password"
                required
              />
            </div>
            <div class="login-field">
              <label for="confirm-password">Confirm password</label>
              <input
                id="confirm-password"
                type="password"
                placeholder="Confirm password"
                value={{this.confirmPassword}}
                {{on "input" this.updateConfirmPassword}}
                autocomplete="new-password"
                required
              />
            </div>
            <button type="submit" class="login-submit" disabled={{this.saving}}>
              {{if this.saving "Creating account..." "Create Account"}}
            </button>
          </form>

          <p class="login-card-setup">
            Already have an account?
            <LinkTo @route="login">Sign in</LinkTo>
          </p>
        {{else}}
          <h1 class="login-card-title">Join the waiting list.</h1>
          <p class="login-card-sub">
            Career Caddy is currently in early access. Enter your email and
            we'll notify you when a spot opens up.
          </p>

          {{#if this.errorMessage}}
            <div class="error">{{this.errorMessage}}</div>
          {{/if}}

          <form
            aria-label="Join waiting list"
            {{on "submit" this.submitWaitlist}}
            class="login-form"
          >
            <div class="login-field">
              <label for="waitlist-email">Email address</label>
              <input
                id="waitlist-email"
                type="email"
                placeholder="you@example.com"
                value={{this.email}}
                {{on "input" this.updateEmail}}
                autocomplete="email"
                required
              />
            </div>
            <button type="submit" class="login-submit" disabled={{this.saving}}>
              {{if this.saving "Joining..." "Join Waiting List"}}
            </button>
          </form>

          <p class="login-card-setup">
            Already have an account?
            <LinkTo @route="login">Sign in</LinkTo>
          </p>
        {{/if}}
      </div>
    </div>
  </:main>
</RouteLayout>