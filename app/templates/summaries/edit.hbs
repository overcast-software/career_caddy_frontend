{{page-title "Edit Summary"}}
<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <LinkTo
      class="btn"
      @route="summaries.show"
      @model={{this.model.id}}
    >View</LinkTo>
  </:subnav>
  <:main>
    <form class="builder-form" {{on "submit" this.saveSummary}}>
      {{#if this.model.jobPost.title}}
        <p class="muted">{{this.model.jobPost.title}}</p>
      {{/if}}
      <div class="field-full">
        <label class="field-label">Resume (optional)</label>
        <PowerSelect
          @options={{this.resumeOptions}}
          @selected={{this.model.resume}}
          @onChange={{this.updateResume}}
          @placeholder="Select a resume..."
          as |resume|
        >
          {{or resume.name resume.title}}
        </PowerSelect>
      </div>
      <div class="field-full">
        <label class="field-label" for="summary-content">Content</label>
        <textarea
          id="summary-content"
          {{on "input" this.updateContent}}
          rows="12"
        >{{this.model.content}}</textarea>
      </div>
      <div class="form-actions">
        <button
          type="button"
          class="btn favorite {{if this.model.active 'favorited'}}"
          title="{{if this.model.active 'Mark inactive' 'Mark active'}}"
          {{on "click" this.toggleActive}}
        >★</button>
        <button type="submit" class="btn">Save</button>
        <button
          type="button"
          class="btn danger"
          {{on "click" this.deleteSummary}}
        >Delete</button>
      </div>
    </form>
  </:main>
</RouteLayout>