<RouteLayout @flashMessages={{this.flashMessages}}>
  <:main>
    <Panel::Card @collapsible={{true}} @title="Resume (optional)">
      <div class="field-full">
        <label class="field-label">Resume</label>
        <PowerSelect
          @options={{this.resumeOptions}}
          @onChange={{this.updateResume}}
          @selected={{this.selectedResume}}
          as |resume|
        >
          {{or resume.name resume.title}}
        </PowerSelect>
      </div>
    </Panel::Card>
    <Panel::Card>
      <div class="field-full">
        <label class="field-label">Job Post</label>
        <JobPosts::Selector
          @jobPosts={{this.jobPosts}}
          @jobPostCallback={{this.addJobPostToCoverLetter}}
        />
      </div>
    </Panel::Card>
    {{#if this.model.jobPost}}
      <Panel::Card @title="Additional Instructions (optional)">
        <div class="field-full">
          <label class="field-label" for="cl-instructions">Instructions for AI</label>
          <textarea
            id="cl-instructions"
            placeholder="Add any additional context or instructions for the AI..."
            {{on "input" this.updateInstructions}}
          >{{this.instructions}}</textarea>
        </div>
      </Panel::Card>
      <Panel::Card>
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="btn primary"
            disabled={{this.model.isSaving}}
            {{on "click" this.saveCoverLetter}}
          >
            AI Craft Cover Letter
          </button>
          <button
            type="button"
            class="btn"
            {{on "click" this.cancel}}
          >Cancel</button>
        </div>
      </Panel::Card>
    {{/if}}
    <Panel::Card @collapsible={{true}}>
      <CoverLetters::Form @coverLetter={{this.model}} />
    </Panel::Card>
  </:main>
</RouteLayout>