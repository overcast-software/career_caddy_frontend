<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <button
      type="button"
      class="btn"
      disabled={{this.model.isSaving}}
      {{on "click" this.saveCoverLetter}}
    >Save</button>
  </:subnav>
  <:main>
    <Panel::Card @collapsible={{true}} @title="Resume (optional)">
      <div class="field-full">
        <label class="field-label">Resume</label>
        <PowerSelect
          @options={{this.resumeOptions}}
          @onChange={{this.updateResume}}
          @selected={{this.selectedResume}}
          as |resume|
        >
          {{or resume.name resume.title}}
        </PowerSelect>
      </div>
    </Panel::Card>
    <Panel::Card>
      <div class="field-full">
        <label class="field-label">Job Post</label>
        <JobPosts::Selector
          @jobPosts={{this.jobPosts}}
          @jobPostCallback={{this.addJobPostToCoverLetter}}
        />
      </div>
    </Panel::Card>
    {{#if this.model.jobPost}}
      <Panel::Card>
        <button
          type="button"
          class="btn primary"
          disabled={{this.model.isSaving}}
          {{on "click" this.saveCoverLetter}}
        >
          AI Craft Cover Letter
        </button>
      </Panel::Card>
    {{/if}}
    <Panel::Card @collapsible={{true}}>
      <CoverLetters::Form @coverLetter={{this.model}} />
    </Panel::Card>
  </:main>
</RouteLayout>