<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <Buttons::Favorite
      @model={{this.model}}
      @onToggle={{this.toggleFavorite}}
    />
    <button type="button" {{on "click" this.exportToDocx}} class="btn">export to
      docx</button>
    <LinkTo
      class="btn"
      @route="cover-letters.edit"
      @model={{this.model}}
    >edit</LinkTo>
  </:subnav>
  <:main>
    <CoverLetters::Item @coverLetter={{this.model}} />
  </:main>
</RouteLayout>