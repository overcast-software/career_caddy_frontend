<RouteLayout @flashMessages={{this.flashMessages}}>
  <:subnav>
    <button
      type="button"
      class="btn favorite {{if this.model.favorite 'favorited'}}"
      data-tooltip="Favorited items appear in Career Data"
      {{on "click" this.toggleFavorite}}
    >★</button>
    <button type="button" {{on "click" this.exportToDocx}} class="btn">export to docx</button>
    <LinkTo class="btn" @route="cover-letters.edit" @model={{this.model}}>edit</LinkTo>
  </:subnav>
  <:main>
    <CoverLetters::Item @coverLetter={{this.model}} />
  </:main>
</RouteLayout>
