<div class="grid gap-3">
  {{#if this.errorMessage}}<p class="text-xs text-red-400">{{this.errorMessage}}</p>{{/if}}

  <label class="flex flex-col gap-1">
    <span class="text-xs text-gray-400 uppercase tracking-wide">Institution</span>
    <input
      type="text"
      value={{this.education.institution}}
      class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
      {{on "input" (fn this.updateField "institution")}}
    />
  </label>

  <div class="grid grid-cols-2 gap-3">
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">Issue Date</span>
      <input
        type="date"
        value={{this.formattedIssueDate}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "issueDate")}}
      />
    </label>
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">Degree</span>
      <input
        type="text"
        value={{this.education.degree}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "degree")}}
      />
    </label>
  </div>

  <div class="grid grid-cols-2 gap-3">
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">Major</span>
      <input
        type="text"
        value={{this.education.major}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "major")}}
      />
    </label>
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">Minor</span>
      <input
        type="text"
        value={{this.education.minor}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "minor")}}
      />
    </label>
  </div>
</div>