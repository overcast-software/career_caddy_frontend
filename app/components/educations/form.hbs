<form class="builder-form">
  {{#if this.errorMessage}}<p class="error">{{this.errorMessage}}</p>{{/if}}

  <div class="field">
    <label class="field-label">Institution</label>
    <input
      type="text"
      value={{this.education.institution}}
      {{on "input" (fn this.updateField "institution")}}
    />
  </div>

  <div class="field-row">
    <div class="field">
      <label class="field-label">Issue Date</label>
      <input
        type="date"
        value={{this.formattedIssueDate}}
        {{on "input" (fn this.updateField "issueDate")}}
      />
    </div>
    <div class="field">
      <label class="field-label">Degree</label>
      <input
        type="text"
        value={{this.education.degree}}
        {{on "input" (fn this.updateField "degree")}}
      />
    </div>
  </div>

  <div class="field-row">
    <div class="field">
      <label class="field-label">Major</label>
      <input
        type="text"
        value={{this.education.major}}
        {{on "input" (fn this.updateField "major")}}
      />
    </div>
    <div class="field">
      <label class="field-label">Minor</label>
      <input
        type="text"
        value={{this.education.minor}}
        {{on "input" (fn this.updateField "minor")}}
      />
    </div>
  </div>
</form>
