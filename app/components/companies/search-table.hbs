{{!
  Server-side company search rendered as a table with relate-actions.
  Search input + InfinityLoader mirror /companies/index; the parent
  route drives the queryParam + infinity model. We just render and
  per-row act.
}}
<div class="panel-card mt-6" data-test-companies-search-table>
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-lg font-semibold">Find related companies</h2>
    <Menus::SubnavSearch
      @value={{@searchTerm}}
      @onSearch={{@onSearch}}
      @onSearchStart={{@onSearchStart}}
      @placeholder="Search companies…"
    />
  </div>
  <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
    Use the per-row actions to merge
    <span class="font-medium">{{@sourceCompany.name}}</span>
    into a result, mark
    <span class="font-medium">{{@sourceCompany.name}}</span>
    as an alias of the result, or mark the result as an alias of
    <span class="font-medium">{{@sourceCompany.name}}</span>.
  </p>

  {{#if @isSearching}}
    <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">Searching…</p>
  {{else if this.hasVisibleRows}}
    <div
      class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800"
    >
      <table class="min-w-full text-sm">
        <thead
          class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600"
        >
          <tr>
            <th
              class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
            >Name</th>
            <th
              class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
            >Display name</th>
            <th
              class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
            >ID</th>
            <th
              class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
            >Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          {{#each @searchResults as |row|}}
            {{#if (this.shouldShowRow row)}}
              <tr
                class="hover:bg-gray-50 dark:hover:bg-gray-700/50"
                data-test-search-row={{row.id}}
              >
                <td
                  class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100"
                >{{row.name}}</td>
                <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                  {{#if row.displayName}}{{row.displayName}}{{else}}—{{/if}}
                </td>
                <td
                  class="px-4 py-3 font-mono text-xs text-gray-500 dark:text-gray-400"
                >#{{row.id}}</td>
                <td class="px-4 py-3">
                  <div class="flex flex-wrap gap-2">
                    <LinkTo
                      @route="admin.companies.show"
                      @model={{row.id}}
                      class="btn"
                      data-test-action="view"
                    >View</LinkTo>
                    <LinkTo
                      @route="companies.edit"
                      @model={{row.id}}
                      class="btn"
                      data-test-action="edit"
                    >Edit</LinkTo>
                    <button
                      type="button"
                      class="btn"
                      disabled={{this.actingId}}
                      data-test-action="merge"
                      {{on "click" (fn this.mergeCurrentInto row)}}
                    >
                      {{if
                        (this.isActing "merge" row.id)
                        "Merging…"
                        "Merge into this"
                      }}
                    </button>
                    <button
                      type="button"
                      class="btn"
                      disabled={{this.actingId}}
                      data-test-action="mark-current"
                      {{on "click" (fn this.markCurrentAsAliasOf row)}}
                    >
                      {{if
                        (this.isActing "mark-current" row.id)
                        "Marking…"
                        "Set this as canonical"
                      }}
                    </button>
                    <button
                      type="button"
                      class="btn"
                      disabled={{this.actingId}}
                      data-test-action="mark-row"
                      {{on "click" (fn this.markRowAsAliasOfCurrent row)}}
                    >
                      {{if
                        (this.isActing "mark-row" row.id)
                        "Marking…"
                        "Adopt as alias"
                      }}
                    </button>
                  </div>
                </td>
              </tr>
            {{/if}}
          {{/each}}
        </tbody>
      </table>
    </div>
    <InfinityLoader @infinityModel={{@searchResults}} @hideOnInfinity={{true}}>
      <div class="py-4 text-center text-sm text-gray-400">Loading more…</div>
    </InfinityLoader>
  {{else}}
    <p class="text-sm text-gray-500 dark:text-gray-400">No companies match.</p>
  {{/if}}
</div>