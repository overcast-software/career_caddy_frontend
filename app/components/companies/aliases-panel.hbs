{{!
  Renders the Company's aliases (Phase A self-FK: every Company whose
  canonical_id == this.id). Each row links to the alias's own staff
  page. An expander panel below the table lets staff demote the
  current Company into an alias of another via the markAsAliasOf
  action (POST /companies/:id/mark-as-alias-of/).
}}
<div class="panel-card mt-6" data-test-aliases-panel>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold">Name aliases</h2>
    <span class="text-xs text-gray-500 dark:text-gray-400">
      {{this.rows.length}}
      {{if (eq this.rows.length 1) "alias" "aliases"}}
    </span>
  </div>

  {{#if this.isAlias}}
    <div
      class="mb-4 rounded-md bg-amber-50 p-3 ring-1 ring-inset ring-amber-200 dark:bg-amber-500/10 dark:ring-amber-500/30"
      data-test-already-alias
    >
      <div class="flex items-start justify-between gap-3">
        <p class="text-sm text-amber-800 dark:text-amber-200">
          This Company is itself an alias. Visit the canonical record to manage
          its aliases, or unmark to restore it as canonical.
        </p>
        <button
          type="button"
          class="btn"
          disabled={{this.unmarking}}
          data-test-unmark-button
          {{on "click" this.confirmUnmark}}
        >
          {{if this.unmarking "Unmarking…" "Unmark — restore as canonical"}}
        </button>
      </div>
    </div>
  {{/if}}

  {{#if this.rows.length}}
    <div
      class="overflow-x-auto rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800"
    >
      <table class="min-w-full text-sm">
        <thead
          class="bg-gray-50 dark:bg-gray-700 border-b border-gray-200 dark:border-gray-600"
        >
          <tr>
            <th
              class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
            >Name</th>
            <th
              class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
            >Display name</th>
            <th
              class="px-4 py-3 text-left font-semibold text-gray-600 dark:text-gray-300"
            >ID</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          {{#each this.rows as |row|}}
            <tr
              class="hover:bg-gray-50 dark:hover:bg-gray-700/50"
              data-test-alias-row={{row.id}}
            >
              <td
                class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100"
              >
                <LinkTo
                  @route="admin.companies.show"
                  @model={{row.id}}
                  class="text-accent-600 dark:text-accent-400 hover:underline"
                >{{row.name}}</LinkTo>
              </td>
              <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
                {{#if row.displayName}}
                  {{row.displayName}}
                {{else}}
                  —
                {{/if}}
              </td>
              <td
                class="px-4 py-3 font-mono text-xs text-gray-500 dark:text-gray-400"
              >#{{row.id}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{else}}
    <EmptyState
      @message="No aliases yet. Aliases are recorded when staff mark a Company as an alias of this one, or when a merge runs."
    />
  {{/if}}

  {{#unless this.isAlias}}
    <p class="text-xs text-gray-500 dark:text-gray-400 mt-3">
      Use the
      <span class="font-medium">Find related companies</span>
      table below to mark another Company as an alias of this one or to mark
      this one as an alias of another.
    </p>
  {{/unless}}
</div>