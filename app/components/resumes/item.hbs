<div class="w-[90%] mx-auto space-y-6">
  <Resumes::Header @user={{@resume.user}} @resume={{@resume}} />

  {{#if this.activeSummary}}
    <section>
      <h2
        class="text-base font-bold uppercase tracking-wider text-gray-900 border-b border-gray-300 pb-1 mb-2"
      >Summary</h2>
      <div class="summary">{{this.activeSummary.content}}</div>
    </section>
  {{/if}}
  {{#if this.hasSkills}}
    <section>
      <h2
        class="text-base font-bold uppercase tracking-wider text-gray-900 border-b border-gray-300 pb-1 mb-2"
      >Skills</h2>
      {{#each-in this.groupedSkillsMap as |group skills|}}
        <div class="skills-row">
          <div class="skills-group-title">{{group}}:</div>
          <ul class="skills-list">
            {{#each skills as |skill|}}
              <li class="skills-block whitespace-pre-wrap">{{skill.text}}</li>
            {{/each}}
          </ul>
        </div>
      {{/each-in}}
    </section>
  {{/if}}

  {{#if @resume.experiences.length}}
    <section>
      <h2
        class="text-base font-bold uppercase tracking-wider text-gray-900 border-b border-gray-300 pb-1 mb-2"
      >Experience</h2>
      {{#each this.sortedExperiences as |exp|}}
        <article class="experience">
          <div class="job-header">
            <div class="job-title font-semibold">
              {{exp.title}}
              <span class="job-dates">
                {{#if exp.startDate}}
                  {{#if exp.endDate}}
                    {{format-date exp.startDate "MM.YYYY"}}
                    -
                    {{format-date exp.endDate "MM.YYYY"}}
                  {{else}}
                    {{format-date exp.startDate "MM.YYYY"}}
                  {{/if}}
                {{else}}
                  {{#if exp.endDate}}
                    {{format-date exp.endDate "MM.YYYY"}}
                  {{/if}}
                {{/if}}
              </span>
            </div>
            <div class="job-meta text-[var(--muted)]">
              <span>{{exp.company.name}}</span>
              <span class="dot">•</span>
              <span>{{exp.location}}</span>
            </div>
          </div>

          {{#if exp.summary}}
            <div class="job-summary">{{exp.summary}}</div>
          {{/if}}

          <ul class="desc-list list-disc ml-5">
            {{#each exp.descriptions as |desc|}}
              <li class="desc-item">{{desc.content}}</li>
            {{/each}}
          </ul>
        </article>
      {{/each}}
    </section>
  {{/if}}

  {{#if @resume.projects.length}}
    <section>
      <h2
        class="text-base font-bold uppercase tracking-wider text-gray-900 border-b border-gray-300 pb-1 mb-2"
      >Projects</h2>
      {{#each @resume.projects as |proj|}}
        <article class="experience">
          <div class="job-header">
            <div class="job-title font-semibold">
              {{proj.title}}
              <span class="job-dates">
                {{#if proj.startDate}}
                  {{#if proj.endDate}}
                    {{format-date proj.startDate "MM.YYYY"}}
                    -
                    {{format-date proj.endDate "MM.YYYY"}}
                  {{else}}
                    {{format-date proj.startDate "MM.YYYY"}}
                  {{/if}}
                {{else}}
                  {{#if proj.endDate}}
                    {{format-date proj.endDate "MM.YYYY"}}
                  {{/if}}
                {{/if}}
              </span>
            </div>
          </div>

          <ul class="desc-list list-disc ml-5">
            {{#each proj.descriptions as |desc|}}
              <li class="desc-item">{{desc.content}}</li>
            {{/each}}
          </ul>
        </article>
      {{/each}}
    </section>
  {{/if}}

  {{#if @resume.certifications.length}}
    <section>
      <h2
        class="text-base font-bold uppercase tracking-wider text-gray-900 border-b border-gray-300 pb-1 mb-2"
      >Certifications</h2>
      {{#each @resume.certifications as |certification|}}
        <Certifications::Item @certification={{certification}} />
      {{/each}}

    </section>
  {{/if}}

  {{#if @resume.educations.length}}
    <section>
      <h2
        class="text-base font-bold uppercase tracking-wider text-gray-900 border-b border-gray-300 pb-1 mb-2"
      >Education</h2>
      {{#each @resume.educations as |education|}}
        <Educations::Item @education={{education}} />
      {{/each}}
    </section>
  {{/if}}

  {{yield}}
</div>