<tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
  <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100">
    <LinkTo @route="resumes.show" @model={{@resume}}>
      {{@resume.name}}
    </LinkTo>
  </td>
  <td class="px-4 py-3 text-center text-gray-600 dark:text-gray-400">
    {{@resume.jobApplications.length}}
  </td>
  <td class="px-4 py-3 text-gray-600 dark:text-gray-400 truncate max-w-xs">
    {{or @resume.notes "—"}}
  </td>
  <td class="px-4 py-3 text-right">
    <div class="flex items-center justify-end gap-2">
      <Buttons::Favorite
        @model={{@resume}}
        @onToggle={{fn @onToggleFavorite @resume}}
      />
      <LinkTo
        @route="resumes.edit"
        @model={{@resume}}
        class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-600"
      >Edit</LinkTo>
      <button
        type="button"
        class="px-2 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50 dark:border-red-800 dark:text-red-400 dark:hover:bg-red-900/30"
        {{on "click" (fn @onDelete @resume)}}
      >Delete</button>
    </div>
  </td>
</tr>