<article class="panel-card">
  <h3>
    <LinkTo @route="resumes.show" @model={{@resume}}>
      {{@resume.name}}
    </LinkTo>
  </h3>

  <p>
    Used in
    {{@resume.jobApplications.length}}
    job applications
  </p>
  <p>
    Note:
    {{or @resume.notes "N/A"}}
  </p>
  <LinkTo @route="resumes.edit" @model={{@resume}} class="btn">Edit</LinkTo>
  <button
    type="button"
    class="btn danger"
    {{on "click" this.deleteResume}}
  >Delete</button>
  <Buttons::Favorite @model={{@resume}} @onToggle={{fn this.toggleFavorite @resume}} />
</article>
{{yield}}
