<div class="w-full overflow-x-auto py-2">
  <ol class="flex min-w-max items-start">
    {{#each this.steps as |step|}}
      <li class="flex flex-1 flex-col items-center">
        {{! Top row: optional left line + circle + optional right line }}
        <div class="flex w-full items-center">
          {{! Left line segment }}
          {{#if step.isFirst}}
            <div class="flex-1"></div>
          {{else}}
            <div
              class="h-0.5 flex-1 rounded-full
                {{if
                  step.lineBeforeDone
                  'bg-accent-500 dark:bg-accent-400'
                  'bg-gray-200 dark:bg-gray-600'
                }}"
            ></div>
          {{/if}}

          {{! Circle }}
          {{#if (eq step.state "done")}}
            <span
              class="flex size-7 shrink-0 items-center justify-center rounded-full bg-accent-500 text-white dark:bg-accent-400"
            >
              <svg
                class="size-3.5"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.5 12.75l6 6 9-13.5"
                />
              </svg>
            </span>
          {{else if (eq step.state "active")}}
            <span
              class="flex size-7 shrink-0 items-center justify-center rounded-full bg-accent-600 text-[10px] font-bold text-white ring-2 ring-accent-300 ring-offset-1 dark:bg-accent-500 dark:ring-accent-400"
            >{{step.number}}</span>
          {{else if (eq step.state "failed")}}
            <span
              class="flex size-7 shrink-0 items-center justify-center rounded-full bg-red-500 text-white ring-2 ring-red-300 ring-offset-1 dark:bg-red-400 dark:ring-red-300"
            >
              <svg
                class="size-3.5"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="3"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
            </span>
          {{else}}
            <span
              class="flex size-7 shrink-0 items-center justify-center rounded-full bg-gray-100 text-[10px] font-bold text-gray-400 dark:bg-gray-700 dark:text-gray-500"
            >{{step.number}}</span>
          {{/if}}

          {{! Right line segment }}
          {{#if step.isLast}}
            <div class="flex-1"></div>
          {{else}}
            <div
              class="h-0.5 flex-1 rounded-full
                {{if
                  step.lineAfterDone
                  'bg-accent-500 dark:bg-accent-400'
                  'bg-gray-200 dark:bg-gray-600'
                }}"
            ></div>
          {{/if}}
        </div>

        {{! Label }}
        <span
          class="mt-1.5 max-w-16 text-center text-[11px] leading-tight
            {{if
              (eq step.state 'done')
              'text-accent-600 dark:text-accent-400'
              (if
                (eq step.state 'active')
                'font-semibold text-accent-700 dark:text-accent-300'
                (if
                  (eq step.state 'failed')
                  'font-semibold text-red-600 dark:text-red-400'
                  'text-gray-400 dark:text-gray-500'
                )
              )
            }}"
        >{{step.label}}</span>
      </li>
    {{/each}}
  </ol>
</div>