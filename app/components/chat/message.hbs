{{! template-lint-disable no-invalid-interactive }}
<div
  class="flex {{if (eq @message.role 'user') 'justify-end' 'justify-start'}}"
  {{on "click" this.handleClick}}
>
  <div
    class="max-w-[85%] rounded-lg px-3 py-2 text-sm
      {{if
        (eq @message.role 'user')
        'bg-accent-600 text-white'
        'bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200'
      }}"
  >
    {{#if (eq @message.role "assistant")}}
      {{#if this.showToolCalls}}
        <div
          class="flex flex-col gap-1 mb-2 pb-2 border-b border-gray-200 dark:border-gray-600"
          data-test-tool-calls
        >
          {{#each this.toolCalls as |call|}}
            <div
              class="flex items-center gap-2 text-xs font-mono"
              data-test-tool-call={{call.name}}
            >
              {{#if (eq call.status "done")}}
                <span class="text-emerald-600 dark:text-emerald-400">✓</span>
              {{else}}
                <span
                  class="inline-block size-2 rounded-full bg-accent-400 animate-pulse"
                ></span>
              {{/if}}
              <span
                class="text-gray-700 dark:text-gray-300 font-semibold"
              >{{call.name}}</span>
            </div>
          {{/each}}
        </div>
      {{/if}}
      <div class="chat-markdown break-words">
        <MarkdownToHtml @markdown={{this.displayContent}} />
      </div>
      {{#if this.elicitation}}
        <div
          class="flex flex-wrap gap-2 mt-3 pt-2 border-t border-gray-200 dark:border-gray-600"
        >
          {{#each this.elicitation.actions as |act|}}
            <button
              type="button"
              class="px-3 py-1.5 text-xs font-medium rounded-md bg-accent-100 dark:bg-accent-900 text-accent-700 dark:text-accent-200 hover:bg-accent-200 dark:hover:bg-accent-800 transition-colors"
              {{on "click" (fn this.runAction act)}}
            >
              {{act.label}}
            </button>
          {{/each}}
        </div>
      {{/if}}
    {{else}}
      <div class="whitespace-pre-wrap break-words">{{@message.content}}</div>
    {{/if}}
  </div>
</div>