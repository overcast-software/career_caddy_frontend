<span
  class="inline-flex items-center gap-1.5 rounded-full border border-accent-200 bg-accent-50 px-3 py-1 text-xs text-accent-700 dark:border-accent-800 dark:bg-accent-900/40 dark:text-accent-300"
>
  {{#if @prefix}}<span
      class="text-accent-500/70 dark:text-accent-400/70"
    >{{@prefix}}</span>{{/if}}<span>{{@label}}</span>
  {{#if @onClear}}
    <button
      type="button"
      class="-mr-1 inline-flex size-4 items-center justify-center rounded-full text-accent-500 hover:bg-accent-100 hover:text-accent-900 dark:text-accent-400 dark:hover:bg-accent-800 dark:hover:text-accent-100"
      aria-label={{or @clearAriaLabel "Clear filter"}}
      {{on "click" @onClear}}
    >×</button>
  {{/if}}
</span>