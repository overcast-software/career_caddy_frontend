<div
  class="panel-card
    {{if @collapsible 'collapsible'}}
    {{if this.collapsed 'collapsed'}}
    {{if @sandtrap 'sandtrap'}}"
>
  <div class="collapsible-head">
    <div class="panel-title">{{@title}}</div>
    {{#if (has-block "top")}}
      <div class="panel-actions">
        {{yield
          (hash collapsed=this.collapsed toggleCollapsed=this.toggleCollapsed)
          to="top"
        }}
      </div>
    {{else if @collapsible}}
      <button type="button" class="panel-caret-btn" {{on "click" this.toggleCollapsed}}>
        <span class="panel-caret {{if this.collapsed 'rotated'}}">▾</span>
      </button>
    {{/if}}
  </div>

  {{#if @collapsible}}
    <div class="collapsible-body">
      <div>
        {{yield
          (hash collapsed=this.collapsed toggleCollapsed=this.toggleCollapsed)
        }}
      </div>
    </div>
  {{else}}
    {{yield
      (hash collapsed=this.collapsed toggleCollapsed=this.toggleCollapsed)
    }}
  {{/if}}
</div>