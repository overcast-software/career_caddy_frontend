<div class="rounded border border-gray-200 bg-white">
  <div class="flow-root p-4">
    <dl class="stagger-rows -my-3 divide-y divide-gray-200 text-sm">
      <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
        <dt class="font-medium text-gray-900">Job Post</dt>
        <dd class="text-gray-700 sm:col-span-2">
          <LinkTo
            @route="job-posts.show"
            @model={{@score.jobPost}}
            class="text-blue-600 hover:underline"
          >{{@score.jobPost.title}}</LinkTo>
        </dd>
      </div>

      <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
        <dt class="font-medium text-gray-900">Company</dt>
        <dd class="text-gray-700 sm:col-span-2">
          <LinkTo
            @route="companies.show"
            @model={{@score.jobPost.company}}
            class="text-blue-600 hover:underline"
          >{{@score.jobPost.company.name}}</LinkTo>
        </dd>
      </div>

      <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
        <dt class="font-medium text-gray-900">Resume</dt>
        <dd class="text-gray-700 sm:col-span-2">
          {{#if @score.resume.id}}
            <LinkTo
              @route="resumes.show"
              @model={{@score.resume}}
              class="text-blue-600 hover:underline"
            >{{@score.resume.name}}</LinkTo>
          {{else}}
            <LinkTo
              @route="career-data"
              class="italic text-gray-400 hover:underline"
            >Career Data</LinkTo>
          {{/if}}
        </dd>
      </div>

      <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
        <dt class="font-medium text-gray-900">Score</dt>
        <dd class="text-gray-700 sm:col-span-2">
          {{#if @score.score}}
            <span class="font-semibold">{{@score.score}}</span>
          {{else}}
            <span class="italic text-gray-400">Not scored</span>
          {{/if}}
        </dd>
      </div>

      {{#if (eq @score.status "pending")}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Status</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <span
              class="inline-flex items-center rounded-full bg-yellow-50 px-2 py-0.5 text-xs font-medium text-yellow-700 ring-1 ring-inset ring-yellow-600/20"
            >Pending</span>
          </dd>
        </div>
      {{else if (eq @score.status "failed")}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Status</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <span
              class="inline-flex items-center rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20"
            >Failed</span>
          </dd>
        </div>
      {{/if}}

      {{#if @score.createdAt}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Created</dt>
          <dd class="text-gray-700 sm:col-span-2">{{format-date
              @score.createdAt
            }}</dd>
        </div>
      {{/if}}

      {{#if @score.explanation}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Explanation</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <MarkdownToHtml @markdown={{@score.explanation}} />
          </dd>
        </div>
      {{/if}}
      {{#if @onDelete}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900"></dt>
          <dd class="sm:col-span-2 text-right">
            <button
              type="button"
              class="px-2 py-1 text-xs rounded border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/30"
              {{on "click" @onDelete}}
            >Delete Score</button>
          </dd>
        </div>
      {{/if}}
    </dl>
  </div>
</div>