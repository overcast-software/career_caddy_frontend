{{yield}}
<h2>
  Job post:
  <LinkTo
    @route="job-posts.show"
    @model={{@score.jobPost}}
  >{{@score.jobPost.title}}</LinkTo>
</h2>
<h2>
  At
  <LinkTo
    @route="companies.show"
    @model={{@score.jobPost.company}}
  >{{@score.jobPost.company.name}}</LinkTo>
</h2>
<h2>
  Resume scored:
  {{#if @score.resume.id}}
    <LinkTo
      @route="resumes.show"
      @model={{@score.resume}}
    >{{@score.resume.name}}</LinkTo>
  {{else}}
    <LinkTo @route="career-data" class="italic">Career Data</LinkTo>
  {{/if}}
</h2>
<h2>
  score:
  {{@score.score}}
</h2>
<MarkdownToHtml @markdown={{@score.explanation}} />