{{! Surfaces JobPost.apply_url + apply_url_status. Status drives chip
    color; a "resolved" status also renders the external link. The
    resolver is best-effort — chip stays absent for unknown to keep the
    header tidy. }}
{{#if (eq @jobPost.applyUrlStatus "resolved")}}
  <a
    href={{@jobPost.applyUrl}}
    target="_blank"
    rel="noopener noreferrer"
    title="Apply at {{@jobPost.applyUrl}}"
    class="mt-1 inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20 hover:bg-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-300 dark:ring-emerald-500/30"
  >
    Apply →
  </a>
{{else if (eq @jobPost.applyUrlStatus "internal")}}
  <span
    title="This posting uses an internal apply flow (e.g. LinkedIn Easy Apply)."
    class="mt-1 inline-flex items-center gap-1 rounded-full bg-sky-50 px-2.5 py-0.5 text-xs font-medium text-sky-700 ring-1 ring-inset ring-sky-600/20 dark:bg-sky-500/10 dark:text-sky-300 dark:ring-sky-500/30"
  >
    Internal apply
  </span>
{{else if (eq @jobPost.applyUrlStatus "stale")}}
  <span
    title="The apply destination previously resolved but is now returning an error. Re-scrape to refresh."
    class="mt-1 inline-flex items-center gap-1 rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-medium text-amber-700 ring-1 ring-inset ring-amber-600/20 dark:bg-amber-500/10 dark:text-amber-300 dark:ring-amber-500/30"
  >
    Apply link stale
  </span>
{{else if (eq @jobPost.applyUrlStatus "failed")}}
  <span
    title="The resolver couldn't determine an apply destination from this posting."
    class="mt-1 inline-flex items-center gap-1 rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-medium text-zinc-600 ring-1 ring-inset ring-zinc-500/20 dark:bg-zinc-500/10 dark:text-zinc-400 dark:ring-zinc-500/30"
  >
    Apply unresolved
  </span>
{{/if}}