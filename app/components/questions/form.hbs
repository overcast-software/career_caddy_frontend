<article class="panel-card">
  <h3 class="form-title">{{if
      this.isEditing
      "Edit Question"
      "Add Interview Question"
    }}</h3>
  <p class="form-hint">Capture questions from an application so AI can help
    draft answers.</p>
  <form class="questions-form builder-form two-col" {{on "submit" this.save}}>

    <div class="field">
      <label class="field-label">Company
        <span class="required">*</span></label>
      {{#if this.hasLockedContext}}
        <input
          type="text"
          value={{this.selectedCompany.name}}
          disabled="true"
          aria-label="Company"
        />
      {{else}}
        <PowerSelectWithCreate
          @search={{this.searchCompanies}}
          @placeholder="Search or create a company…"
          @onCreate={{this.addCompanyToQuestion}}
          @onChange={{this.updateCompany}}
          @selected={{this.selectedCompany}}
          as |company|
        >
          {{company.name}}
        </PowerSelectWithCreate>
      {{/if}}
    </div>

    {{#if this.isLoadingRelated}}
      <p class="loading-hint">Loading job posts and applications…</p>
    {{/if}}

    <div class="field">
      <label class="field-label">Job Post</label>
      {{#if this.hasLockedContext}}
        <input
          type="text"
          value={{this.selectedJobPost.title}}
          disabled="true"
          aria-label="Job Post"
        />
      {{else}}
        <PowerSelect
          @options={{this.loadedJobPosts}}
          @onChange={{this.updateJobPost}}
          @selected={{this.selectedJobPost}}
          @placeholder={{if
            this.selectedCompany
            "Select a job post (optional)"
            "Select a company first"
          }}
          @allowClear={{true}}
          @disabled={{not this.selectedCompany}}
          as |jobPost|
        >
          {{jobPost.title}}
        </PowerSelect>
      {{/if}}
    </div>

    <div class="field">
      <label class="field-label">Job Application</label>
      {{#if this.hasLockedContext}}
        <input
          type="text"
          value={{if
            this.selectedJobAppOption.label
            this.selectedJobAppOption.label
            "None"
          }}
          disabled="true"
          aria-label="Job Application"
        />
      {{else}}
        <PowerSelect
          @options={{this.filteredJobAppOptions}}
          @onChange={{this.updateJobApplication}}
          @selected={{this.selectedJobAppOption}}
          @placeholder={{if
            this.selectedCompany
            "Select an application (optional)"
            "Select a company first"
          }}
          @allowClear={{true}}
          @disabled={{not this.selectedCompany}}
          as |opt|
        >
          {{opt.label}}
        </PowerSelect>
      {{/if}}
    </div>

    <div class="field-full">
      <label class="field-label" for="question-content">Question
        <span class="required">*</span></label>
      <textarea
        id="question-content"
        value={{@question.content}}
        {{on "input" this.updateContent}}
        placeholder="Paste the interview question here…"
        rows="4"
      ></textarea>
    </div>

    {{! Favorite state is derived from whether any answer is favorited
        — see models/question.js. The read-only indicator that used to
        live here made the edit form look like it had a broken button;
        the star now only appears where it means something (list +
        show), not in the editor. }}
    <div class="form-actions">
      <button type="submit" class="btn primary" disabled={{@question.isSaving}}>
        Save
      </button>
      <button type="button" class="btn" {{on "click" this.cancel}}>
        Cancel
      </button>
    </div>
  </form>
</article>