<div
  class="inline-flex items-center gap-1 rounded-full border border-gray-300 bg-white px-1 py-1 text-xs shadow-sm dark:border-gray-600 dark:bg-gray-800"
  {{on-insert this.setup}}
  {{on-render this.refresh @sections}}
>
  <button
    type="button"
    class="inline-flex size-6 items-center justify-center rounded-full text-gray-500 transition hover:bg-accent-50 hover:text-accent-700 disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-gray-500 dark:text-gray-400 dark:hover:bg-accent-900/30 dark:hover:text-accent-300"
    aria-label="Previous section"
    title="Previous section"
    disabled={{not this.hasPrev}}
    {{on "click" this.gotoPrev}}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      class="size-4"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="m4.5 15.75 7.5-7.5 7.5 7.5"
      />
    </svg>
  </button>

  <span
    class="min-w-[7ch] px-2 text-center font-medium text-gray-800 dark:text-gray-100"
    aria-live="polite"
  >{{this.activeTitle}}</span>

  <button
    type="button"
    class="inline-flex size-6 items-center justify-center rounded-full text-gray-500 transition hover:bg-accent-50 hover:text-accent-700 disabled:opacity-30 disabled:hover:bg-transparent disabled:hover:text-gray-500 dark:text-gray-400 dark:hover:bg-accent-900/30 dark:hover:text-accent-300"
    aria-label="Next section"
    title="Next section"
    disabled={{not this.hasNext}}
    {{on "click" this.gotoNext}}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
      class="size-4"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="m19.5 8.25-7.5 7.5-7.5-7.5"
      />
    </svg>
  </button>
</div>