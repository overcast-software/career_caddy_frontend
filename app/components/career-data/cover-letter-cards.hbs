{{#if this.items.length}}
  <div class="space-y-4">
    {{#each this.items as |item|}}
      <article
        id="cl-{{item.id}}"
        class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800"
      >
        <header class="mb-3 border-b border-gray-100 pb-2 dark:border-gray-700">
          <h4 class="text-base font-semibold text-gray-900 dark:text-gray-100">
            {{#if item.company}}{{item.company}}{{else}}Cover Letter{{/if}}
            {{#if item.job}}
              <span class="font-normal text-gray-500 dark:text-gray-400">·
                {{item.job}}</span>
            {{/if}}
          </h4>
          {{#if item.created_at}}
            <p class="text-xs text-gray-400 dark:text-gray-500">
              {{format-date item.created_at "MMM D, YYYY"}}
            </p>
          {{/if}}
        </header>
        <div class="markdown-content text-sm">
          <MarkdownToHtml @markdown={{item.content}} />
        </div>
      </article>
    {{/each}}
  </div>
{{else}}
  <p class="text-sm italic text-gray-500 dark:text-gray-400">
    No favorited cover letters yet — star one on
    <LinkTo @route="cover-letters" class="underline">Cover Letters</LinkTo>
    to pin it here.
  </p>
{{/if}}