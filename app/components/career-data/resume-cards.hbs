{{#if this.items.length}}
  <div class="space-y-4">
    {{#each this.items as |item|}}
      <article
        id="resume-{{item.id}}"
        class="markdown-content rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800"
      >
        <header class="mb-3 border-b border-gray-100 pb-2 dark:border-gray-700">
          <h4
            class="text-lg font-semibold text-gray-900 dark:text-gray-100"
          >{{item.title}}</h4>
          {{#if item.subtitle}}
            <p
              class="text-sm text-gray-500 dark:text-gray-400"
            >{{item.subtitle}}</p>
          {{/if}}
        </header>
        <MarkdownToHtml @markdown={{item.markdown}} />
      </article>
    {{/each}}
  </div>
{{else}}
  <p class="text-sm italic text-gray-500 dark:text-gray-400">
    No favorited resumes yet — star one on
    <LinkTo @route="resumes" class="underline">Resumes</LinkTo>
    to pin it here.
  </p>
{{/if}}