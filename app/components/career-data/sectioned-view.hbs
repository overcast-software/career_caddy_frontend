{{! Structured render from the /career-data sections array. Top-level
    groups (Resumes / Q&A / Cover Letters) are visual headers; sub-cards
    carry the anchor ids so the subnav nav labels each resume /
    question / cover letter individually. }}
<div class="mx-auto max-w-3xl space-y-8 pb-12">
  {{#each this.sections as |group|}}
    <div>
      <h3
        class="mb-3 text-xs font-semibold uppercase tracking-wide text-accent-700 dark:text-accent-300"
      >{{group.title}}</h3>

      {{#if (eq group.type "resumes")}}
        <CareerData::ResumeCards @items={{group.items}} />
      {{else if (eq group.type "qas")}}
        <CareerData::QaCards @items={{group.items}} />
      {{else if (eq group.type "cover_letters")}}
        <CareerData::CoverLetterCards @items={{group.items}} />
      {{/if}}
    </div>
  {{/each}}
</div>