{{! Stacked cards, one per ### heading. The jump nav lives in the subnav
    (see CareerData::AnchorNav) so the page body stays uncluttered and the
    same component can drive anchor navigation on other markdown pages. }}
<div class="mx-auto max-w-3xl space-y-6 pb-12">
  {{#each this.sections as |part|}}
    <section
      id={{part.id}}
      class="markdown-content scroll-mt-24 rounded-xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800"
    >
      <header
        class="mb-4 flex items-baseline justify-between gap-3 border-b border-gray-100 pb-2 dark:border-gray-700"
      >
        <h3
          class="text-sm font-semibold uppercase tracking-wide text-accent-700 dark:text-accent-300"
        >{{part.title}}</h3>
      </header>
      <MarkdownToHtml @markdown={{part.body}} />
    </section>
  {{/each}}
</div>