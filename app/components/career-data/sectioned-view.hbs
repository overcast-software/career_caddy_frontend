<div class="flex gap-6 md:gap-8">
  {{! Side rail — hidden on narrow viewports; sticky so it stays in view
      as the user scrolls. Clicking an entry jumps to the matching card.
      Uses native anchor jumps (#section-id), no JS router required. }}
  <nav
    aria-label="Career data sections"
    class="sticky top-20 hidden w-44 shrink-0 self-start md:block"
  >
    <div class="border-l-2 border-gray-200 pl-4 dark:border-gray-700 space-y-1">
      {{#each this.sections as |part|}}
        <a
          href="#{{part.id}}"
          class="block rounded px-2 py-1 text-xs font-medium text-gray-600 transition hover:bg-accent-50 hover:text-accent-700 dark:text-gray-300 dark:hover:bg-accent-900/30 dark:hover:text-accent-300"
        >
          {{part.title}}
        </a>
      {{/each}}
    </div>
  </nav>

  <div class="min-w-0 flex-1 space-y-4">
    {{#each this.sections as |part|}}
      <section
        id={{part.id}}
        class="markdown-content scroll-mt-24 rounded-lg border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800"
      >
        <h3
          class="mb-3 text-lg font-semibold text-gray-900 dark:text-gray-100"
        >{{part.title}}</h3>
        <MarkdownToHtml @markdown={{part.body}} />
      </section>
    {{/each}}
  </div>
</div>