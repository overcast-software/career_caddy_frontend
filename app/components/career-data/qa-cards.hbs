{{#if this.items.length}}
  <div class="space-y-3">
    {{#each this.items as |item|}}
      <article
        id="qa-{{item.id}}"
        class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800"
      >
        <h4
          class="mb-2 text-sm font-semibold text-gray-900 dark:text-gray-100"
        >{{item.question}}</h4>
        {{#if item.answer}}
          <div class="markdown-content text-sm">
            <MarkdownToHtml @markdown={{item.answer}} />
          </div>
        {{/if}}
      </article>
    {{/each}}
  </div>
{{else}}
  <p class="text-sm italic text-gray-500 dark:text-gray-400">
    No favorited answers yet — star one on
    <LinkTo @route="answers" class="underline">Answers</LinkTo>
    to pin it here.
  </p>
{{/if}}