<tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
  <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100">
    <LinkTo @route="job-applications.show" @model={{@jobApplication.id}}>
      {{this.jobPost.title}}
    </LinkTo>
  </td>
  <td class="px-4 py-3 text-gray-600 dark:text-gray-300">{{this.jobPost.company.name}}</td>
  <td class="px-4 py-3 text-gray-600 dark:text-gray-300">{{@jobApplication.status}}</td>
  <td class="px-4 py-3 text-gray-600 dark:text-gray-300">
    {{#if @jobApplication.appliedAt}}
      {{moment-format @jobApplication.appliedAt "MMM D, YYYY"}}
    {{else}}
      <span class="text-gray-400 dark:text-gray-600">—</span>
    {{/if}}
  </td>
  <td class="px-4 py-3 text-right">
    <div class="flex items-center justify-end gap-2">
      <LinkTo
        @route="job-applications.show"
        @model={{@jobApplication.id}}
        class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
      >View</LinkTo>
      <LinkTo
        @route="job-applications.edit"
        @model={{@jobApplication.id}}
        class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-700"
      >Edit</LinkTo>
      <button
        type="button"
        class="px-2 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50 dark:border-red-800 dark:text-red-400 dark:hover:bg-red-900/30"
        {{on "click" this.delete}}
      >Delete</button>
    </div>
  </td>
</tr>
