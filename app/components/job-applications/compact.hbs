<tr class="hover:bg-gray-50">
  <td class="px-4 py-3 font-medium text-gray-900">
    <LinkTo @route="job-applications.show" @model={{@jobApplication.id}}>
      {{this.jobPost.title}}
    </LinkTo>
  </td>
  <td class="px-4 py-3 text-gray-600">{{this.jobPost.company.name}}</td>
  <td class="px-4 py-3 text-gray-600">{{@jobApplication.status}}</td>
  <td class="px-4 py-3 text-gray-600">
    {{moment-format @jobApplication.appliedAt "MMM D, YYYY"}}
  </td>
  <td class="px-4 py-3 text-right">
    <div class="flex items-center justify-end gap-2">
      <LinkTo
        @route="job-applications.show"
        @model={{@jobApplication.id}}
        class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
      >View</LinkTo>
      <LinkTo
        @route="job-applications.edit"
        @model={{@jobApplication.id}}
        class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
      >Edit</LinkTo>
      <button
        type="button"
        class="px-2 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50"
        {{on "click" this.delete}}
      >Delete</button>
    </div>
  </td>
</tr>
