<div class="w-full overflow-x-auto">
  <svg
    viewBox={{this.viewBox}}
    xmlns="http://www.w3.org/2000/svg"
    style={{this.svgStyle}}
    role="img"
    aria-label="Job application status flow"
  >
    {{! ── Main track ──────────────────────────────────────────── }}
    {{#each this.mainLineSegments as |seg|}}
      <line
        x1={{seg.x1}}
        y1={{seg.y}}
        x2={{seg.x2}}
        y2={{seg.y}}
        stroke={{seg.stroke}}
        stroke-width="2"
      />
    {{/each}}

    {{! ── VB branch: vertical drop from Vetted Good ───────────── }}
    <line
      x1={{this.vbBranchLine.x}}
      y1={{this.vbBranchLine.y1}}
      x2={{this.vbBranchLine.x}}
      y2={{this.vbBranchLine.y2}}
      stroke={{this.vbBranchLine.stroke}}
      stroke-width="2"
    />

    {{! ── Declined branch: short drop from Offer ──────────────── }}
    <line
      x1={{this.decBranchLine.x}}
      y1={{this.decBranchLine.y1}}
      x2={{this.decBranchLine.x}}
      y2={{this.decBranchLine.y2}}
      stroke={{this.decBranchLine.stroke}}
      stroke-width="2"
    />

    {{! ── Rejection entries: Contact / Interviewed / TT / AD → rail }}
    {{#each this.rejectionEntries as |entry|}}
      <line
        x1={{entry.x}}
        y1={{entry.y1}}
        x2={{entry.x}}
        y2={{entry.y2}}
        stroke={{entry.stroke}}
        stroke-width="2"
      />
    {{/each}}

    {{! ── No-go rail horizontal ───────────────────────────────── }}
    {{#each this.nogoRailSegments as |seg|}}
      <line
        x1={{seg.x1}}
        y1={{seg.y}}
        x2={{seg.x2}}
        y2={{seg.y}}
        stroke={{seg.stroke}}
        stroke-width="2"
      />
    {{/each}}

    {{! ── Main track nodes ────────────────────────────────────── }}
    {{#each this.mainNodes as |node|}}
      <g>
        <title>{{node.label}}</title>
        {{#if node.isActive}}
          <circle
            cx={{node.x}}
            cy={{node.y}}
            r="13"
            fill="white"
            stroke={{node.fill}}
            stroke-width="2.5"
          />
        {{/if}}
        <circle cx={{node.x}} cy={{node.y}} r="8" fill={{node.fill}} />
        <g transform={{node.labelTransform}}>
          <text
            x="2"
            y="0"
            font-size="10"
            fill={{node.textFill}}
            font-weight={{node.fontWeight}}
          >{{node.label}}</text>
        </g>
      </g>
    {{/each}}

    {{! ── Vetted Bad node ─────────────────────────────────────── }}
    <g>
      <title>Vetted Bad</title>
      {{#if this.vbNode.isActive}}
        <circle
          cx={{this.vbNode.x}}
          cy={{this.vbNode.y}}
          r="13"
          fill="white"
          stroke="#dc2626"
          stroke-width="2.5"
        />
      {{/if}}
      <circle
        cx={{this.vbNode.x}}
        cy={{this.vbNode.y}}
        r="8"
        fill={{this.vbNode.fill}}
      />
      <text
        x={{this.vbNode.x}}
        y={{this.vbNode.labelY}}
        text-anchor="middle"
        font-size="10"
        fill={{this.vbNode.textFill}}
        font-weight={{this.vbNode.fontWeight}}
      >Vetted Bad</text>
    </g>

    {{! ── Declined node ───────────────────────────────────────── }}
    <g>
      <title>Declined</title>
      {{#if this.decNode.isActive}}
        <circle
          cx={{this.decNode.x}}
          cy={{this.decNode.y}}
          r="13"
          fill="white"
          stroke="#dc2626"
          stroke-width="2.5"
        />
      {{/if}}
      <circle
        cx={{this.decNode.x}}
        cy={{this.decNode.y}}
        r="8"
        fill={{this.decNode.fill}}
      />
      <text
        x={{this.decNode.x}}
        y={{this.decNode.labelY}}
        text-anchor="middle"
        font-size="10"
        fill={{this.decNode.textFill}}
        font-weight={{this.decNode.fontWeight}}
      >Declined</text>
    </g>

    {{! ── Rail nodes: Rejected, Expired, Archived ─────────────── }}
    {{#each this.railNodes as |node|}}
      <g>
        <title>{{node.label}}</title>
        {{#if node.isActive}}
          <circle
            cx={{node.x}}
            cy={{node.y}}
            r="13"
            fill="white"
            stroke="#dc2626"
            stroke-width="2.5"
          />
        {{/if}}
        <circle cx={{node.x}} cy={{node.y}} r="8" fill={{node.fill}} />
        <text
          x={{node.x}}
          y={{node.labelY}}
          text-anchor="middle"
          font-size="10"
          fill={{node.textFill}}
          font-weight={{node.fontWeight}}
        >{{node.label}}</text>
      </g>
    {{/each}}
  </svg>
</div>