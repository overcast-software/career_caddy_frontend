<div class="space-y-4">
  <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Status History</h3>

  {{#if this.sortedStatuses.length}}
    <ol class="relative ml-3 border-l border-gray-200 space-y-4 pb-1">
      {{#each this.sortedStatuses as |entry|}}
        <li class="relative ml-5">
          {{! dot sits on the border line }}
          <div class="absolute -left-[1.625rem] top-1 h-3 w-3 rounded-full ring-2 ring-white {{entry.dotClass}}"></div>

          <div class="flex items-start justify-between gap-2">
            <div class="flex flex-wrap items-baseline gap-x-2">
              <span class="text-sm {{if entry.isCurrent 'font-semibold text-gray-900' 'font-medium text-gray-600'}}">
                {{entry.status}}
              </span>
              {{#if entry.displayDate}}
                <span class="text-xs text-gray-400">
                  {{format-date entry.displayDate "MMM D, YYYY"}}
                </span>
              {{/if}}
            </div>

            {{! Action buttons — always visible but muted; ⋮ turns blue when open }}
            <div class="flex items-center gap-1 shrink-0 mt-0.5">
              <button
                type="button"
                title="Adjust date"
                class="transition-colors {{if (eq this.expandedId entry.record.id) 'text-blue-500' 'text-gray-300 hover:text-gray-500'}}"
                {{on "click" (fn this.toggleExpand entry.record)}}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z" />
                </svg>
              </button>
              <button
                type="button"
                title="Remove this entry"
                class="text-gray-300 hover:text-red-500 transition-colors"
                {{on "click" (fn this.deleteEntry entry.record)}}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>
          </div>

          {{! Inline date editor — expands when this entry's ⋮ is active }}
          {{#if (eq this.expandedId entry.record.id)}}
            <div class="mt-2 flex flex-wrap items-center gap-2">
              <input
                type="datetime-local"
                class="text-xs border border-gray-300 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-400"
                value={{this.editingDate}}
                {{on "change" this.updateEditingDate}}
              />
              <button
                type="button"
                class="btn small"
                {{on "click" (fn this.saveDate entry.record)}}
              >Save</button>
              <button
                type="button"
                class="text-xs text-gray-500 hover:text-gray-700"
                {{on "click" this.cancelEdit}}
              >Cancel</button>
            </div>
          {{/if}}
        </li>
      {{/each}}
    </ol>
  {{else}}
    <p class="text-sm italic text-gray-400">No history yet — log the first status below.</p>
  {{/if}}

  <div class="border-t border-gray-100 pt-4 space-y-2">
    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">Log status</p>
    <div class="space-y-2">
      <div class="flex gap-2 items-start">
        <div class="flex-1">
          <PowerSelect
            @options={{this.statusOptions}}
            @onChange={{this.selectStatus}}
            @selected={{this.selectedStatus}}
            @placeholder="Select next status…"
            as |status|
          >
            {{status}}
          </PowerSelect>
        </div>
        <button
          type="button"
          class="btn shrink-0"
          disabled={{this.cannotSubmit}}
          {{on "click" this.logStatus}}
        >
          {{if this.isSaving "Saving…" "Log"}}
        </button>
      </div>

      {{#if this.impliedStatuses.length}}
        <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-2.5 py-1.5">
          Will also log: <span class="font-medium">{{this.willLogPreview}}</span>
        </p>
      {{/if}}
    </div>
  </div>
</div>
