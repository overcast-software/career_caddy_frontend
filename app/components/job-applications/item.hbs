<Panel::Card>
  <div class="builder-form">
    <div class="field">
      <h1>{{@jobApplication.jobPost.title}}</h1>
    </div>

    <section class="job-post-description">
      <div class="field">
        <div class="field-label">Resume:</div>
        {{#if @jobApplication.resume}}
          {{@jobApplication.resume.name}}
        {{else}}
          -
        {{/if}}
      </div>
    </section>

    <section>
      <div class="field">
        <div class="field-label">Cover Letter</div>
        {{#if @jobApplication.coverLetter}}
          {{@jobApplication.coverLetter.createdAt}}
        {{else}}
          no cover letter recorded
        {{/if}}
      </div>
    </section>

    <section>
      <div class="field">
        <div class="field-label">Applied At</div>
        {{format-date @jobApplication.appliedAt}}
      </div>

    </section>
    <div class="field">
      <div class="field-label">Status</div>
      {{#if @jobApplication.status}}
        <span class={{job-application-status-class @jobApplication.status}}>
          {{@jobApplication.status}}
        </span>
      {{else}}
        <span class="text-gray-400 dark:text-gray-600">—</span>
      {{/if}}
    </div>

    <div class="field">
      <div class="field-label">Tracking URL</div>
      {{#if @jobApplication.trackingUrl}}
        <a
          href={{@jobApplication.trackingUrl}}
          target="_blank"
          rel="noopener noreferrer"
        >{{@jobApplication.trackingUrl}}</a>
      {{else}}
        -
      {{/if}}
    </div>

    <div class="field">
      <div class="field-label">Notes</div>
      {{@jobApplication.notes}}
    </div>

    <div class="form-actions">
      {{yield}}
    </div>
  </div>
</Panel::Card>