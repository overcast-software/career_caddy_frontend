<div
  class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700"
>
  <h3 class="mb-2 text-sm font-semibold text-gray-700 dark:text-gray-200">Status
    events over time</h3>
  <div
    class="mb-3 flex flex-wrap gap-3 text-xs text-gray-600 dark:text-gray-300"
  >
    {{#each this.legendEntries as |entry|}}
      <span class="inline-flex items-center gap-1">
        <span
          class="inline-block h-3 w-3 rounded-sm"
          style={{entry.swatchStyle}}
        ></span>
        {{entry.label}}
      </span>
    {{/each}}
  </div>
  <svg
    class="activity-stacked block w-full h-auto"
    role="img"
    aria-label="Status events over time"
    {{on-render this.draw @series}}
  ></svg>
</div>