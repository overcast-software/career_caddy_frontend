<div
  class="mb-4 flex flex-wrap items-center gap-3 rounded-lg border border-gray-200 bg-white p-3 dark:border-gray-700"
  {{on-insert this.loadOptions}}
>
  <label
    class="flex items-center gap-1 text-xs text-gray-600 dark:text-gray-300"
  >
    <span class="font-medium">Source</span>
    <select
      class="rounded border border-gray-300 px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-800"
      {{on "change" this.setSource}}
    >
      <option value="" selected={{not this.filters.source}}>All sources</option>
      {{#each this.options.sources as |s|}}
        <option value={{s}} selected={{eq this.filters.source s}}>{{s}}</option>
      {{/each}}
    </select>
  </label>

  <div class="flex items-center gap-1 text-xs text-gray-600 dark:text-gray-300">
    <span class="font-medium">Window</span>
    <div
      class="inline-flex rounded border border-gray-300 dark:border-gray-600 overflow-hidden"
    >
      {{#each this.presets as |p|}}
        <button
          type="button"
          class="px-2 py-1 text-xs
            {{if
              (eq this.activePresetKey p.key)
              'bg-accent-500 text-white'
              'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800'
            }}"
          {{on "click" (fn this.setPreset p)}}
        >{{p.label}}</button>
      {{/each}}
      <button
        type="button"
        class="px-2 py-1 text-xs
          {{if
            (eq this.activePresetKey 'custom')
            'bg-accent-500 text-white'
            'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-800'
          }}"
        {{on "click" (fn this.setPreset (hash key="custom"))}}
      >Custom</button>
    </div>
    {{#if (or (eq this.activePresetKey "custom") this.customOpen)}}
      <input
        type="date"
        aria-label="From date"
        class="rounded border border-gray-300 px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-800"
        value={{this.filters.from}}
        {{on "change" this.setFrom}}
      />
      <span class="text-gray-400">–</span>
      <input
        type="date"
        aria-label="To date"
        class="rounded border border-gray-300 px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-800"
        value={{this.filters.to}}
        {{on "change" this.setTo}}
      />
    {{/if}}
  </div>

  {{#if this.showPersonFilter}}
    <label
      class="flex items-center gap-1 text-xs text-gray-600 dark:text-gray-300"
    >
      <span class="font-medium">Person</span>
      <select
        class="rounded border border-gray-300 px-2 py-1 text-xs dark:border-gray-600 dark:bg-gray-800"
        {{on "change" this.setUser}}
      >
        <option value="" selected={{not this.filters.user}}>All users</option>
        {{#each this.options.users as |u|}}
          <option
            value={{u.id}}
            selected={{eq this.filters.user u.id}}
          >{{u.display}}</option>
        {{/each}}
      </select>
    </label>
  {{/if}}
</div>