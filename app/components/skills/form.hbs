<form class="builder-form">

  <div class="skill-groups">
    {{#each-in this.groupedSkillsMap as |group skills|}}
      <div class="skill-group">
        <div class="group-title">{{group}}</div>
        <div class="tags">
          {{#each skills as |skill|}}
            <div class="skill-tag">
              <button
                type="button"
                class="tag-remove"
                {{on "click" (fn this.removeSkill skill)}}
              >x</button>
              <span class="tag-text">{{skill.text}}</span>
            </div>
          {{/each}}
        </div>
      </div>
    {{/each-in}}
  </div>

  <div class="field-row">
    <label class="field">
      <span class="field-label">Skill</span>
      <input
        type="text"
        placeholder="e.g., JavaScript"
        value={{this.newSkillText}}
        {{on "input" this.updateNewSkillText}}
      />
    </label>
    <label class="field">
      <span class="field-label">Type</span>
      <input
        type="text"
        placeholder="e.g., Languages, Tools"
        value={{this.newSkillType}}
        {{on "input" this.updateNewSkillType}}
      />
    </label>
  </div>

  <button
    type="button"
    class="btn primary"
    disabled={{eq this.newSkillText.length 0}}
    {{on "click" this.addSkill}}
  >Add Skill</button>

</form>