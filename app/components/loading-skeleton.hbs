{{! Generic list-style loading skeleton used by every parent path's
    *-loading.hbs template. Eight animated-pulse cards matches the
    perceived page weight of a typical index route without pretending
    to preview the exact row shape. }}
<div class="space-y-3">
  {{#each (array 1 2 3 4 5 6 7 8)}}
    <div
      class="animate-pulse rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900"
    >
      <div class="h-4 w-1/3 rounded bg-gray-200 dark:bg-gray-700"></div>
      <div class="mt-2 h-3 w-1/2 rounded bg-gray-100 dark:bg-gray-800"></div>
      <div class="mt-3 h-3 w-full rounded bg-gray-100 dark:bg-gray-800"></div>
    </div>
  {{/each}}
</div>