<button
  type="button"
  class="mobile-overlay {{if this.sidebarOpen 'mobile-overlay--visible'}}"
  aria-label="Close menu"
  {{on "click" this.close}}
></button>
<div class="mobile-drawer {{if this.sidebarOpen 'mobile-drawer--open'}}">
  <Sidebar @onClose={{this.close}} />
</div>

<div
  class="course
    {{if this.sidebarOpen 'course--sidebar-open'}}
    {{if this.chat.sidebarOpen 'course--chat-open'}}"
>
  <header class="site-header">
    <TopBar
      @showLoading={{this.showLoading}}
      @onToggle={{this.toggle}}
      @onClose={{this.close}}
    />
  </header>
  {{#if this.spinner.isShowing}}
    <div class="loading-bar" aria-hidden="true"></div>
  {{/if}}
  <div class="course-body">
    <aside class="course-sidebar">
      <Sidebar @onClose={{this.close}} />
    </aside>
    <div class="course-main">
      <div id="subnav-portal"></div>
      {{yield}}
    </div>
    {{#unless this.currentUser.isGuest}}
      <Chat::Sidebar @onOpen={{this.closeSidebarForChat}} />
    {{/unless}}
  </div>
  <footer class="route-footer">
    <span>copyleft 2026</span>
    {{#if this.currentUser.isGuest}}
      <span class="route-footer-guest">Demo mode</span>
    {{else}}
      <a href="https://github.com/overcast-software/career_caddy">Github</a>
    {{/if}}
    <nav>
      {{#unless this.currentUser.isGuest}}
        {{#unless this.chat.sidebarOpen}}
          <button
            type="button"
            class="relative flex items-center gap-1 text-accent-600 hover:text-accent-700 dark:text-accent-400 dark:hover:text-accent-300
              {{if this.chat.hasUnread 'aw-shimmer'}}"
            title={{if
              this.chat.hasUnread
              "Caddy has a new message for you"
              "Open Caddy AI chat"
            }}
            data-test-aw-attention={{if this.chat.hasUnread "true" "false"}}
            {{on "click" this.toggleChat}}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"
              />
            </svg>
            Chat with AI
            {{#if this.chat.hasUnread}}
              <span
                aria-hidden="true"
                class="absolute -top-0.5 -right-0.5 size-2 rounded-full bg-accent-500"
              ></span>
            {{/if}}
          </button>
        {{/unless}}
      {{/unless}}
    </nav>
  </footer>
</div>