<form class="builder-form" {{on "submit" this.save}}>
  <div class="field">
    <button
      type="button"
      class="btn {{if this.useAI 'primary'}}"
      disabled={{this.isPolling}}
      {{on "click" this.toggleAI}}
    >
      {{if this.useAI "✓ Ask AI to answer" "Ask AI to answer"}}
    </button>
  </div>

  {{#if this.isPolling}}
    <div class="field">
      <p><em>AI is generating your answer, please wait…</em></p>
    </div>
  {{else if this.useAI}}
    <div class="field-full">
      <label class="field-label" for="answer-additional-prompt">Additional
        prompt for AI</label>
      <textarea
        id="answer-additional-prompt"
        class="w-full bg-accent-50 text-gray-900 dark:bg-accent-900/20 dark:text-gray-100"
        rows="3"
        placeholder="Add any additional context or instructions for the AI..."
        {{on "input" this.updateAdditionalPrompt}}
      >{{this.additionalPrompt}}</textarea>
    </div>

    {{#if @showQuestion}}
      <div class="field">
        <p><strong>Question:</strong> {{@answer.question.content.content}}</p>
      </div>
    {{/if}}
    <div class="field">
      <p><em>AI will generate an answer based on the question and your
          additional prompt.</em></p>
    </div>
  {{else}}
    <div class="field-full">
      <label class="field-label" for="answer-content">Answer</label>
      <textarea
        id="answer-content"
        rows="12"
        {{on "change" this.updateContent}}
      >{{@answer.content}}</textarea>
    </div>
  {{/if}}

  {{! Action row: favorite star on the left, primary actions on the
      right ending with whatever the caller yields (Delete for the edit
      route, nothing for new). Matches the Questions::Form convention. }}
  <div class="form-actions justify-between items-center">
    <div class="flex items-center gap-2">
      <Buttons::Favorite
        @model={{@answer}}
        @onToggle={{fn this.toggleFavorite @answer}}
      />
    </div>
    <div class="flex items-center gap-2">
      <button
        type="submit"
        class="btn {{if this.isPolling 'primary opacity-60'}}"
        disabled={{this.isPolling}}
      >{{if
          this.isPolling
          "AI Generating…"
          (if this.useAI "Ask AI" "Save")
        }}</button>
      <button
        type="button"
        class="btn"
        {{on "click" this.cancel}}
      >Cancel</button>
      {{yield to="actions"}}
    </div>
  </div>
</form>