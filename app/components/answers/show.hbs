<div class="mt-4 border-t border-gray-100 pt-4">
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-sm font-semibold text-gray-700">Answer</h3>
    <div class="flex gap-2">
      {{yield to="actions"}}
      {{#if @editRoute}}
        <LinkTo
          @route={{@editRoute}}
          @model={{@answer}}
          class="btn small"
        >Edit</LinkTo>
      {{/if}}
    </div>
  </div>
  <div class="panel-card">
    <MarkdownToHtml @markdown={{@answer.content}} />
  </div>
</div>