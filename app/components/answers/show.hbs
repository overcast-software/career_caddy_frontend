<div class="rounded border-2 border-gray-200 bg-white">
  <div class="flow-root p-4">
    <dl class="stagger-rows -my-3 divide-y divide-gray-200 text-sm">
      {{#if this.showQuestion}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Question</dt>
          <dd class="text-gray-700 sm:col-span-2">
            {{#if this.questionId}}
              <LinkTo
                @route="questions.show.answers.show"
                @models={{array this.questionId @answer.id}}
                class="text-blue-600 hover:underline"
              >{{@answer.question.content.content}}</LinkTo>
            {{else}}
              <span class="italic text-gray-400">No question</span>
            {{/if}}
          </dd>
        </div>
      {{/if}}

      <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
        <dt class="font-medium text-gray-900">Answer</dt>
        <dd class="text-gray-700 sm:col-span-2">
          {{#if @answer.content}}
            <MarkdownToHtml @markdown={{@answer.content}} />
          {{else if (eq @answer.status "pending")}}
            <span class="italic text-gray-400">AI is generating…</span>
          {{else}}
            <span class="italic text-gray-400">No content</span>
          {{/if}}
        </dd>
      </div>

      <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
        <dt class="font-medium text-gray-900">Favorite</dt>
        <dd class="text-gray-700 sm:col-span-2">
          {{#if @answer.favorite}}
            <span
              class="inline-flex items-center rounded-full bg-yellow-50 px-2 py-0.5 text-xs font-medium text-yellow-700 ring-1 ring-inset ring-yellow-600/20"
            >Favorited</span>
          {{else}}
            <span
              class="inline-flex items-center rounded-full bg-gray-50 px-2 py-0.5 text-xs font-medium text-gray-500 ring-1 ring-inset ring-gray-300/20"
            >Not favorited</span>
          {{/if}}
        </dd>
      </div>

      {{#if (eq @answer.status "pending")}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Status</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <span
              class="inline-flex items-center rounded-full bg-yellow-50 px-2 py-0.5 text-xs font-medium text-yellow-700 ring-1 ring-inset ring-yellow-600/20"
            >Pending</span>
          </dd>
        </div>
      {{else if (eq @answer.status "failed")}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Status</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <span
              class="inline-flex items-center rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20"
            >Failed</span>
          </dd>
        </div>
      {{/if}}

      {{#if @answer.ai_assist}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Source</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <span
              class="inline-flex items-center rounded-full bg-blue-50 px-2 py-0.5 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20"
            >AI Generated</span>
          </dd>
        </div>
      {{/if}}

      {{#if @answer.createdAt}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Created</dt>
          <dd class="text-gray-700 sm:col-span-2">{{format-date
              @answer.createdAt
            }}</dd>
        </div>
      {{/if}}
    </dl>
  </div>

  <div class="flex items-center gap-2 border-t border-gray-200 px-4 py-3">
    <button
      type="button"
      class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
      {{on "click" this.copyToClipboard}}
    >{{this.copyButtonText}}</button>
    <button
      type="button"
      class="px-2 py-1 text-xs rounded border
        {{if
          @answer.favorite
          'border-yellow-300 bg-yellow-50 text-yellow-700'
          'border-gray-200 text-gray-600 hover:bg-gray-100'
        }}"
      {{on "click" this.toggleFavorite}}
    >{{if @answer.favorite "Favorited" "Favorite"}}</button>
    <LinkTo
      @route={{this.answerShowRoute}}
      @model={{@answer.id}}
      class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
    >View</LinkTo>
    {{yield to="actions"}}
    {{#if @editRoute}}
      <LinkTo
        @route={{@editRoute}}
        @model={{@answer}}
        class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
      >Edit</LinkTo>
    {{/if}}
    <button
      type="button"
      class="px-2 py-1 text-xs rounded border border-red-200 text-red-600 hover:bg-red-50"
      {{on "click" this.deleteAnswer}}
    >Delete</button>
  </div>
</div>