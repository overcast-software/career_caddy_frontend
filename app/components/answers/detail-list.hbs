<div class="space-y-4">
  {{#each @answers as |answer|}}
    {{#if answer.id}}
      <Answers::Show
        @answer={{answer}}
        @editRoute={{@editRoute}}
        @showQuestion={{@showQuestion}}
      >
        <:actions>
          {{#if @showRoute}}
            <LinkTo
              @route={{@showRoute}}
              @model={{answer}}
              class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
            >View</LinkTo>
          {{/if}}
        </:actions>
      </Answers::Show>
    {{/if}}
  {{else}}
    <EmptyState @message={{or @emptyMessage "No answers found."}} />
  {{/each}}
</div>