{{#if @scrapes.length}}
  <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">URL</th>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600"
          >Company</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Job Post</th>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600"
          >Status</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Scraped At</th>
          <th
            class="px-4 py-3 text-right font-semibold text-gray-600"
          >Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each @scrapes as |scrape|}}
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-gray-900 max-w-xs truncate">
              {{#if scrape.url}}
                <a
                  href={{scrape.url}}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:underline"
                >{{scrape.url}}</a>
              {{else}}
                <span class="text-gray-400">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-gray-600">
              {{#if scrape.company.name}}
                <LinkTo @route="companies.show" @model={{scrape.company}}>
                  {{scrape.company.name}}
                </LinkTo>
              {{else}}
                <span class="text-gray-400">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-gray-600">
              {{#if scrape.jobPost.id}}
                <LinkTo @route="job-posts.show" @model={{scrape.jobPost}}>
                  {{scrape.jobPost.title}}
                </LinkTo>
              {{else}}
                <span class="text-gray-400">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3">
              <span
                class="px-2 py-0.5 rounded-full text-xs font-medium
                  {{if
                    (eq scrape.state 'completed')
                    'bg-green-100 text-green-700'
                  }}
                  {{if (eq scrape.state 'done') 'bg-green-100 text-green-700'}}
                  {{if (eq scrape.state 'failed') 'bg-red-100 text-red-700'}}
                  {{if (eq scrape.state 'error') 'bg-red-100 text-red-700'}}
                  {{if
                    (eq scrape.state 'pending')
                    'bg-yellow-100 text-yellow-700'
                  }}
                  {{if (eq scrape.state 'running') 'bg-blue-100 text-blue-700'}}
                  "
              >
                {{or scrape.status "unknown"}}
              </span>
            </td>
            <td class="px-4 py-3 text-gray-600">
              {{#if scrape.scrapedAt}}
                {{moment-format scrape.scrapedAt "MMM D, YYYY h:mm a"}}
              {{else}}
                <span class="text-gray-400">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <LinkTo
                  @route="scrapes.show"
                  @model={{scrape}}
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
                >View</LinkTo>
                <button
                  type="button"
                  class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
                  {{on "click" (fn @onRetry scrape)}}
                >Retry</button>
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <EmptyState @message="No scrapes found." />
{{/if}}