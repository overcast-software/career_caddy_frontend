<div class="panel-card space-y-6">
  <StatusSteps
    @steps={{this.scrapeSteps}}
    @current={{this.normalizedState}}
    @failedStates={{this.failedStates}}
  />

  <div class="flow-root">
    <dl class="-my-3 divide-y divide-gray-200 text-sm">
      {{#if @scrape.url}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">URL</dt>
          <dd class="text-gray-700 sm:col-span-2 break-all">
            <a
              href={{@scrape.url}}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:underline"
            >{{@scrape.url}}</a>
          </dd>
        </div>
      {{/if}}

      {{#if @scrape.company.name}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Company</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <LinkTo @route="companies.show" @model={{@scrape.company}}>
              {{@scrape.company.name}}
            </LinkTo>
          </dd>
        </div>
      {{/if}}

      {{#if @scrape.jobPost.id}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Job Post</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <LinkTo @route="job-posts.show" @model={{@scrape.jobPost}}>
              {{@scrape.jobPost.title}}
            </LinkTo>
          </dd>
        </div>
      {{/if}}

      {{#if @scrape.scrapedAt}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Scraped At</dt>
          <dd class="text-gray-700 sm:col-span-2">
            {{moment-format @scrape.scrapedAt "MMM D, YYYY h:mm a"}}
          </dd>
        </div>
      {{/if}}

      {{#if @scrape.parseMethod}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Parse Method</dt>
          <dd class="text-gray-700 sm:col-span-2">{{@scrape.parseMethod}}</dd>
        </div>
      {{/if}}

      {{#if @scrape.externalLink}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">External Link</dt>
          <dd class="text-gray-700 sm:col-span-2 break-all">
            <a
              href={{@scrape.externalLink}}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:underline"
            >{{@scrape.externalLink}}</a>
          </dd>
        </div>
      {{/if}}

      {{#if @scrape.jobContent}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900 flex items-center gap-2">
            Job Content
            <button
              type="button"
              class="text-xs text-accent-600 hover:text-accent-800 dark:text-accent-400 dark:hover:text-accent-300"
              {{on "click" this.toggleJobContent}}
            >{{if this.jobContentExpanded "Collapse" "Expand"}}</button>
          </dt>
          <dd
            class="text-gray-700 dark:text-gray-300 sm:col-span-2 whitespace-pre-wrap
              {{unless this.jobContentExpanded 'line-clamp-4 overflow-hidden'}}"
          >
            {{@scrape.jobContent}}
          </dd>
        </div>
      {{/if}}

      {{#if @scrape.sourceScrape.id}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Source Scrape</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <LinkTo @route="scrapes.show" @model={{@scrape.sourceScrape}}>
              {{or
                @scrape.sourceScrape.url
                (concat "Scrape #" @scrape.sourceScrape.id)
              }}
            </LinkTo>
          </dd>
        </div>
      {{/if}}

      {{#if @scrape.scrapes.length}}
        <div class="grid grid-cols-1 gap-1 py-3 sm:grid-cols-3 sm:gap-4">
          <dt class="font-medium text-gray-900">Child Scrapes</dt>
          <dd class="text-gray-700 sm:col-span-2">
            <ul class="space-y-1">
              {{#each @scrape.scrapes as |child|}}
                <li>
                  <LinkTo @route="scrapes.show" @model={{child}}>
                    {{or child.url (concat "Scrape #" child.id)}}
                  </LinkTo>
                  <span
                    class="ml-2 px-2 py-0.5 rounded-full text-xs font-medium
                      {{if
                        (eq child.status 'completed')
                        'bg-green-100 text-green-700'
                      }}
                      {{if
                        (eq child.status 'done')
                        'bg-green-100 text-green-700'
                      }}
                      {{if
                        (eq child.status 'failed')
                        'bg-red-100 text-red-700'
                      }}
                      {{if (eq child.status 'error') 'bg-red-100 text-red-700'}}
                      {{if
                        (eq child.status 'pending')
                        'bg-yellow-100 text-yellow-700'
                      }}
                      {{if
                        (eq child.status 'running')
                        'bg-accent-100 text-accent-700'
                      }}
                      "
                  >{{or child.status "unknown"}}</span>
                </li>
              {{/each}}
            </ul>
          </dd>
        </div>
      {{/if}}
    </dl>
  </div>
</div>