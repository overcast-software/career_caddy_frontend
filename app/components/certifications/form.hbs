<div class="grid gap-3">
  {{#if this.errorMessage}}<p class="text-xs text-red-400">{{this.errorMessage}}</p>{{/if}}

  <div class="grid grid-cols-2 gap-3">
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">Issuer</span>
      <input
        type="text"
        value={{@certification.issuer}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "issuer")}}
      />
    </label>
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">Title</span>
      <input
        type="text"
        value={{@certification.title}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "title")}}
      />
    </label>
  </div>

  <label class="flex flex-col gap-1">
    <span class="text-xs text-gray-400 uppercase tracking-wide">Issue Date</span>
    <input
      type="date"
      value={{this.formattedIssueDate}}
      class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
      {{on "input" (fn this.updateField "issueDate")}}
    />
  </label>

  <label class="flex flex-col gap-1">
    <span class="text-xs text-gray-400 uppercase tracking-wide">Content
      <span class="normal-case font-normal" style="color: var(--muted)">&mdash; overrides default display (issuer, title, date)</span>
    </span>
    <textarea
      rows="3"
      placeholder="Leave blank to auto-generate from fields above"
      class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
      {{on "input" (fn this.updateField "content")}}
    >{{@certification.content}}</textarea>
  </label>
</div>