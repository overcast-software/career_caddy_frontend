<form class="builder-form two-col" {{on "submit" this.submitEdit}}>
  <div class="field">
    <label class="field-label" for="title">Title</label>
    <input
      id="title"
      type="text"
      value={{@jobPost.title}}
      {{on "input" (fn this.updateField "title")}}
      required
    />
  </div>

  <div class="field">
    <label class="field-label" for="url">URL</label>
    <input
      id="url"
      type="text"
      value={{@jobPost.link}}
      {{on "input" (fn this.updateField "link")}}
    />
  </div>

  <div class="field">
    <label class="field-label">Company</label>
    <PowerSelectWithCreate
      @search={{this.searchCompanies}}
      @onCreate={{this.addCompanyToJobPost}}
      @onChange={{this.updateCompany}}
      @selected={{this.selectedCompany}}
      @placeholder="Search or create a company…"
      as |company|
    >
      {{company.name}}
    </PowerSelectWithCreate>
  </div>

  <div class="field">
    <label class="field-label" for="posted-date">Posted Date</label>
    <input
      id="posted-date"
      type="date"
      value={{if
        @jobPost.postedDate
        (moment-format @jobPost.postedDate "YYYY-MM-DD")
        ""
      }}
      {{on "change" (fn this.updateDateField "postedDate")}}
    />
  </div>

  <div class="field">
    <label class="field-label" for="source">Source</label>
    <select id="source" {{on "change" (fn this.updateField "source")}}>
      {{#each this.sourceOptions as |opt|}}
        <option
          value={{opt}}
          selected={{eq @jobPost.source opt}}
        >{{opt}}</option>
      {{/each}}
    </select>
  </div>

  <div class="field-full">
    <label class="field-label" for="description">Description</label>
    <textarea
      id="description"
      rows="12"
      {{on "input" (fn this.updateField "description")}}
    >{{@jobPost.description}}</textarea>
  </div>

  <div class="form-actions justify-end">
    <button type="submit" class="btn primary">Save</button>
    <button type="button" class="btn" {{on "click" this.cancel}}>Cancel</button>
    <button
      type="button"
      class="btn danger"
      {{on "click" this.confirmDelete}}
    >Delete</button>
  </div>

  {{#if this.showDeleteConfirm}}
    <div
      class="field-full mt-4 rounded-lg border border-red-300 dark:border-red-800 bg-red-50 dark:bg-red-950/40 p-4"
    >
      <p class="text-sm font-medium text-red-800 dark:text-red-300 mb-3">
        Are you sure you want to delete this job post?
      </p>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          class="btn danger"
          {{on "click" this.submitDelete}}
        >Delete post only</button>
        {{#if this.isStaff}}
          <button
            type="button"
            class="btn bg-amber-600 hover:bg-amber-700 text-white dark:bg-amber-500 dark:hover:bg-amber-600"
            title="Delete job post AND all scores, scrapes, applications, questions, cover letters, summaries"
            {{on "click" this.nuclearDelete}}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-5 shrink-0 inline-block mr-1"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"
              />
            </svg>
            Nuclear — delete everything</button>
        {{/if}}
        <button
          type="button"
          class="btn"
          {{on "click" this.cancelDelete}}
        >Cancel</button>
      </div>
    </div>
  {{/if}}

  <div
    class="field-full mt-6 rounded-lg border border-gray-200 dark:border-gray-700 p-4"
  >
    <label class="field-label" for="reextract-text">Re-extract from paste</label>
    <p class="mt-1 mb-2 text-sm text-gray-600 dark:text-gray-400">
      Paste the job posting page text here and we'll re-run the AI extractor to
      refresh title, description, salary, location, and posted date on this job
      post. Company is left alone.
    </p>
    <textarea
      id="reextract-text"
      class="w-full min-h-[10rem] font-mono text-sm"
      placeholder="Paste fresh job posting content…"
      value={{this.pasteText}}
      disabled={{this.reextracting}}
      {{on "input" this.updatePasteText}}
    ></textarea>
    <div class="mt-3 flex justify-end">
      <button
        type="button"
        class="btn"
        disabled={{not this.canReextract}}
        {{on "click" this.reextractFromPaste}}
      >{{if
          this.reextracting
          "Re-extracting…"
          "Re-extract from paste"
        }}</button>
    </div>
  </div>

</form>