<form class="builder-form two-col" {{on "submit" this.submitEdit}}>
  <div class="field">
    <label class="field-label" for="title">Title</label>
    <input
      id="title"
      type="text"
      value={{@jobPost.title}}
      {{on "input" (fn this.updateField "title")}}
      required
    />
  </div>

  <div class="field">
    <label class="field-label" for="url">URL</label>
    <input
      id="url"
      type="text"
      value={{@jobPost.link}}
      {{on "input" (fn this.updateField "link")}}
    />
  </div>

  <div class="field-full">
    <label class="field-label" for="canonical-link">Canonical URL</label>
    <p class="mt-1 mb-2 text-sm text-gray-600 dark:text-gray-400">
      Computed from URL on save. Career Caddy uses this to detect
      within-platform duplicates.
    </p>
    <div
      id="canonical-link"
      data-test-canonical-link
      class="block w-full rounded-md border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/60 p-2 font-mono text-sm text-gray-700 dark:text-gray-300 break-all"
    >
      {{#if @jobPost.canonicalLink}}
        {{@jobPost.canonicalLink}}
      {{else}}
        <span class="text-gray-400 italic">— (no canonical URL yet)</span>
      {{/if}}
    </div>
  </div>

  <div class="field">
    <label class="field-label" for="apply-url">Apply URL</label>
    <input
      id="apply-url"
      type="text"
      data-test-apply-url
      value={{this.applyUrlInput}}
      {{on "input" this.updateApplyUrl}}
    />
    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">
      Employer ATS destination. Career Caddy uses this to detect cross-platform
      duplicates.
    </p>
  </div>

  <div class="field">
    <label class="field-label">Company</label>
    <PowerSelectWithCreate
      @search={{this.searchCompanies}}
      @onCreate={{this.addCompanyToJobPost}}
      @onChange={{this.updateCompany}}
      @selected={{this.selectedCompany}}
      @placeholder="Search or create a company…"
      as |company|
    >
      {{company.name}}
    </PowerSelectWithCreate>
  </div>

  <div class="field">
    <label class="field-label" for="posted-date">Posted Date</label>
    <input
      id="posted-date"
      type="date"
      value={{if
        @jobPost.postedDate
        (moment-format @jobPost.postedDate "YYYY-MM-DD")
        ""
      }}
      {{on "change" (fn this.updateDateField "postedDate")}}
    />
  </div>

  <div class="field">
    <label class="field-label" for="source">Source</label>
    <select id="source" {{on "change" (fn this.updateField "source")}}>
      {{#each this.sourceOptions as |opt|}}
        <option
          value={{opt}}
          selected={{eq @jobPost.source opt}}
        >{{opt}}</option>
      {{/each}}
    </select>
  </div>

  <div class="field-full">
    <label class="field-label" for="description">Description</label>
    <textarea
      id="description"
      rows="12"
      {{on "input" (fn this.updateField "description")}}
    >{{@jobPost.description}}</textarea>
  </div>

  <div
    class="field-full mt-2 rounded-lg border border-gray-200 dark:border-gray-700 p-4"
    data-test-visibility
  >
    <label class="field-label" for="visibility">Visibility</label>
    <p class="mt-1 mb-3 text-sm text-gray-600 dark:text-gray-400">
      Controls who can see this post in federated contexts. Public posts are
      addressed to the ActivityStreams public collection; Private posts have no
      audience and stay local. Single-user instance today — future granularity
      (Followers / Unlisted) will appear here without changing the stored shape.
    </p>
    <select
      id="visibility"
      data-test-visibility-select
      {{on "change" this.updateVisibility}}
    >
      <option value="public" selected={{this.isPublic}}>Public</option>
      <option value="private" selected={{not this.isPublic}}>Private</option>
    </select>
  </div>

  <div
    class="field-full mt-2 rounded-lg border border-gray-200 dark:border-gray-700 p-4"
    data-test-duplicate-handling
  >
    <div class="mb-3 flex items-start justify-between gap-3">
      <div>
        <label class="field-label">Duplicate handling</label>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
          Manually link this post to a known duplicate, or promote it to the
          canonical row for its cluster. The system also auto-detects matches on
          canonical URL, apply URL, and fingerprint.
        </p>
      </div>
      <LinkTo
        @route="admin.job-posts.dupes"
        @model={{@jobPost.id}}
        class="btn shrink-0"
        data-test-manage-dupes
      >Manage dupes →</LinkTo>
    </div>

    {{#if @jobPost.duplicateOfId}}
      <div
        class="mb-3 rounded-md border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-950/40 p-3 text-sm"
        data-test-current-duplicate-target
      >
        <div class="flex items-center justify-between gap-3">
          <div>
            <span
              class="font-medium text-amber-900 dark:text-amber-100"
            >Duplicate of:</span>
            <LinkTo
              @route="job-posts.show"
              @model={{@jobPost.duplicateOfId}}
              class="ml-2 underline text-amber-900 dark:text-amber-100 hover:opacity-80"
              data-test-current-duplicate-link
            >
              #{{@jobPost.duplicateOfId}}
            </LinkTo>
          </div>
          <div class="flex gap-2">
            <button
              type="button"
              class="btn"
              disabled={{this.dupSubmitting}}
              data-test-promote-canonical
              {{on "click" this.promoteCanonical}}
            >Promote this post</button>
            <button
              type="button"
              class="btn"
              disabled={{this.dupSubmitting}}
              data-test-unlink-duplicate
              {{on "click" this.unlinkDuplicate}}
            >Unlink</button>
          </div>
        </div>
      </div>
    {{/if}}

    <div class="field">
      <label class="field-label" for="dup-picker">
        Mark as duplicate of another post
      </label>
      <PowerSelect
        @search={{this.searchJobPosts}}
        @onChange={{this.selectDupTarget}}
        @selected={{this.selectedDupTarget}}
        @placeholder="Search posts by title, company, or URL…"
        @searchEnabled={{true}}
        @renderInPlace={{false}}
        @disabled={{this.dupSubmitting}}
        data-test-duplicate-picker
        as |post|
      >
        <div class="flex flex-col">
          <span class="text-sm">{{post.title}}</span>
          {{#if post.company}}
            <span
              class="text-xs text-gray-500 dark:text-gray-400"
            >{{post.company.name}}</span>
          {{/if}}
        </div>
      </PowerSelect>
      {{#if this.selectedDupTarget}}
        <div
          class="mt-3 flex flex-wrap items-center gap-2"
          data-test-dup-target-actions
        >
          <button
            type="button"
            class="btn primary"
            disabled={{this.dupSubmitting}}
            data-test-dup-target-mark
            {{on "click" this.confirmMarkAsDuplicate}}
          >Mark as duplicate</button>
          <LinkTo
            @route="admin.dedupe.compare"
            @models={{array @jobPost.id this.selectedDupTarget.id}}
            class="btn"
            data-test-dup-target-compare
          >Compare side-by-side</LinkTo>
          <button
            type="button"
            class="btn"
            disabled={{this.dupSubmitting}}
            data-test-dup-target-clear
            {{on "click" this.clearDupTarget}}
          >Clear</button>
        </div>
      {{/if}}
    </div>
  </div>

  <div class="form-actions justify-end">
    <button type="submit" class="btn primary">Save</button>
    <button type="button" class="btn" {{on "click" this.cancel}}>Cancel</button>
    <button
      type="button"
      class="btn danger"
      data-test-delete-trigger
      {{on "click" this.confirmDelete}}
    >Delete</button>
  </div>

  {{#if this.showDeleteConfirm}}
    <div
      class="field-full mt-4 rounded-lg border border-red-300 dark:border-red-800 bg-red-50 dark:bg-red-950/40 p-4"
    >
      <p class="text-sm font-medium text-red-800 dark:text-red-300 mb-3">
        Are you sure you want to delete this job post?
      </p>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          class="btn danger"
          data-test-delete-confirm
          {{on "click" this.submitDelete}}
        >Delete post only</button>
        {{#if this.isStaff}}
          <button
            type="button"
            class="btn bg-amber-600 hover:bg-amber-700 text-white dark:bg-amber-500 dark:hover:bg-amber-600"
            title="Delete job post AND all scores, scrapes, applications, questions, cover letters, summaries"
            data-test-nuclear-delete
            {{on "click" this.nuclearDelete}}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-5 shrink-0 inline-block mr-1"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"
              />
            </svg>
            Nuclear — delete everything</button>
        {{/if}}
        <button
          type="button"
          class="btn"
          {{on "click" this.cancelDelete}}
        >Cancel</button>
      </div>
    </div>
  {{/if}}

  <div
    class="field-full mt-6 rounded-lg border border-gray-200 dark:border-gray-700 p-4"
  >
    <label class="field-label" for="reextract-text">Re-extract from paste</label>
    <p class="mt-1 mb-2 text-sm text-gray-600 dark:text-gray-400">
      Paste the job posting page text here and we'll re-run the AI extractor to
      refresh title, description, salary, location, and posted date on this job
      post. Company is left alone.
    </p>
    <textarea
      id="reextract-text"
      class="w-full min-h-[10rem] font-mono text-sm"
      placeholder="Paste fresh job posting content…"
      value={{this.pasteText}}
      disabled={{this.reextracting}}
      {{on "input" this.updatePasteText}}
    ></textarea>
    <div class="mt-3 flex justify-end">
      <button
        type="button"
        class="btn"
        disabled={{not this.canReextract}}
        {{on "click" this.reextractFromPaste}}
      >{{if
          this.reextracting
          "Re-extracting…"
          "Re-extract from paste"
        }}</button>
    </div>
  </div>

</form>