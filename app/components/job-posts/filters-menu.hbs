<div class="relative inline-block" data-filters-menu-root>
  <button
    type="button"
    class="inline-flex items-center gap-1.5 rounded border border-gray-300 bg-white px-2.5 py-1 text-xs text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200 dark:hover:bg-gray-700"
    aria-haspopup="true"
    aria-expanded={{this.open}}
    {{on "click" this.toggle}}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="size-4"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z"
      />
    </svg>
    Filters
    {{#if this.activeCount}}
      <span
        class="ml-1 inline-flex min-w-4 items-center justify-center rounded-full bg-accent-500 px-1.5 py-0.5 text-[10px] font-semibold leading-none text-white"
      >{{this.activeCount}}</span>
    {{/if}}
  </button>

  {{#if this.open}}
    <button
      type="button"
      aria-label="Close filters menu"
      class="fixed inset-0 z-10 cursor-default bg-transparent"
      {{on "click" this.close}}
    ></button>
    <div
      class="absolute right-0 z-20 mt-2 w-72 rounded-lg border border-gray-200 bg-white p-3 shadow-lg dark:border-gray-700 dark:bg-gray-800"
      role="menu"
    >
      <div class="flex items-center justify-between pb-2">
        <h3
          class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400"
        >Filters</h3>
        {{#if this.activeCount}}
          <button
            type="button"
            class="text-xs text-gray-500 underline hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-100"
            {{on "click" this.clearAll}}
          >Clear all</button>
        {{/if}}
      </div>

      <label
        class="mb-3 flex items-center gap-2 text-sm text-gray-700 dark:text-gray-200"
      >
        <input
          type="checkbox"
          class="rounded border-gray-300 dark:border-gray-600"
          checked={{@filters.excludeVettedBad}}
          {{on "change" this.setExcludeVettedBad}}
        />
        <span>Hide <span class="font-medium">Vetted Bad</span></span>
      </label>

      <div class="mb-3">
        <div
          class="mb-1 text-xs font-medium text-gray-600 dark:text-gray-300"
        >Stubs</div>
        <div
          class="inline-flex w-full overflow-hidden rounded border border-gray-300 dark:border-gray-600"
        >
          <button
            type="button"
            class="flex-1 px-2 py-1 text-xs
              {{if
                @filters.stub
                'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700'
                'bg-accent-500 text-white'
              }}"
            {{on "click" (fn this.setStub "")}}
          >All</button>
          <button
            type="button"
            class="flex-1 border-l border-gray-300 px-2 py-1 text-xs dark:border-gray-600
              {{if
                (eq @filters.stub 'false')
                'bg-accent-500 text-white'
                'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700'
              }}"
            {{on "click" (fn this.setStub "false")}}
          >Hide</button>
          <button
            type="button"
            class="flex-1 border-l border-gray-300 px-2 py-1 text-xs dark:border-gray-600
              {{if
                (eq @filters.stub 'true')
                'bg-accent-500 text-white'
                'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700'
              }}"
            {{on "click" (fn this.setStub "true")}}
          >Only</button>
        </div>
      </div>

      <div class="mb-3">
        <div
          class="mb-1 text-xs font-medium text-gray-600 dark:text-gray-300"
        >Scoring</div>
        <div
          class="inline-flex w-full overflow-hidden rounded border border-gray-300 dark:border-gray-600"
        >
          <button
            type="button"
            class="flex-1 px-2 py-1 text-xs
              {{if
                @filters.scored
                'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700'
                'bg-accent-500 text-white'
              }}"
            {{on "click" (fn this.setScored "")}}
          >All</button>
          <button
            type="button"
            class="flex-1 border-l border-gray-300 px-2 py-1 text-xs dark:border-gray-600
              {{if
                (eq @filters.scored 'true')
                'bg-accent-500 text-white'
                'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700'
              }}"
            {{on "click" (fn this.setScored "true")}}
          >Scored</button>
          <button
            type="button"
            class="flex-1 border-l border-gray-300 px-2 py-1 text-xs dark:border-gray-600
              {{if
                (eq @filters.scored 'false')
                'bg-accent-500 text-white'
                'text-gray-700 hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700'
              }}"
            {{on "click" (fn this.setScored "false")}}
          >Unscored</button>
        </div>
      </div>

      <label class="block text-xs font-medium text-gray-600 dark:text-gray-300">
        <span class="mb-1 block">Source</span>
        <select
          class="w-full rounded border border-gray-300 bg-white px-2 py-1 text-sm dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100"
          {{on "change" this.setSource}}
        >
          <option value="" selected={{not @filters.source}}>All sources</option>
          {{#each this.sources as |s|}}
            <option value={{s}} selected={{eq @filters.source s}}>{{s}}</option>
          {{/each}}
        </select>
      </label>
    </div>
  {{/if}}
</div>