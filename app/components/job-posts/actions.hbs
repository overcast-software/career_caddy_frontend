<section class="job-post-controls">
  <div class="field-full">
    <label class="field-label">Resume</label>
    <PowerSelect
      @options={{this.resumeOptions}}
      @onChange={{this.updateResume}}
      @selected={{this.selectedResume}}
      @placeholder="Select a resume"
      as |resume|
    >
      {{or resume.name resume.title}}
    </PowerSelect>
  </div>
  <div class="actions">
    {{#if @jobPost.scrapes.length}}
      <LinkTo
        @route="scrapes.show"
        @model={{get @jobPost.scrapes "0"}}
        class="btn btn-sm"
      >View Scrape</LinkTo>
    {{else}}
      <button
        type="button"
        class="btn btn-sm"
        {{on "click" this.createScrape}}
      >Create Scrape</button>
    {{/if}}
  </div>

  {{#if this.selectedResume}}
    {{#unless @jobPost.description}}
      <p class="text-sm text-amber-600">Job description is missing — AI actions
        are disabled.</p>
    {{/unless}}
    <div class="actions">
      <button
        type="button"
        class="btn"
        disabled={{not @jobPost.description}}
        {{on "click" this.scoreResume}}
      >Score against job post</button>
      <button
        type="button"
        class="btn"
        disabled={{not @jobPost.description}}
        {{on "click" this.createSummary}}
      >Create new resume summary</button>
      <button
        type="button"
        class="btn"
        disabled={{not @jobPost.description}}
        {{on "click" this.createCoverLetter}}
      >Create cover letter</button>
      <LinkTo
        @route="job-posts.show.job-applications.new"
        @model={{@jobPost}}
        class="btn"
      >
        Apply
      </LinkTo>
    </div>
  {{/if}}

</section>
{{yield}}