{{#if this.jobPosts.length}}
  <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
    <table class="min-w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Title</th>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600"
          >Company</th>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600"
          >Posted</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-600">Score</th>
          <th
            class="px-4 py-3 text-left font-semibold text-gray-600"
          >Status</th>
          <th
            class="px-4 py-3 text-right font-semibold text-gray-600"
          >Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {{#each this.jobPosts as |jobPost|}}
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-900">
              <LinkTo @route="job-posts.show" @model={{jobPost}}>
                {{jobPost.title}}
              </LinkTo>
              {{#if jobPost.needsScrape}}
                <span
                  class="ml-2 inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600"
                >
                  needs scrape
                </span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-gray-600">
              {{~#if jobPost.company.name~}}
                {{jobPost.company.name}}
              {{~else~}}
                <span class="italic text-amber-500">missing</span>
              {{~/if~}}
            </td>
            <td class="px-4 py-3 text-gray-600">
              {{moment-format
                (if jobPost.postedDate jobPost.postedDate jobPost.createdAt)
                "MMM D, YYYY"
              }}
            </td>
            <td class="px-4 py-3 text-gray-600">
              {{#if jobPost.topScore.score}}
                <span class="font-medium text-accent-600">
                  <LinkTo @route="scores.show" @model={{jobPost.topScore}}>
                    {{jobPost.topScore.score}}
                  </LinkTo>
                </span>
              {{else}}
                <span class="text-gray-300">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3">
              {{#if jobPost.activeApplicationStatus}}
                <span
                  class="inline-flex items-center rounded-full bg-accent-50 px-2 py-0.5 text-xs font-medium text-accent-700 dark:bg-accent-900/40 dark:text-accent-200"
                >{{jobPost.activeApplicationStatus}}</span>
              {{else}}
                <span class="text-gray-300">—</span>
              {{/if}}
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                {{#if
                  (and jobPost.isStub jobPost.link (not jobPost.hasAnyScore))
                }}
                  {{! Stub + scrapable link + not yet scored: the most
                      useful action is to enrich via scrape and then
                      score against career-data. Once any score exists
                      we stop nagging and drop to the plain Score link. }}
                  <button
                    type="button"
                    class="inline-flex items-center gap-1.5 px-2 py-1 text-xs rounded border border-accent-200 text-accent-600 hover:bg-accent-50 disabled:opacity-70 disabled:cursor-not-allowed dark:border-accent-700 dark:text-accent-300 dark:hover:bg-accent-900/30"
                    disabled={{jobPost.isWorking}}
                    {{on "click" (fn this.scrapeAndScore jobPost)}}
                  >
                    {{#if jobPost.isWorking}}
                      <svg
                        class="animate-spin size-3.5"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <circle
                          class="opacity-25"
                          cx="12"
                          cy="12"
                          r="10"
                          stroke="currentColor"
                          stroke-width="4"
                        ></circle>
                        <path
                          class="opacity-75"
                          fill="currentColor"
                          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"
                        ></path>
                      </svg>
                      {{or jobPost.busyPhase "Working…"}}
                    {{else}}
                      Scrape & Score
                    {{/if}}
                  </button>
                {{else}}
                  <LinkTo
                    @route="job-posts.show.scores"
                    @model={{jobPost}}
                    class="px-2 py-1 text-xs rounded border border-gray-200 text-gray-600 hover:bg-gray-100"
                  >Score</LinkTo>
                {{/if}}
              </div>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{else}}
  <EmptyState @message="No job posts found." />
{{/if}}