<div class="grid gap-3">
  <label class="flex flex-col gap-1">
    <span class="text-xs text-gray-400 uppercase tracking-wide">Title</span>
    <input
      type="text"
      value={{@project.title}}
      class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
      {{on "input" (fn this.updateField "title")}}
    />
  </label>

  <label class="flex flex-col gap-1">
    <span class="text-xs text-gray-400 uppercase tracking-wide">Description</span>
    <textarea
      rows="3"
      class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
      {{on "input" (fn this.updateField "description")}}
    >{{@project.description}}</textarea>
  </label>

  <div class="grid grid-cols-2 gap-3">
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">Start Date</span>
      <input
        type="date"
        value={{this.formattedStartDate}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "startDate")}}
      />
    </label>
    <label class="flex flex-col gap-1">
      <span class="text-xs text-gray-400 uppercase tracking-wide">End Date</span>
      <input
        type="date"
        value={{this.formattedEndDate}}
        class="w-full rounded-md border border-gray-600 bg-gray-800 px-3 py-2 text-sm text-gray-200 focus:border-accent-500 focus:outline-none focus:ring-1 focus:ring-accent-500"
        {{on "input" (fn this.updateField "endDate")}}
      />
    </label>
  </div>

  <label class="flex items-center gap-2 text-sm text-gray-300">
    <input
      type="checkbox"
      checked={{@project.isActive}}
      class="rounded border-gray-600 bg-gray-800 text-accent-500 focus:ring-accent-500"
      {{on "change" (fn this.updateField "isActive")}}
    />
    Active
  </label>
</div>